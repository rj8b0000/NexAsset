@if (Style == "skeleton")
{
    <!-- Skeleton Loading Block -->
    <div class="card-custom w-100 animate-fade-in">
        <!-- Header Skeleton -->
        <div class="d-flex align-items-center gap-3 border-bottom pb-4 mb-4">
            <div class="skeleton-circle" style="width: 48px; height: 48px; border-radius: 50%;"></div>
            <div class="flex-grow-1">
                <div class="skeleton-line" style="width: 250px; height: 16px; margin-bottom: 8px;"></div>
                <div class="skeleton-line" style="width: 150px; height: 10px;"></div>
            </div>
        </div>
        
        <!-- Content Lines Skeleton -->
        <div class="d-flex flex-column gap-3">
            <div class="skeleton-line" style="width: 100%; height: 12px;"></div>
            <div class="skeleton-line" style="width: 90%; height: 12px;"></div>
            <div class="skeleton-line" style="width: 95%; height: 12px;"></div>
            <div class="skeleton-line" style="width: 60%; height: 12px; margin-bottom: 24px;"></div>
        </div>
        
        <!-- Table Skeleton Grid -->
        <div class="border rounded p-3">
            <div class="d-flex gap-3 mb-3 border-bottom pb-2">
                <div class="skeleton-line" style="width: 5%; height: 10px;"></div>
                <div class="skeleton-line" style="width: 25%; height: 10px;"></div>
                <div class="skeleton-line" style="width: 25%; height: 10px;"></div>
                <div class="skeleton-line" style="width: 25%; height: 10px;"></div>
                <div class="skeleton-line" style="width: 20%; height: 10px;"></div>
            </div>
            @for (int i = 0; i < 3; i++)
            {
                <div class="d-flex gap-3 mb-3">
                    <div class="skeleton-line" style="width: 5%; height: 12px;"></div>
                    <div class="skeleton-line" style="width: 25%; height: 12px;"></div>
                    <div class="skeleton-line" style="width: 25%; height: 12px;"></div>
                    <div class="skeleton-line" style="width: 25%; height: 12px;"></div>
                    <div class="skeleton-line" style="width: 20%; height: 12px;"></div>
                </div>
            }
        </div>
    </div>
}
else if (Style == "progress")
{
    <!-- Progress Bar -->
    <div class="w-100 p-4 text-center animate-fade-in">
        <span class="text-caption text-secondary d-block mb-2">@Message</span>
        <div class="progress" style="height: 6px; background-color: var(--border-color); border-radius: 3px; overflow: hidden;">
            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 75%; background-color: var(--primary); height: 100%; transition: width 0.5s ease-in-out;"></div>
        </div>
    </div>
}
else
{
    <!-- Spinner -->
    <div class="w-100 p-5 text-center d-flex flex-column align-items-center justify-content-center gap-3 animate-fade-in" style="min-height: 200px;">
        <div class="spinner-custom"></div>
        <span class="text-caption text-secondary">@Message</span>
    </div>
}

@code {
    [Parameter] public string Style { get; set; } = "spinner"; // spinner, progress, skeleton
    [Parameter] public string Message { get; set; } = "Loading resource...";
}
