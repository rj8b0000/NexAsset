@*
    Small labeled text/textarea input for form views. Two-way binds via
    Value/ValueChanged and shows a per-field validation message when Error is set.
*@
<div class="@ColumnClass">
    <label class="form-label-custom">
        @Label
        @if (Required)
        {
            <span style="color: var(--danger);"> *</span>
        }
    </label>
    @if (Multiline)
    {
        <textarea class="form-control-custom" rows="@Rows" placeholder="@Placeholder" style="@BorderStyle" value="@Value" @oninput="HandleInput"></textarea>
    }
    else
    {
        <input type="@Type" class="form-control-custom" placeholder="@Placeholder" style="@BorderStyle" value="@Value" @oninput="HandleInput" />
    }
    @if (HasError)
    {
        <div class="text-caption mt-1" style="color: var(--danger); font-size: 11px;">@Error</div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public EventCallback OnInput { get; set; }
    [Parameter] public bool Required { get; set; }
    [Parameter] public string Type { get; set; } = "text";
    [Parameter] public bool Multiline { get; set; }
    [Parameter] public int Rows { get; set; } = 3;
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string ColumnClass { get; set; } = "col-md-6";

    private bool HasError => !string.IsNullOrEmpty(Error);
    private string BorderStyle => HasError ? "border-color: var(--danger);" : "";

    private async Task HandleInput(ChangeEventArgs e)
    {
        await ValueChanged.InvokeAsync(e.Value?.ToString() ?? "");
        await OnInput.InvokeAsync();
    }
}
