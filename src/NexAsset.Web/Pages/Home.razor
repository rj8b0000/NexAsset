@page "/"
@page "/dashboard"
@attribute [Authorize]
@using NexAsset.Web.State
@using NexAsset.Web.Infrastructure.Dashboard
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Models.Dashboard
@using NexAsset.Web.Shared.Models
@inject IDashboardApiClient DashboardApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject NotificationState NotificationState
@inject NavigationState NavigationState
@inject NavigationManager NavigationManager
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms
@implements IDisposable

<!-- DASHBOARD VIEW -->
<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <span class="text-caption text-secondary">Live operational summary for @(Perms.IsSuperAdmin ? "the selected organization" : "your organization").</span>
    @* Only SuperAdmin may look across organizations; everyone else is pinned to their own. *@
    @if (Perms.IsSuperAdmin)
    {
        <div style="min-width: 260px;">
            <select class="form-control-custom py-1 px-2" value="@(_selectedOrgId?.ToString() ?? "")" @onchange="OnOrgChangedAsync">
                @foreach (var org in _orgs)
                {
                    <option value="@org.Id" selected="@(org.Id == _selectedOrgId)">@org.Code — @org.Name</option>
                }
            </select>
        </div>
    }
</div>

@if (_loadError is not null)
{
    <EmptyState Title="Couldn't load the dashboard" Description="@_loadError"
                IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                OnActionClick="LoadSummaryAsync" />
}
else if (_summary is null)
{
    <LoadingState Message="Loading dashboard..." />
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Total Assets" Value="@_summary.Assets.ToString()" IconClass="lucide-box" TrendLabel="@UtilizationLabel" Trend="neutral" Subtext="registered assets" Status="primary" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Assigned Assets" Value="@_summary.AssignedAssets.ToString()" IconClass="lucide-user-check" TrendLabel="In use" Trend="neutral" Subtext="with employees" Status="success" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Available Assets" Value="@_summary.AvailableAssets.ToString()" IconClass="lucide-box-select" TrendLabel="Ready" Trend="neutral" Subtext="ready to assign" Status="info" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Pending Approvals" Value="@_summary.PendingPurchaseRequests.ToString()" IconClass="lucide-check-square" TrendLabel="@($"{_summary.PendingPurchaseOrders} POs")" Trend="neutral" Subtext="purchase requests" Status="warning" />
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Employees" Value="@_summary.Employees.ToString()" IconClass="lucide-users" TrendLabel="Active" Trend="neutral" Subtext="in this organization" Status="primary" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Low Stock Items" Value="@_summary.LowStockItems.ToString()" IconClass="lucide-warehouse" TrendLabel="@(_summary.LowStockItems > 0 ? "Reorder" : "OK")" Trend="@(_summary.LowStockItems > 0 ? "down" : "neutral")" Subtext="at or below reorder level" Status="@(_summary.LowStockItems > 0 ? "danger" : "success")" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Open Service Tickets" Value="@_summary.OpenServiceTickets.ToString()" IconClass="lucide-headphones" TrendLabel="Support" Trend="neutral" Subtext="awaiting resolution" Status="info" />
        </div>
        <div class="col-md-3 col-sm-6">
            <StatCard Title="Under Maintenance" Value="@_summary.AssetsUnderMaintenance.ToString()" IconClass="lucide-wrench" TrendLabel="Repairs" Trend="neutral" Subtext="assets in service" Status="warning" />
        </div>
    </div>
}

<div class="row g-4">
    <!-- Left Side: Recent Activities -->
    <div class="col-lg-7 col-md-12">
        <div class="card-custom h-100">
            <div class="d-flex align-items-center justify-content-between border-bottom pb-3 mb-3">
                <h3 class="h2-title"><i class="lucide-history me-1 text-primary"></i> Recent System Activity</h3>
                <button class="btn-custom btn-custom-secondary py-1 px-3 text-caption" @onclick='() => NavigationManager.NavigateTo("/administration/timeline")'>Full Log</button>
            </div>

            <div class="d-flex flex-column gap-3" style="max-height: 380px; overflow-y: auto;">
                @foreach (var act in NotificationState.Activities.Take(5))
                {
                    <div class="d-flex gap-3 align-items-start py-2 timeline-activity-item">
                        <div class="position-relative">
                            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold text-caption" style="width: 32px; height: 32px; background-color: var(--primary-light); color: var(--primary); font-size: 11px;">
                                @(act.User.Substring(0, Math.Min(2, act.User.Length)).ToUpper())
                            </div>
                            <!-- Colored status dot -->
                            <span class="position-absolute bottom-0 end-0 rounded-circle border border-white" style="width: 8px; height: 8px; background-color: @(act.Title.Contains("Created") || act.Title.Contains("Added") || act.Title.Contains("Success") ? "var(--success)" : act.Title.Contains("Deleted") || act.Title.Contains("Error") ? "var(--danger)" : "var(--info)");"></span>
                        </div>
                        <div class="flex-grow-1" style="line-height: 1.3;">
                            <div class="fw-semibold text-caption" style="color: var(--text-primary);">@act.Title</div>
                            <span class="text-caption text-secondary" style="font-size: 12px;">@act.Details</span>
                            <div class="d-flex align-items-center gap-2 mt-1" style="font-size: 10px; color: var(--text-muted);">
                                <span><i class="lucide-user" style="font-size: 10px;"></i> @act.User</span>
                                <span>•</span>
                                <span><i class="lucide-clock" style="font-size: 10px;"></i> @act.Timestamp.ToString("MM-dd HH:mm")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Right Side: Quick Action Panel + Quick Stats -->
    <div class="col-lg-5 col-md-12">
        <div class="card-custom h-100 d-flex flex-column justify-content-between">
            <div>
                <h3 class="h2-title border-bottom pb-3 mb-3"><i class="lucide-zap me-1 text-warning"></i> Operational Shortcuts</h3>
                <div class="row g-3">
                    <div class="col-6">
                        <button type="button" class="dashboard-shortcut-btn w-100" @onclick='() => NavigationManager.NavigateTo("/assets")'>
                            <i class="lucide-plus-circle fs-3 text-primary"></i>
                            <span class="fw-semibold">Add Asset</span>
                        </button>
                    </div>
                    <div class="col-6">
                        <button type="button" class="dashboard-shortcut-btn w-100" @onclick='() => NavigationManager.NavigateTo("/assets")'>
                            <i class="lucide-user-plus fs-3 text-success"></i>
                            <span class="fw-semibold">Assign Item</span>
                        </button>
                    </div>
                    <div class="col-6">
                        <button type="button" class="dashboard-shortcut-btn w-100" @onclick='() => NavigationManager.NavigateTo("/procurement")'>
                            <i class="lucide-file-text fs-3 text-info"></i>
                            <span class="fw-semibold">New PR</span>
                        </button>
                    </div>
                    <div class="col-6">
                        <button type="button" class="dashboard-shortcut-btn w-100" @onclick='() => NavigationManager.NavigateTo("/maintenance")'>
                            <i class="lucide-wrench fs-3 text-warning"></i>
                            <span class="fw-semibold">Maint. Ticket</span>
                        </button>
                    </div>
                </div>
            </div>
            <div class="pt-4 border-top mt-4">
                <div class="d-flex align-items-center justify-content-between text-caption text-secondary">
                    <span>Operations database status:</span>
                    <span class="badge-custom badge-custom-success"><i class="lucide-check-circle-2 me-1"></i> Synchronized</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private DashboardSummary? _summary;
    private string? _loadError;
    private Guid? _selectedOrgId;
    private List<(Guid Id, string Code, string Name)> _orgs = new();

    private string UtilizationLabel =>
        _summary is null || _summary.Assets == 0
            ? "—"
            : $"{_summary.AssignedAssets * 100 / _summary.Assets}% util";

    protected override async Task OnInitializedAsync()
    {
        NavigationState.OnChange += OnWorkspaceChanged;

        // Only SuperAdmin can pick an organization, so only it needs (and may read) the list.
        if (Perms.IsSuperAdmin)
        {
            var orgs = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
            if (orgs.IsSuccess && orgs.Data is not null)
                _orgs = orgs.Data.Items.Select(o => (o.Id, o.Code, o.Name)).ToList();
        }

        // Follow the workspace organization (sidebar switcher), then the user's own
        // organization, then the first one a SuperAdmin can see.
        _selectedOrgId = NavigationState.ActiveOrganizationId
                         ?? Perms.OrganizationId
                         ?? (_orgs.FirstOrDefault().Id is var id && id != Guid.Empty ? id : null);
        if (_selectedOrgId is null)
        {
            _loadError = Perms.IsSuperAdmin
                ? "No organizations exist yet. Create one to see dashboard data."
                : "Your account isn't linked to an organization yet. Ask an administrator to link your employee record.";
            return;
        }
        // Deliberately do not write the workspace organization here: a SuperAdmin who merely
        // opens the dashboard should stay unfocused ("All organizations"). The dashboard shows a
        // concrete organization's summary locally; focusing the whole app happens only when the
        // user picks one from the sidebar or the selector below.
        await LoadSummaryAsync();
    }

    // The sidebar/settings switcher changed the workspace org — follow it.
    private async void OnWorkspaceChanged()
    {
        if (NavigationState.ActiveOrganizationId is { } id && id != _selectedOrgId)
        {
            _selectedOrgId = id;
            await LoadSummaryAsync();
            StateHasChanged();
        }
    }

    private async Task OnOrgChangedAsync(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
        {
            _selectedOrgId = id;
            var org = _orgs.FirstOrDefault(o => o.Id == id);
            if (org.Id != Guid.Empty) NavigationState.SwitchOrganization(org.Id, org.Name);
            await LoadSummaryAsync();
        }
    }

    public void Dispose()
    {
        NavigationState.OnChange -= OnWorkspaceChanged;
    }

    private async Task LoadSummaryAsync()
    {
        if (_selectedOrgId is null) return;
        _loadError = null;
        _summary = null;
        var result = await DashboardApiClient.GetSummaryAsync(_selectedOrgId.Value);
        if (result.IsSuccess && result.Data is not null) _summary = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading the dashboard.";
    }
}
