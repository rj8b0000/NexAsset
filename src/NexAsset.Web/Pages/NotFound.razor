@page "/not-found"
@layout MainLayout
@inject NavigationManager NavigationManager

<div class="container py-5">
    <EmptyState Title="404 - Page Not Found"
                Description="The workspace view or ledger page you are attempting to access does not exist or has been relocated."
                IconClass="lucide-alert-circle"
                ActionLabel="Return to Dashboard"
                OnActionClick="GoHome" />
</div>

@code {
    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }
}