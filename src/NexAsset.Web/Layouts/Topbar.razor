@using NexAsset.Web.State
@using NexAsset.Web.Infrastructure.Services
@using NexAsset.Web.Infrastructure.Authentication
@inject NavigationState NavigationState
@inject IAuthenticationService AuthenticationService
@inject ICurrentUserService CurrentUser
@inject NotificationState NotificationState
@inject ThemeState ThemeState
@inject MockDatabaseService Db
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="topbar-slot h-100 w-100 d-flex align-items-center justify-content-between px-4" style="background-color: var(--bg-surface); border-bottom: 1px solid var(--border-color); color: var(--text-primary);">
    <!-- Left Section: Menu Toggle + Module Title + Branch Switcher -->
    <div class="d-flex align-items-center gap-3">
        <!-- Sidebar Toggle (Mobile only) -->
        <button type="button" class="btn-custom btn-custom-secondary p-1.5 d-md-none" style="border-radius: 8px;" @onclick="ToggleMobileSidebar">
            <i class="lucide-menu"></i>
        </button>

        <div class="d-flex align-items-center gap-2">
            <h2 class="h2-title mb-0" style="font-weight: 700; color: var(--text-primary);">@GetActivePageTitle()</h2>
            <span class="text-muted-custom">/</span>
            <!-- Branch Switcher -->
            <div class="dropdown">
                <button class="btn-custom py-1.5 px-3 border-0 bg-transparent text-caption d-flex align-items-center gap-1.5" 
                        style="color: var(--text-secondary); font-weight: 500;" @onclick="ToggleBranchDropdown">
                    <i class="lucide-map-pin" style="color: var(--primary);"></i>
                    <span>@NavigationState.ActiveBranch</span>
                    <i class="lucide-chevron-down fs-7"></i>
                </button>
                <div class="dropdown-menu p-1 @(BranchDropdownOpen ? "show" : "")" 
                     style="display: @(BranchDropdownOpen ? "block" : "none"); position: absolute; left: 0; z-index: 1020; margin-top: 4px; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-8); box-shadow: var(--shadow-md);">
                    @foreach (var br in Db.Branches)
                    {
                        <button type="button" class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" 
                                style="color: @(NavigationState.ActiveBranch == br ? "var(--primary)" : "var(--text-primary)");"
                                @onclick="() => SwitchBranch(br)">
                            @br
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Center Section: Global Search -->
    <div class="d-none d-lg-flex align-items-center flex-grow-1 mx-5" style="max-width: 400px;">
        <div class="position-relative w-100">
            <i class="lucide-search position-absolute text-muted-custom" style="left: 12px; top: 50%; transform: translateY(-50%); font-size: 14px;"></i>
            <input type="text" class="form-control-custom" style="padding-left: 36px; border-radius: 9999px; height: 38px;" 
                   placeholder="Search assets, employees, tickets..." @bind-value="GlobalSearchText" @bind-value:event="oninput" @onkeyup="HandleGlobalSearch" />
        </div>
    </div>

    <!-- Right Section: Quick Actions + Theme Toggle + Notifications + Profile -->
    <div class="d-flex align-items-center gap-3">
        
        <!-- Quick Action Shortcuts -->
        <div class="dropdown d-none d-sm-block">
            <button type="button" class="btn-custom btn-custom-primary py-1.5 px-3" style="border-radius: var(--radius-8);" @onclick="ToggleQuickActions">
                <i class="lucide-plus"></i> <span style="font-size: 13px;">Quick Action</span>
            </button>
            <div class="dropdown-menu dropdown-menu-end p-2 @(QuickActionsOpen ? "show" : "")" 
                 style="display: @(QuickActionsOpen ? "block" : "none"); position: absolute; right: 0; z-index: 1030; min-width: 180px; margin-top: 4px; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-8); box-shadow: var(--shadow-md);">
                <div class="text-label p-2" style="font-size: 10px;">Common tasks</div>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent text-primary-hover" style="color: var(--text-primary);" @onclick='() => QuickNavigate("/assets")'>
                    <i class="lucide-box me-2 text-primary"></i> Create Asset
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent text-primary-hover" style="color: var(--text-primary);" @onclick='() => QuickNavigate("/assets")'>
                    <i class="lucide-user-plus me-2 text-success"></i> Assign Asset
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent text-primary-hover" style="color: var(--text-primary);" @onclick='() => QuickNavigate("/procurement")'>
                    <i class="lucide-shopping-cart me-2 text-info"></i> Purchase Request
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent text-primary-hover" style="color: var(--text-primary);" @onclick='() => QuickNavigate("/maintenance/create")'>
                    <i class="lucide-wrench me-2 text-warning"></i> Maintenance Request
                </button>
            </div>
        </div>

        <!-- Light/Dark Mode Switcher -->
        <button type="button" class="btn-custom btn-custom-secondary p-2 rounded-circle" style="width: 38px; height: 38px; border-color: var(--border-color) !important; background-color: var(--bg-surface) !important;" @onclick="ToggleTheme">
            <i class="@(ThemeState.DarkMode ? "lucide-sun text-warning" : "lucide-moon text-dark") fs-5"></i>
        </button>

        <!-- Notifications Bell -->
        <div class="dropdown">
            <button type="button" class="btn-custom btn-custom-secondary p-2 rounded-circle position-relative" style="width: 38px; height: 38px; border-color: var(--border-color) !important; background-color: var(--bg-surface) !important;" @onclick="ToggleNotificationPanel">
                <i class="lucide-bell" style="color: var(--text-secondary);"></i>
                @if (GetUnreadNotificationsCount() > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-circle bg-danger border border-white" style="padding: 4px; font-size: 8px;">
                        <span class="visually-hidden">unread messages</span>
                    </span>
                }
            </button>
            <div class="dropdown-menu dropdown-menu-end p-0 @(NotificationPanelOpen ? "show" : "")" 
                 style="display: @(NotificationPanelOpen ? "block" : "none"); position: absolute; right: 0; z-index: 1020; width: 340px; margin-top: 8px; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-12); box-shadow: var(--shadow-lg); overflow: hidden;">
                <div class="p-3 border-bottom d-flex align-items-center justify-content-between bg-light-custom" style="background-color: var(--bg-surface-hover);">
                    <span class="fw-semibold text-caption" style="color: var(--text-primary);">Notifications</span>
                    @if (GetUnreadNotificationsCount() > 0)
                    {
                        <button class="btn-custom btn-custom-link text-caption p-0" style="font-size: 11px;" @onclick="MarkAllRead">Mark all read</button>
                    }
                </div>
                <div style="max-height: 280px; overflow-y: auto;">
                    @if (NotificationState.Notifications.Any())
                    {
                        @foreach (var not in NotificationState.Notifications)
                        {
                            <div class="p-3 border-bottom d-flex gap-3 text-start align-items-start @(not.IsRead ? "" : "bg-light-custom")" style="background-color: @(not.IsRead ? "transparent" : "var(--primary-light)"); transition: background-color var(--transition-fast);">
                                <span class="d-inline-block rounded-circle mt-1" style="width: 6px; height: 6px; background-color: @(not.Urgency == "High" ? "var(--danger)" : "var(--primary)"); flex-shrink: 0;"></span>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold text-caption" style="color: var(--text-primary); font-size: 12.5px;">@not.Title</div>
                                    <p class="text-secondary mb-1 mt-0.5" style="font-size: 11.5px; line-height: 1.4;">@not.Message</p>
                                    <span class="text-muted-custom" style="font-size: 10px;">@not.Timestamp.ToString("t")</span>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="py-5 text-center text-secondary text-caption">No notifications yet</div>
                    }
                </div>
                <div class="p-2 border-top text-center bg-light-custom" style="background-color: var(--bg-surface-hover);">
                    <button class="btn-custom btn-custom-link text-caption w-100 py-1" style="font-size: 12px; font-weight: 500;" @onclick='() => NavigateTo("/notifications")'>View all logs</button>
                </div>
            </div>
        </div>

        <!-- Profile Dropdown -->
        <div class="dropdown">
            <button type="button" class="btn-custom p-0.5 border-0 rounded-circle d-flex align-items-center justify-content-center" 
                    style="width: 38px; height: 38px; background-color: var(--primary-light); color: var(--primary); font-weight: 700; font-size: 13px;" @onclick="ToggleProfileDropdown">
                @GetUserInitials()
            </button>
            <div class="dropdown-menu dropdown-menu-end p-2 @(ProfileDropdownOpen ? "show" : "")" 
                 style="display: @(ProfileDropdownOpen ? "block" : "none"); position: absolute; right: 0; z-index: 1020; min-width: 200px; margin-top: 8px; background: var(--bg-surface); border: 1px solid var(--border-color); border-radius: var(--radius-12); box-shadow: var(--shadow-lg);">
                <div class="p-2 border-bottom mb-2 text-start">
                    <div class="fw-semibold text-caption" style="color: var(--text-primary);">@(CurrentUser.DisplayName ?? "NexAsset User")</div>
                    <span class="text-muted-custom" style="font-size: 11px;">@(CurrentUser.Email ?? "")</span>
                </div>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent text-primary-hover" style="color: var(--text-primary);" @onclick='() => NavigateTo("/settings")'>
                    <i class="lucide-sliders me-2 text-secondary"></i> Account Settings
                </button>
                <div class="dropdown-divider"></div>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption text-danger border-0 bg-transparent" @onclick="HandleLogout">
                    <i class="lucide-log-out me-2"></i> Log Out
                </button>
            </div>
        </div>

    </div>
</div>

@code {
    private bool BranchDropdownOpen = false;
    private bool QuickActionsOpen = false;
    private bool NotificationPanelOpen = false;
    private bool ProfileDropdownOpen = false;
    private string GlobalSearchText = "";

    protected override void OnInitialized()
    {
        NavigationState.OnChange += StateHasChanged;
        ThemeState.OnChange += StateHasChanged;
        NotificationState.OnChange += StateHasChanged;
        CurrentUser.OnChange += StateHasChanged;
    }

    private void ToggleBranchDropdown()
    {
        BranchDropdownOpen = !BranchDropdownOpen;
        QuickActionsOpen = false;
        NotificationPanelOpen = false;
        ProfileDropdownOpen = false;
    }

    private void ToggleQuickActions()
    {
        QuickActionsOpen = !QuickActionsOpen;
        BranchDropdownOpen = false;
        NotificationPanelOpen = false;
        ProfileDropdownOpen = false;
    }

    private void ToggleMobileSidebar()
    {
        NavigationState.SetSidebarCollapsed(!NavigationState.SidebarCollapsed);
    }

    private void ToggleNotificationPanel()
    {
        NotificationPanelOpen = !NotificationPanelOpen;
        BranchDropdownOpen = false;
        QuickActionsOpen = false;
        ProfileDropdownOpen = false;
    }

    private void ToggleProfileDropdown()
    {
        ProfileDropdownOpen = !ProfileDropdownOpen;
        BranchDropdownOpen = false;
        QuickActionsOpen = false;
        NotificationPanelOpen = false;
    }

    private void SwitchBranch(string branch)
    {
        NavigationState.SwitchBranch(branch);
        BranchDropdownOpen = false;
    }

    private void HandleGlobalSearch()
    {
        NavigationState.SetSearchQuery(GlobalSearchText);
    }

    private async Task ToggleTheme()
    {
        var newTheme = !ThemeState.DarkMode;
        ThemeState.SetDarkMode(newTheme);
        await JSRuntime.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{(newTheme ? "dark" : "light")}')");
        NotificationState.AddToast(newTheme ? "Dark Mode Active" : "Light Mode Active", $"Interface color scheme updated to {(newTheme ? "Dark" : "Light")}.", ToastType.Info);
    }

    private int GetUnreadNotificationsCount()
    {
        return NotificationState.Notifications.Count(n => !n.IsRead);
    }

    private void MarkAllRead()
    {
        NotificationState.MarkAllNotificationsRead();
        NotificationPanelOpen = false;
    }

    private void NavigateTo(string url)
    {
        NavigationManager.NavigateTo(url);
        NotificationPanelOpen = false;
        ProfileDropdownOpen = false;
    }

    private void QuickNavigate(string url)
    {
        NavigationManager.NavigateTo(url);
        QuickActionsOpen = false;
        ProfileDropdownOpen = false;
    }

    private async Task HandleLogout()
    {
        ProfileDropdownOpen = false;
        await AuthenticationService.LogoutAsync();
    }

    private string GetUserInitials()
    {
        var name = CurrentUser.DisplayName;
        if (string.IsNullOrWhiteSpace(name)) return "U";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "U",
            1 => parts[0].Substring(0, 1).ToUpperInvariant(),
            _ => (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpperInvariant()
        };
    }

    private string GetActivePageTitle()
    {
        var relativeUri = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).Split('?')[0].Split('/')[0];
        if (string.IsNullOrEmpty(relativeUri)) return "Dashboard";
        
        // Match specific segments to clean strings
        return relativeUri.ToLower() switch
        {
            "approvalcenter" => "Approval Center",
            _ => char.ToUpper(relativeUri[0]) + relativeUri.Substring(1)
        };
    }

    public void Dispose()
    {
        NavigationState.OnChange -= StateHasChanged;
        ThemeState.OnChange -= StateHasChanged;
        NotificationState.OnChange -= StateHasChanged;
        CurrentUser.OnChange -= StateHasChanged;
    }
}
