@using NexAsset.Web.State
@using NexAsset.Web.Infrastructure.Services
@using NexAsset.Web.Infrastructure.Authentication
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Shared.Models
@inject NavigationState NavigationState
@inject IAuthenticationService AuthenticationService
@inject ICurrentUserService CurrentUser
@inject NotificationState NotificationState
@inject MockDatabaseService Db
@inject IOrganizationApiClient OrganizationApiClient
@inject NavigationManager NavigationManager
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms
@implements IDisposable

<div class="sidebar-slot h-100 d-flex flex-column" style="background-color: var(--sidebar-bg); border-right: 1px solid var(--sidebar-border); color: var(--sidebar-text); transition: width var(--transition-normal); width: @(NavigationState.SidebarCollapsed ? "var(--sidebar-width-collapsed)" : "var(--sidebar-width)");">
    
    <!-- Sidebar Header (Logo + Title) -->
    <div class="p-3 border-bottom d-flex align-items-center justify-content-between" style="border-color: var(--sidebar-border); height: var(--topbar-height);">
        @if (!NavigationState.SidebarCollapsed)
        {
            <div class="d-flex align-items-center gap-2 animate-fade-in">
                <div class="d-flex align-items-center justify-content-center bg-primary rounded-3 text-white" style="width: 32px; height: 32px;">
                    <i class="lucide-box fs-5"></i>
                </div>
                <span class="fs-5 fw-bold" style="letter-spacing: -0.03em; color: var(--sidebar-text);">NexAsset</span>
            </div>
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center bg-primary rounded-3 text-white mx-auto" style="width: 32px; height: 32px;">
                <i class="lucide-box fs-5"></i>
            </div>
        }
        
        @if (!NavigationState.SidebarCollapsed)
        {
            <button type="button" class="btn-custom p-1 border-0" style="background: transparent; color: var(--sidebar-text-muted);" @onclick="ToggleSidebar">
                <i class="lucide-chevron-left fs-5"></i>
            </button>
        }
    </div>

    <!-- Organization Switch (only visible when expanded). Switching organization is a
         SuperAdmin-only capability; everyone else is pinned to their own organization and
         sees it as a static label. -->
    @if (!NavigationState.SidebarCollapsed)
    {
        <div class="px-3 py-3 border-bottom" style="border-color: var(--sidebar-border);">
            @if (Perms.IsSuperAdmin)
            {
                <div class="dropdown">
                    <button class="btn-custom w-100 text-start d-flex align-items-center justify-content-between py-2 px-3 border-0"
                            style="background-color: var(--sidebar-active-bg); color: var(--sidebar-text); border-radius: var(--radius-8);"
                            @onclick="ToggleOrgDropdown">
                        <div class="d-flex align-items-center gap-2">
                            <i class="lucide-building-2" style="color: var(--primary);"></i>
                            <span class="text-caption fw-semibold">@(NavigationState.ActiveOrganizationId is null ? NavigationState.AllOrganizationsLabel : NavigationState.ActiveOrganization)</span>
                        </div>
                        <i class="lucide-chevrons-up-down text-muted-custom" style="font-size: 12px;"></i>
                    </button>

                    <div class="dropdown-menu p-1 w-100 @(OrgDropdownOpen ? "show" : "")"
                         style="display: @(OrgDropdownOpen ? "block" : "none"); background-color: var(--sidebar-active-bg); border: 1px solid var(--sidebar-border); border-radius: var(--radius-8); position: absolute; left: 0; right: 0; z-index: 1010; margin-top: 4px;">
                        @* All organizations = no focus; every view shows every organization's data. *@
                        <button type="button" class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent"
                                style="color: @(NavigationState.ActiveOrganizationId is null ? "var(--primary)" : "var(--sidebar-text)");"
                                @onclick="ViewAllOrgs">
                            @NavigationState.AllOrganizationsLabel
                        </button>
                        <div class="dropdown-divider my-1"></div>
                        @foreach (var org in _organizations)
                        {
                            <button type="button" class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent"
                                    style="color: @(NavigationState.ActiveOrganizationId == org.Id ? "var(--primary)" : "var(--sidebar-text)");"
                                    @onclick="() => SwitchOrg(org.Id, org.Name)">
                                @org.Name
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex align-items-center gap-2 py-2 px-3"
                     style="background-color: var(--sidebar-active-bg); color: var(--sidebar-text); border-radius: var(--radius-8);">
                    <i class="lucide-building-2" style="color: var(--primary);"></i>
                    <span class="text-caption fw-semibold">@NavigationState.ActiveOrganization</span>
                </div>
            }
        </div>
    }

    <!-- Sidebar Search -->
    @if (!NavigationState.SidebarCollapsed)
    {
        <div class="p-3 border-bottom" style="border-color: var(--sidebar-border);">
            <div class="position-relative w-100">
                <i class="lucide-search position-absolute text-muted-custom" style="left: 10px; top: 50%; transform: translateY(-50%); font-size: 13px;"></i>
                <input type="text" class="form-control-custom border-0 py-1.5"
                       style="padding-left: 32px; background-color: var(--sidebar-active-bg); color: var(--sidebar-text); font-size: 12px;"
                       placeholder="Quick jump..." @bind-value="QuickSearchQuery" @bind-value:event="oninput" @onkeyup="HandleQuickSearchKey" />
            </div>
        </div>
    }

    <!-- Navigation Scrollable -->
    <div class="flex-grow-1 overflow-auto py-3">
        <nav class="d-flex flex-column gap-1 px-2">
            @foreach (var section in _navSections)
            {
                var items = section.Items.Where(CanSee).ToList();
                if (items.Count == 0)
                {
                    continue;
                }

                if (!NavigationState.SidebarCollapsed && section.Title is not null)
                {
                    <div class="px-4 mt-4 mb-2 text-label" style="font-size: 10px; color: var(--sidebar-text-muted);">@(section.Title)</div>
                }

                foreach (var nav in items)
                {
                    <NavLink href="@GetNavUrl(nav.Module)" Match="@(nav.Module == "Dashboard" ? NavLinkMatch.All : NavLinkMatch.Prefix)" class="nav-btn-custom py-2 px-3 rounded-3 w-100 border-0 bg-transparent text-start d-flex align-items-center justify-content-between text-decoration-none" ActiveClass="active" style="cursor: pointer; transition: all var(--transition-fast);">
                        <div class="d-flex align-items-center gap-3">
                            <i class="@nav.Icon fs-5"></i>
                            @if (!NavigationState.SidebarCollapsed)
                            {
                                <span class="text-caption font-weight-semibold animate-fade-in">@nav.Name</span>
                            }
                        </div>

                        @if (!NavigationState.SidebarCollapsed)
                        {
                            @if (nav.Module == "Maintenance" && GetActiveMaintenanceCount() > 0)
                            {
                                <span class="badge-custom badge-custom-warning py-0.5 px-1.5" style="font-size: 10px;">@GetActiveMaintenanceCount()</span>
                            }
                            else if (nav.Module == "Administration" && GetPendingApprovalsCount() > 0)
                            {
                                <span class="badge-custom badge-custom-info py-0.5 px-1.5" style="font-size: 10px;">@GetPendingApprovalsCount()</span>
                            }
                        }
                    </NavLink>
                }
            }
        </nav>
    </div>

    <!-- Sidebar Collapse Toggle for Collapsed View -->
    @if (NavigationState.SidebarCollapsed)
    {
        <div class="p-3 border-top text-center" style="border-color: var(--sidebar-border);">
            <button type="button" class="btn-custom p-1 border-0 mx-auto" style="background: transparent; color: var(--sidebar-text-muted);" @onclick="ToggleSidebar">
                <i class="lucide-chevron-right fs-5"></i>
            </button>
        </div>
    }

    <!-- Sidebar Footer Profile (Avatar + Details) -->
    <div class="p-3 border-top d-flex align-items-center gap-3 sidebar-profile-footer" style="border-color: var(--sidebar-border); background-color: var(--bg-surface-hover);">
        <div class="position-relative">
            <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" 
                 style="width: 38px; height: 38px; background-color: var(--primary); color: #ffffff; font-size: 14px;">
                @GetUserInitials()
            </div>
            <span class="position-absolute bottom-0 end-0 rounded-circle border border-dark" 
                  style="width: 10px; height: 10px; background-color: var(--success);"></span>
        </div>
        
        @if (!NavigationState.SidebarCollapsed)
        {
            <div class="flex-grow-1 overflow-hidden animate-fade-in" style="line-height: 1.2;">
                <div class="fw-semibold text-caption text-truncate" style="color: var(--sidebar-text);">@(CurrentUser.DisplayName ?? "NexAsset User")</div>
                <span class="text-muted-custom text-truncate d-block" style="font-size: 11px;">@(CurrentUser.Email ?? "")</span>
            </div>
            
            <button type="button" class="btn-custom p-1 border-0 bg-transparent text-muted-custom" @onclick="HandleLogout">
                <i class="lucide-log-out" style="font-size: 14px;"></i>
            </button>
        }
    </div>
</div>

@code {
    private bool OrgDropdownOpen = false;
    private string QuickSearchQuery = "";
    private List<(Guid Id, string Name)> _organizations = new();

    protected override async Task OnInitializedAsync()
    {
        NavigationState.OnChange += StateHasChanged;
        CurrentUser.OnChange += StateHasChanged;
        Perms.OnChanged += StateHasChanged;

        if (Perms.IsSuperAdmin)
        {
            // Only SuperAdmin can move between organizations, so only it needs the full list.
            // Start unfocused ("All organizations") — selecting one is what scopes the app.
            var orgs = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
            if (orgs.IsSuccess && orgs.Data is not null)
                _organizations = orgs.Data.Items.Select(o => (o.Id, o.Name)).ToList();
        }
        else if (Perms.OrganizationId is { } ownOrgId)
        {
            // Everyone else is pinned to their employee record's organization, which
            // /api/auth/me/permissions reports without needing Organizations.View.
            NavigationState.InitializeOrganization(ownOrgId, Perms.OrganizationName ?? "My organization");
        }
    }

    private void ToggleSidebar()
    {
        NavigationState.SetSidebarCollapsed(!NavigationState.SidebarCollapsed);
    }

    private void ToggleOrgDropdown()
    {
        OrgDropdownOpen = !OrgDropdownOpen;
    }

    // Switching organization re-scopes every API call. MainLayout keys the page on the active
    // organization, so changing it recreates the current page and its data reloads under the new
    // scope — no full reload needed (a reload would wipe the in-memory selection).
    private void SwitchOrg(Guid id, string name)
    {
        NavigationState.SwitchOrganization(id, name);
        OrgDropdownOpen = false;
    }

    private void ViewAllOrgs()
    {
        NavigationState.ViewAllOrganizations();
        OrgDropdownOpen = false;
    }

    private string GetNavUrl(string module)
    {
        return module.ToLower() switch
        {
            "dashboard" => "/",
            _ => $"/{module.ToLower()}"
        };
    }

    private int GetActiveMaintenanceCount()
    {
        return Db.MaintenanceTickets.Count(t => t.Status != "Resolved");
    }

    private int GetPendingApprovalsCount()
    {
        return Db.ProcurementRequests.Count(t => t.Status == "Pending");
    }

    private async Task HandleLogout()
    {
        await AuthenticationService.LogoutAsync();
    }

    private string GetUserInitials()
    {
        var name = CurrentUser.DisplayName;
        if (string.IsNullOrWhiteSpace(name)) return "U";

        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length switch
        {
            0 => "U",
            1 => parts[0].Substring(0, 1).ToUpperInvariant(),
            _ => (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpperInvariant()
        };
    }

    // Enter: jump to a matching module, otherwise fall through to global record search.
    private void HandleQuickSearchKey(KeyboardEventArgs e)
    {
        if (e.Key != "Enter" || string.IsNullOrWhiteSpace(QuickSearchQuery)) return;

        var match = _navSections.SelectMany(s => s.Items).Where(CanSee)
            .FirstOrDefault(n => n.Name.Contains(QuickSearchQuery, StringComparison.OrdinalIgnoreCase));

        if (match != null)
        {
            NavigationManager.NavigateTo(GetNavUrl(match.Module));
            NotificationState.AddToast("Module Jumped", $"Navigated directly to: {match.Name}", ToastType.Info);
        }
        else
        {
            NavigationManager.NavigateTo($"/search?q={Uri.EscapeDataString(QuickSearchQuery)}");
        }
        QuickSearchQuery = "";
    }

    public void Dispose()
    {
        NavigationState.OnChange -= StateHasChanged;
        CurrentUser.OnChange -= StateHasChanged;
        Perms.OnChanged -= StateHasChanged;
    }

    // A nav entry is visible when the user holds its module's View-level permission.
    // Settings has no code: it is every user's own workspace page, and the sections
    // inside it are gated individually. Managing organizations is SuperAdmin-only —
    // everyone else works inside a single organization and never chooses between them.
    private bool CanSee(NavItem nav) =>
        nav.SuperAdminOnly
            ? Perms.IsSuperAdmin
            : nav.Permission is null || Perms.HasPermission(nav.Permission);

    // Navigation grouped by how an asset-management user actually works, not by database entity.
    // A section renders its header (when expanded) only if the user can see at least one of its
    // items; a null title (Dashboard) renders the item with no header. Icons/permissions are
    // unchanged from the previous flat lists — only the grouping and ordering differ.
    private readonly List<NavSection> _navSections = new()
    {
        new NavSection(null, new()
        {
            new NavItem { Name = "Dashboard", Module = "Dashboard", Icon = "lucide-layout-dashboard", Permission = "Dashboard.View" },
        }),
        new NavSection("Business Setup", new()
        {
            new NavItem { Name = "Organizations", Module = "Organizations", Icon = "lucide-building-2", SuperAdminOnly = true },
            new NavItem { Name = "Branches", Module = "Branches", Icon = "lucide-git-branch", Permission = "Branches.View" },
            new NavItem { Name = "Departments", Module = "Departments", Icon = "lucide-layers", Permission = "Departments.View" },
            new NavItem { Name = "Designations", Module = "Designations", Icon = "lucide-award", Permission = "Designations.View" },
        }),
        new NavSection("People", new()
        {
            new NavItem { Name = "Employees", Module = "Employees", Icon = "lucide-users", Permission = "Employees.View" },
            new NavItem { Name = "Users", Module = "Users", Icon = "lucide-user-cog", Permission = "Users.View" },
        }),
        new NavSection("Asset Management", new()
        {
            new NavItem { Name = "Asset Categories", Module = "asset-categories", Icon = "lucide-tags", Permission = "AssetCategories.View" },
            new NavItem { Name = "Assets", Module = "Assets", Icon = "lucide-box", Permission = "Assets.View" },
            new NavItem { Name = "Inventory", Module = "Inventory", Icon = "lucide-warehouse", Permission = "Inventory.View" },
            new NavItem { Name = "Consumables", Module = "Consumables", Icon = "lucide-package-open", Permission = "Consumables.View" },
        }),
        new NavSection("Procurement", new()
        {
            new NavItem { Name = "Vendors", Module = "Vendors", Icon = "lucide-store", Permission = "Vendors.View" },
            new NavItem { Name = "Procurement Requests", Module = "Procurement", Icon = "lucide-shopping-cart", Permission = "PurchaseRequests.View" },
            new NavItem { Name = "Purchase Orders", Module = "purchase-orders", Icon = "lucide-clipboard-list", Permission = "PurchaseOrders.View" },
        }),
        new NavSection("Operations", new()
        {
            new NavItem { Name = "Maintenance", Module = "Maintenance", Icon = "lucide-wrench", Permission = "Maintenance.View" },
            new NavItem { Name = "Customers", Module = "Customers", Icon = "lucide-contact", Permission = "Customers.View" },
            new NavItem { Name = "Service Tickets", Module = "service-tickets", Icon = "lucide-headphones", Permission = "ServiceTickets.View" },
        }),
        new NavSection("Project Workspace", new()
        {
            new NavItem { Name = "Projects", Module = "projects", Icon = "lucide-folder-kanban", Permission = "Projects.View" },
            new NavItem { Name = "Project Categories", Module = "project-categories", Icon = "lucide-tag", Permission = "ProjectCategories.View" },
        }),
        new NavSection("Finance", new()
        {
            new NavItem { Name = "Finance", Module = "Finance", Icon = "lucide-credit-card", Permission = "Finance.View" },
        }),
        new NavSection("Analytics", new()
        {
            new NavItem { Name = "Reports", Module = "Reports", Icon = "lucide-bar-chart-3", Permission = "Reports.View" },
        }),
        new NavSection("Administration", new()
        {
            new NavItem { Name = "Roles", Module = "Roles", Icon = "lucide-shield", Permission = "Roles.View" },
            new NavItem { Name = "Permissions", Module = "Permissions", Icon = "lucide-key-round", Permission = "Permissions.View" },
            new NavItem { Name = "Administration", Module = "Administration", Icon = "lucide-settings", Permission = "AuditLogs.View" },
        }),
        new NavSection("Secondary Operations", new()
        {
            new NavItem { Name = "Notifications", Module = "Notifications", Icon = "lucide-bell", Permission = "Notifications.View" },
            new NavItem { Name = "Approval Center", Module = "ApprovalCenter", Icon = "lucide-check-square", Permission = "PurchaseRequests.Approve" },
            new NavItem { Name = "Settings", Module = "Settings", Icon = "lucide-sliders" },
        }),
    };

    private sealed record NavSection(string? Title, List<NavItem> Items);

    private class NavItem
    {
        public string Name { get; set; } = "";
        public string Module { get; set; } = "";
        public string Icon { get; set; } = "";
        public string? Permission { get; set; }
        public bool SuperAdminOnly { get; set; }
    }
}
