@page "/approvalcenter"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Infrastructure.Procurement
@using NexAsset.Web.Models.Procurement
@using NexAsset.Web.Shared.Models
@inject IPurchaseRequestApiClient PurchaseRequestApiClient
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient
@inject INotificationService Notifications

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Approval Center</h1>
            <span class="text-caption text-secondary">Review purchase requests and approve or reject them.</span>
        </div>
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading approvals..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load approvals" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="PurchaseRequestItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Approval"
                   ShowFilterPanel="false"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="r => r.Id.ToString()"
                   CustomRowActions="ApprovalActions" />
    }
</div>

@code {
    private PagedResult<PurchaseRequestItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private Dictionary<Guid, string> _empNames = new();
    private List<ColumnDefinition<PurchaseRequestItem>> _columns = new();

    // Approve/Reject only make sense while a request is awaiting a decision; the backend
    // enforces the actual transition rules.
    private RenderFragment<PurchaseRequestItem> ApprovalActions => item =>
        @<text>
            @if (item.Status is ProcurementStatus.Draft or ProcurementStatus.PendingApproval)
            {
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--success);" @onclick="() => DecideAsync(item, ProcurementStatus.Approved)">
                    <i class="lucide-check me-2"></i> Approve
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption text-danger border-0 bg-transparent" @onclick="() => DecideAsync(item, ProcurementStatus.Rejected)">
                    <i class="lucide-x me-2"></i> Reject
                </button>
            }
        </text>;

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "PR Number", PropertySelector = r => r.RequestNumber, SortColumn = "RequestNumber" },
            new() { Header = "Title", Sortable = true, SortColumn = "Title", Template = r =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@r.Title</span> },
            new() { Header = "Requester", Sortable = false, Template = r =>
                @<span>@(_empNames.TryGetValue(r.RequestedByEmployeeId, out var n) ? n : "—")</span> },
            new() { Header = "Amount", Sortable = true, SortColumn = "EstimatedAmount", Template = r => @<span>@r.EstimatedAmount.ToString("C")</span> },
            new() { Header = "Status", Sortable = false, Template = r =>
                @<span class="badge-custom @(ProcurementStatus.BadgeClass(r.Status))">@ProcurementStatus.Label(r.Status)</span> }
        };

        var emps = await EmployeeApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "FirstName" });
        if (emps.IsSuccess && emps.Data is not null)
            _empNames = emps.Data.Items.ToDictionary(e => e.Id, e => $"{e.FirstName} {e.LastName}");

        await LoadAsync(_query);
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await PurchaseRequestApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading approvals.";
    }

    private async Task DecideAsync(PurchaseRequestItem item, int status)
    {
        _busy = true;
        var result = await PurchaseRequestApiClient.SetStatusAsync(item.Id, new SetProcurementStatusRequest
        {
            Status = status,
            ApprovalRemarks = status == ProcurementStatus.Approved ? "Approved via Approval Center" : "Rejected via Approval Center",
            Remarks = status == ProcurementStatus.Approved ? "Approved via Approval Center" : "Rejected via Approval Center"
        });
        _busy = false;

        if (result.IsSuccess)
        {
            Notifications.ShowSuccess(status == ProcurementStatus.Approved ? "Approved" : "Rejected",
                $"Purchase request {item.RequestNumber} {(status == ProcurementStatus.Approved ? "approved" : "rejected")}.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Failed", result.Error?.Message ?? "Could not update the request.");
        }
    }
}
