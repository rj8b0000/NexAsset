@page "/maintenance"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Maintenance
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Maintenance.Components
@inject NexAsset.Web.Infrastructure.Maintenance.IMaintenanceRecordApiClient MaintenanceApiClient
@inject IAssetApiClient AssetApiClient
@inject INotificationService Notifications

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Maintenance</h1>
            <span class="text-caption text-secondary">Manage preventive and corrective maintenance across assets.</span>
        </div>
        <button class="btn-custom btn-custom-primary" @onclick="() => _formOpen = true">
            <i class="lucide-plus"></i> New Request
        </button>
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading maintenance records..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load maintenance records" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="MaintenanceRecordItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Maintenance Record"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="m => m.Id.ToString()"
                   OnViewDetails="OpenDetails"
                   CustomRowActions="StatusAction" />
    }
</div>

<MaintenanceFormDialog IsOpen="_formOpen" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<MaintenanceStatusDialog IsOpen="_statusOpen" RecordId="_statusId" EntityLabel="@_statusLabel" CurrentStatus="_statusCurrent"
                         OnClose="() => _statusOpen = false" OnCompleted="OnStatusCompleted" />

<Dialog IsOpen="_detailsTarget is not null" Title="Maintenance Details" Size="md" OnClose="() => _detailsTarget = null">
    <ChildContent>
        @if (_detailsTarget is not null)
        {
            <div class="d-flex align-items-center gap-2 mb-3">
                <span class="h2-title mb-0">@_detailsTarget.Title</span>
                <span class="badge-custom @(MaintenanceStatus.BadgeClass(_detailsTarget.Status))">@MaintenanceStatus.Label(_detailsTarget.Status)</span>
            </div>
            @Row("Asset", Lookup(_assetNames, _detailsTarget.AssetId))
            @Row("Type", MaintenanceType.Label(_detailsTarget.MaintenanceType))
            @Row("Requested", _detailsTarget.RequestedDate.ToString("yyyy-MM-dd"))
            @Row("Scheduled", _detailsTarget.ScheduledDate?.ToString("yyyy-MM-dd") ?? "—")
            @Row("Completed", _detailsTarget.CompletedDate?.ToString("yyyy-MM-dd") ?? "—")
            @Row("Cost", _detailsTarget.Cost?.ToString("C") ?? "—")
            @Row("Description", string.IsNullOrWhiteSpace(_detailsTarget.Description) ? "—" : _detailsTarget.Description!)
            @Row("Remarks", string.IsNullOrWhiteSpace(_detailsTarget.Remarks) ? "—" : _detailsTarget.Remarks!)
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="() => _detailsTarget = null">Close</button>
    </FooterContent>
</Dialog>

@code {
    private PagedResult<MaintenanceRecordItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private MaintenanceRecordItem? _detailsTarget;

    private bool _statusOpen;
    private Guid? _statusId;
    private string _statusLabel = "";
    private int _statusCurrent;

    private Dictionary<Guid, string> _assetNames = new();
    private List<ColumnDefinition<MaintenanceRecordItem>> _columns = new();

    private RenderFragment<MaintenanceRecordItem> StatusAction => item =>
        @<button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenStatus(item)">
            <i class="lucide-git-branch me-2"></i> Update Status
        </button>;

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Title", Sortable = true, SortColumn = "Title", Template = m =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@m.Title</span> },
            new() { Header = "Asset", Sortable = false, Template = m => @<span>@Lookup(_assetNames, m.AssetId)</span> },
            new() { Header = "Type", Sortable = false, Template = m => @<span>@MaintenanceType.Label(m.MaintenanceType)</span> },
            new() { Header = "Requested", Sortable = true, SortColumn = "RequestedDate", Template = m => @<span>@m.RequestedDate.ToString("yyyy-MM-dd")</span> },
            new() { Header = "Scheduled", Sortable = false, Template = m => @<span>@(m.ScheduledDate?.ToString("yyyy-MM-dd") ?? "—")</span> },
            new() { Header = "Cost", Sortable = false, Template = m => @<span>@(m.Cost?.ToString("C") ?? "—")</span> },
            new() { Header = "Status", Sortable = false, Template = m =>
                @<span class="badge-custom @(MaintenanceStatus.BadgeClass(m.Status))">@MaintenanceStatus.Label(m.Status)</span> }
        };

        await LoadAssetNamesAsync();
        await LoadAsync(_query);
    }

    private static string Lookup(Dictionary<Guid, string> map, Guid id) =>
        map.TryGetValue(id, out var n) ? n : "—";

    private async Task LoadAssetNamesAsync()
    {
        var assets = await AssetApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "AssetName" });
        if (assets.IsSuccess && assets.Data is not null)
            _assetNames = assets.Data.Items.ToDictionary(a => a.Id, a => $"{a.AssetCode} — {a.AssetName}");
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await MaintenanceApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading maintenance records.";
    }

    private void OpenDetails(MaintenanceRecordItem item) => _detailsTarget = item;

    private void OpenStatus(MaintenanceRecordItem item)
    {
        _statusId = item.Id;
        _statusLabel = item.Title;
        _statusCurrent = item.Status;
        _statusOpen = true;
    }

    private async Task OnStatusCompleted()
    {
        _statusOpen = false;
        Notifications.ShowSuccess("Updated", "Maintenance status updated.");
        await LoadAsync(_query);
    }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Maintenance request created.");
        await LoadAsync(_query);
    }

    private RenderFragment Row(string label, string value) => @<div class="d-flex justify-content-between py-1 border-bottom" style="border-color: var(--border-color) !important;">
        <span class="text-caption text-secondary">@label</span>
        <span class="text-caption fw-semibold text-end" style="color: var(--text-primary); max-width: 65%;">@value</span>
    </div>;
}
