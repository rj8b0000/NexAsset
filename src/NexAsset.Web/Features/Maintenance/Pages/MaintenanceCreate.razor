@page "/maintenance/create"
@using NexAsset.Web.Infrastructure.Models
@using NexAsset.Web.Infrastructure.Services
@inject IMaintenanceApiClient MaintenanceApiClient
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <FormSection Title="Open Maintenance Ticket" 
                 Breadcrumbs='(new List<string> { "Maintenance", "Create" })' 
                 OnCancel="HandleCancel" OnSave="HandleSave" OnReset="HandleReset">
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Asset Name / ID</label>
                <input type="text" class="form-control-custom" placeholder="e.g. HP LaserJet Printer" @bind="NewTicket.AssetName" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Issue Details</label>
                <input type="text" class="form-control-custom" placeholder="e.g. Fuser roller replacement & tune up" @bind="NewTicket.Issue" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Maintenance Type</label>
                <select class="form-control-custom" @bind="NewTicket.Type">
                    <option value="Corrective">Corrective (Repair)</option>
                    <option value="Preventive">Preventive (Routine)</option>
                </select>
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Urgency Priority</label>
                <select class="form-control-custom" @bind="NewTicket.Urgency">
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                </select>
            </div>
        </div>
    </FormSection>
</div>

@code {
    private MaintenanceMock NewTicket = new()
    {
        Type = "Corrective",
        Urgency = "Medium",
        Status = "Open"
    };

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(NewTicket.AssetName) || string.IsNullOrEmpty(NewTicket.Issue)) return;
        await MaintenanceApiClient.CreateMaintenanceTicketAsync(NewTicket);
        NavigationManager.NavigateTo("/maintenance");
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/maintenance");
    }

    private void HandleReset()
    {
        NewTicket = new MaintenanceMock
        {
            Type = "Corrective",
            Urgency = "Medium",
            Status = "Open"
        };
    }
}
