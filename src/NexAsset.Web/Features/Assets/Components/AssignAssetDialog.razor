@*
    Extracted from the identical "Assign Custody Dialog" markup previously duplicated in
    AssetList.razor and AssetDetails.razor. Owns its own selection state internally and
    resets it whenever it closes, so callers don't need to manage a two-way-bound field.
*@
<Dialog IsOpen="IsOpen" Title="Assign Asset Custody" Size="md" OnClose="OnClose">
    <ChildContent>
        <div class="form-group-custom mb-3">
            <label class="form-label-custom">Select Employee for Assignment</label>
            <select class="form-control-custom" @bind="_selectedEmployee">
                <option value="">-- Choose Employee --</option>
                @if (Employees != null)
                {
                    @foreach (var emp in Employees)
                    {
                        <option value="@emp.Name">@emp.Name (@emp.Department)</option>
                    }
                }
            </select>
        </div>
        <p class="text-caption text-secondary">The asset condition is logged as 'Verifiable Good'. This worker will receive an automated email request to confirm custody.</p>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="HandleConfirm">Assign Custody</button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public List<EmployeeMock>? Employees { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    /// <summary>Raised with the selected employee's name when the user confirms.</summary>
    [Parameter] public EventCallback<string> OnConfirm { get; set; }

    private string _selectedEmployee = "";

    protected override void OnParametersSet()
    {
        if (!IsOpen)
        {
            _selectedEmployee = "";
        }
    }

    private async Task HandleConfirm()
    {
        if (!string.IsNullOrEmpty(_selectedEmployee))
        {
            await OnConfirm.InvokeAsync(_selectedEmployee);
        }
    }
}
