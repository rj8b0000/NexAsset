@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Models.Assets
@using NexAsset.Web.Shared.Models
@inject IAssetLifecycleApiClient LifecycleApiClient
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient

<Dialog IsOpen="IsOpen" Title="@($"Assign Asset — {AssetName}")" Size="md" OnClose="OnClose">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_generalError))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                <i class="lucide-alert-circle"></i> @_generalError
            </div>
        }
        <div class="row g-3">
            <SelectField Label="Employee" Required="true" ColumnClass="col-12"
                         Options="_employeeOptions" Placeholder="Select an employee"
                         Value="@(_request.EmployeeId == Guid.Empty ? "" : _request.EmployeeId.ToString())"
                         ValueChanged="@(v => _request.EmployeeId = Guid.TryParse(v, out var g) ? g : Guid.Empty)"
                         Error='@Err("EmployeeId")' />
            <TextField Label="Assigned Date" Required="true" Type="date" Value="@_request.AssignedDate"
                       ValueChanged="@(v => _request.AssignedDate = v)" Error='@Err("AssignedDate")' />
            <TextField Label="Remarks" ColumnClass="col-12" Multiline="true" Value="@_request.Remarks"
                       ValueChanged="@(v => _request.Remarks = v)" Error='@Err("Remarks")' />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Assigning...</span>
            }
            else
            {
                <i class="lucide-user-check"></i>
                <span>Assign</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? AssetId { get; set; }
    [Parameter] public Guid? OrganizationId { get; set; }
    [Parameter] public string AssetName { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    private AssignAssetRequest _request = new();
    private List<SelectField.Option> _employeeOptions = new();
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open)
        {
            _open = true;
            _generalError = null;
            _fieldErrors = new();
            _request = new AssignAssetRequest { AssetId = AssetId ?? Guid.Empty };
            await LoadEmployeesAsync();
        }
        else if (!IsOpen && _open)
        {
            _open = false;
        }
    }

    private async Task LoadEmployeesAsync()
    {
        var result = await EmployeeApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "FirstName" });
        if (result.IsSuccess && result.Data is not null)
            _employeeOptions = result.Data.Items
                // Only employees from the asset's organization can receive it.
                .Where(e => OrganizationId is null || e.OrganizationId == OrganizationId)
                .Select(e => new SelectField.Option(e.Id.ToString(), $"{e.EmployeeCode} — {e.FirstName} {e.LastName}"))
                .ToList();
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        if (_request.EmployeeId == Guid.Empty) _fieldErrors["EmployeeId"] = "Employee is required.";
        if (string.IsNullOrWhiteSpace(_request.AssignedDate)) _fieldErrors["AssignedDate"] = "Assigned date is required.";
        if (_fieldErrors.Count > 0) return;

        _saving = true;
        var result = await LifecycleApiClient.AssignAsync(_request);
        _saving = false;

        if (!result.IsSuccess)
        {
            ApplyError(result.Error);
            return;
        }
        await OnCompleted.InvokeAsync();
    }

    private void ApplyError(ApiError? error)
    {
        _generalError = error?.Message ?? "Assignment failed. Please try again.";
        if (error?.FieldErrors is not null)
            foreach (var kv in error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
