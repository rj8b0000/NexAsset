@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Models.Assets
@inject IAssetLifecycleApiClient LifecycleApiClient

<Dialog IsOpen="IsOpen" Title="@($"Return Asset — {AssetName}")" Size="md" OnClose="OnClose">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_generalError))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                <i class="lucide-alert-circle"></i> @_generalError
            </div>
        }
        <div class="row g-3">
            <TextField Label="Return Date" Required="true" Type="date" Value="@_request.ReturnDate"
                       ValueChanged="@(v => _request.ReturnDate = v)" Error='@Err("ReturnDate")' />
            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="ret-usable" checked="@_request.IsAssetUsable" @onchange="e => _request.IsAssetUsable = (bool)e.Value!" />
                    <label class="form-check-label text-caption" for="ret-usable">Asset is usable</label>
                </div>
            </div>
            <TextField Label="Inspection Notes" ColumnClass="col-12" Multiline="true" Value="@_request.InspectionNotes"
                       ValueChanged="@(v => _request.InspectionNotes = v)" Error='@Err("InspectionNotes")' />
            <TextField Label="Return Remarks" ColumnClass="col-12" Multiline="true" Value="@_request.ReturnRemarks"
                       ValueChanged="@(v => _request.ReturnRemarks = v)" Error='@Err("ReturnRemarks")' />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Returning...</span>
            }
            else
            {
                <i class="lucide-undo-2"></i>
                <span>Return</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? AssetId { get; set; }
    [Parameter] public string AssetName { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnCompleted { get; set; }

    private ReturnAssetRequest _request = new();
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    protected override void OnParametersSet()
    {
        if (IsOpen && !_open)
        {
            _open = true;
            _generalError = null;
            _fieldErrors = new();
            _request = new ReturnAssetRequest { AssetId = AssetId ?? Guid.Empty };
        }
        else if (!IsOpen && _open)
        {
            _open = false;
        }
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        if (string.IsNullOrWhiteSpace(_request.ReturnDate)) { _fieldErrors["ReturnDate"] = "Return date is required."; return; }

        _saving = true;
        var result = await LifecycleApiClient.ReturnAsync(_request);
        _saving = false;

        if (!result.IsSuccess)
        {
            ApplyError(result.Error);
            return;
        }
        await OnCompleted.InvokeAsync();
    }

    private void ApplyError(ApiError? error)
    {
        _generalError = error?.Message ?? "Return failed. Please try again.";
        if (error?.FieldErrors is not null)
            foreach (var kv in error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
