@using System.Globalization
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Models.Assets
@using NexAsset.Web.Shared.Models
@inject IAssetApiClient AssetApiClient
@inject IAssetCategoryApiClient AssetCategoryApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IBranchApiClient BranchApiClient
@inject IDepartmentApiClient DepartmentApiClient
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient

<Dialog IsOpen="IsOpen" Title="@(IsEdit ? "Edit Asset" : "New Asset")" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (_loading)
        {
            <LoadingState Message="Loading asset..." />
        }
        else
        {
            @if (!string.IsNullOrEmpty(_generalError))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                    <i class="lucide-alert-circle"></i> @_generalError
                </div>
            }
            <div class="row g-3">
                <TextField Label="Asset Code" Required="true" Value="@_model.AssetCode" ValueChanged="@(v => _model.AssetCode = v)" Error='@Err("AssetCode")' />
                <TextField Label="Asset Name" Required="true" Value="@_model.AssetName" ValueChanged="@(v => _model.AssetName = v)" Error='@Err("AssetName")' />

                <SelectField Label="Organization" Required="true" Options="_orgOptions" Placeholder="Select an organization"
                             Value="@GuidStr(_model.OrganizationId)" ValueChanged="OnOrgChanged" Error='@Err("OrganizationId")' />
                <SelectField Label="Category" Required="true" Options="CategoryOptions" Placeholder="Select a category"
                             Value="@GuidStr(_model.CategoryId)" ValueChanged="@(v => _model.CategoryId = ParseGuid(v) ?? Guid.Empty)" Error='@Err("CategoryId")' />

                <SelectField Label="Branch" Options="BranchOptions" Placeholder="(None)"
                             Value="@GuidStr(_model.BranchId)" ValueChanged="@(v => _model.BranchId = ParseGuid(v))" Error='@Err("BranchId")' />
                <SelectField Label="Department" Options="DeptOptions" Placeholder="(None)"
                             Value="@GuidStr(_model.DepartmentId)" ValueChanged="@(v => _model.DepartmentId = ParseGuid(v))" Error='@Err("DepartmentId")' />

                <SelectField Label="Current Holder" Options="_employeeOptions" Placeholder="(None)"
                             Value="@GuidStr(_model.CurrentEmployeeId)" ValueChanged="@(v => _model.CurrentEmployeeId = ParseGuid(v))" Error='@Err("CurrentEmployeeId")' />
                <SelectField Label="Status" Required="true" Options="_statusOptions" Placeholder="Select status"
                             Value="@_model.AssetStatus.ToString()" ValueChanged="@(v => _model.AssetStatus = int.TryParse(v, out var s) ? s : NexAsset.Web.Models.Assets.AssetStatus.Available)" Error='@Err("AssetStatus")' />

                <TextField Label="Serial Number" Value="@_model.SerialNumber" ValueChanged="@(v => _model.SerialNumber = v)" Error='@Err("SerialNumber")' />
                <TextField Label="Barcode" Value="@_model.Barcode" ValueChanged="@(v => _model.Barcode = v)" Error='@Err("Barcode")' />
                <TextField Label="QR Code" Value="@_model.QrCode" ValueChanged="@(v => _model.QrCode = v)" Error='@Err("QrCode")' />
                <TextField Label="Brand" Value="@_model.Brand" ValueChanged="@(v => _model.Brand = v)" Error='@Err("Brand")' />
                <TextField Label="Model" Value="@_model.Model" ValueChanged="@(v => _model.Model = v)" Error='@Err("Model")' />
                <TextField Label="Vendor" Value="@_model.Vendor" ValueChanged="@(v => _model.Vendor = v)" Error='@Err("Vendor")' />

                <TextField Label="Purchase Date" Type="date" Value="@_model.PurchaseDate" ValueChanged="@(v => _model.PurchaseDate = v)" Error='@Err("PurchaseDate")' />
                <TextField Label="Warranty Expiry" Type="date" Value="@_model.WarrantyExpiry" ValueChanged="@(v => _model.WarrantyExpiry = v)" Error='@Err("WarrantyExpiry")' />
                <TextField Label="Purchase Cost" Type="number" Value="@_purchaseCostStr" ValueChanged="@(v => _purchaseCostStr = v)" Error='@Err("PurchaseCost")' />
                <TextField Label="Current Value" Type="number" Value="@_currentValueStr" ValueChanged="@(v => _currentValueStr = v)" Error='@Err("CurrentValue")' />

                <TextField Label="Location" Value="@_model.Location" ValueChanged="@(v => _model.Location = v)" Error='@Err("Location")' />
                <TextField Label="Remarks" ColumnClass="col-12" Multiline="true" Value="@_model.Remarks" ValueChanged="@(v => _model.Remarks = v)" Error='@Err("Remarks")' />
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@(_saving || _loading)">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Save</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EditId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private AssetFormModel _model = new();
    private string _purchaseCostStr = "";
    private string _currentValueStr = "";

    private List<SelectField.Option> _orgOptions = new();
    private List<(Guid Id, Guid OrgId, string Label)> _categories = new();
    private List<(Guid Id, Guid OrgId, string Label)> _branches = new();
    private List<(Guid Id, Guid OrgId, string Label)> _departments = new();
    private List<SelectField.Option> _employeeOptions = new();
    private readonly List<SelectField.Option> _statusOptions =
        NexAsset.Web.Models.Assets.AssetStatus.Options.Select(o => new SelectField.Option(o.Value.ToString(), o.Label)).ToList();

    private bool _loading;
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private bool IsEdit => EditId.HasValue;
    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;
    private static string GuidStr(Guid g) => g == Guid.Empty ? "" : g.ToString();
    private static string GuidStr(Guid? g) => g?.ToString() ?? "";
    private static Guid? ParseGuid(string v) => Guid.TryParse(v, out var g) ? g : null;

    private IReadOnlyList<SelectField.Option> CategoryOptions => Filtered(_categories);
    private IReadOnlyList<SelectField.Option> BranchOptions => Filtered(_branches);
    private IReadOnlyList<SelectField.Option> DeptOptions => Filtered(_departments);

    private IReadOnlyList<SelectField.Option> Filtered(List<(Guid Id, Guid OrgId, string Label)> src) =>
        src.Where(x => x.OrgId == _model.OrganizationId).Select(x => new SelectField.Option(x.Id.ToString(), x.Label)).ToList();

    private void OnOrgChanged(string v)
    {
        _model.OrganizationId = Guid.TryParse(v, out var g) ? g : Guid.Empty;
        if (_model.CategoryId != Guid.Empty && !_categories.Any(x => x.Id == _model.CategoryId && x.OrgId == _model.OrganizationId)) _model.CategoryId = Guid.Empty;
        if (_model.BranchId is { } b && !_branches.Any(x => x.Id == b && x.OrgId == _model.OrganizationId)) _model.BranchId = null;
        if (_model.DepartmentId is { } d && !_departments.Any(x => x.Id == d && x.OrgId == _model.OrganizationId)) _model.DepartmentId = null;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open) { _open = true; await InitializeAsync(); }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task InitializeAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        _model = new AssetFormModel();
        _purchaseCostStr = "";
        _currentValueStr = "";
        _loading = true;

        await LoadLookupsAsync();

        if (EditId.HasValue)
        {
            var result = await AssetApiClient.GetByIdAsync(EditId.Value);
            if (result.IsSuccess && result.Data is not null)
            {
                _model = AssetFormModel.FromDetail(result.Data);
                _purchaseCostStr = _model.PurchaseCost?.ToString(CultureInfo.InvariantCulture) ?? "";
                _currentValueStr = _model.CurrentValue?.ToString(CultureInfo.InvariantCulture) ?? "";
            }
            else
            {
                _generalError = result.Error?.Message ?? "Could not load this asset.";
            }
        }
        _loading = false;
    }

    private async Task LoadLookupsAsync()
    {
        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null)
            _orgOptions = orgs.Data.Items.Select(o => new SelectField.Option(o.Id.ToString(), $"{o.Code} — {o.Name}")).ToList();

        var cats = await AssetCategoryApiClient.GetPagedAsync(big);
        if (cats.IsSuccess && cats.Data is not null)
            _categories = cats.Data.Items.Select(c => (c.Id, c.OrganizationId, $"{c.Code} — {c.Name}")).ToList();

        var branches = await BranchApiClient.GetPagedAsync(big);
        if (branches.IsSuccess && branches.Data is not null)
            _branches = branches.Data.Items.Select(b => (b.Id, b.OrganizationId, $"{b.Code} — {b.Name}")).ToList();

        var depts = await DepartmentApiClient.GetPagedAsync(big);
        if (depts.IsSuccess && depts.Data is not null)
            _departments = depts.Data.Items.Select(d => (d.Id, d.OrganizationId, $"{d.Code} — {d.Name}")).ToList();

        var emps = await EmployeeApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "FirstName" });
        if (emps.IsSuccess && emps.Data is not null)
            _employeeOptions = emps.Data.Items.Select(e => new SelectField.Option(e.Id.ToString(), $"{e.EmployeeCode} — {e.FirstName} {e.LastName}")).ToList();
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();

        if (string.IsNullOrWhiteSpace(_model.AssetCode)) _fieldErrors["AssetCode"] = "Asset code is required.";
        if (string.IsNullOrWhiteSpace(_model.AssetName)) _fieldErrors["AssetName"] = "Asset name is required.";
        if (_model.OrganizationId == Guid.Empty) _fieldErrors["OrganizationId"] = "Organization is required.";
        if (_model.CategoryId == Guid.Empty) _fieldErrors["CategoryId"] = "Category is required.";

        // Parse the money fields; reject non-numeric input.
        _model.PurchaseCost = ParseDecimal(_purchaseCostStr, "PurchaseCost");
        _model.CurrentValue = ParseDecimal(_currentValueStr, "CurrentValue");
        if (_fieldErrors.Count > 0) return;

        // Empty date strings must be sent as null (the backend binds DateOnly?).
        _model.PurchaseDate = string.IsNullOrWhiteSpace(_model.PurchaseDate) ? null : _model.PurchaseDate;
        _model.WarrantyExpiry = string.IsNullOrWhiteSpace(_model.WarrantyExpiry) ? null : _model.WarrantyExpiry;

        _saving = true;
        bool success;
        ApiError? error;
        if (IsEdit)
        {
            var res = await AssetApiClient.UpdateAsync(EditId!.Value, _model);
            success = res.IsSuccess; error = res.Error;
        }
        else
        {
            var res = await AssetApiClient.CreateAsync(_model);
            success = res.IsSuccess; error = res.Error;
        }
        _saving = false;

        if (!success) { ApplyError(error); return; }
        await OnSaved.InvokeAsync();
    }

    private decimal? ParseDecimal(string? value, string field)
    {
        if (string.IsNullOrWhiteSpace(value)) return null;
        if (decimal.TryParse(value, NumberStyles.Any, CultureInfo.InvariantCulture, out var d)) return d;
        _fieldErrors[field] = "Enter a valid number.";
        return null;
    }

    private void ApplyError(ApiError? error)
    {
        _generalError = error?.Message ?? "Save failed. Please try again.";
        if (error?.FieldErrors is not null)
            foreach (var kv in error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
