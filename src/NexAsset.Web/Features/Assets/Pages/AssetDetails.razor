@page "/assets/details/{id}"
@using NexAsset.Web.Infrastructure.Models
@using NexAsset.Web.Infrastructure.Services
@using NexAsset.Web.State
@inject IAssetApiClient AssetApiClient
@inject IEmployeeApiClient EmployeeApiClient
@inject MockDatabaseService Db
@inject NotificationState NotificationState
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <!-- Back buttons -->
    <button class="btn-custom btn-custom-secondary mb-4" @onclick='() => NavigationManager.NavigateTo("/assets")'>
        <i class="lucide-arrow-left"></i> Back to Assets List
    </button>

    @if (Asset == null)
    {
        <LoadingState />
    }
    else
    {
        <div class="row g-4">
            <!-- Left Core Details Block -->
            <div class="col-lg-8">
                <div class="card-custom mb-4">
                    <div class="border-bottom pb-3 mb-4 d-flex align-items-center justify-content-between">
                        <div>
                            <span class="text-label">Entity Record Details</span>
                            <h2 class="h1-title mt-1">@Asset.Name</h2>
                        </div>
                        <span class="badge-custom @(Asset.Status == "Available" ? "badge-custom-success" : Asset.Status == "Assigned" ? "badge-custom-primary" : "badge-custom-warning")">
                            @Asset.Status
                        </span>
                    </div>

                    <!-- Property details fields -->
                    <div class="row g-3">
                        <div class="col-md-6"><strong>Asset ID:</strong> <span class="text-secondary">@Asset.Id</span></div>
                        <div class="col-md-6"><strong>Serial Number:</strong> <span class="text-secondary">@Asset.Serial</span></div>
                        <div class="col-md-6"><strong>Asset Category:</strong> <span class="text-secondary">@Asset.Category</span></div>
                        <div class="col-md-6"><strong>Acquisition Price:</strong> <span class="text-secondary">@(Asset.Value.ToString("C"))</span></div>
                        <div class="col-md-6"><strong>Registered Office Location:</strong> <span class="text-secondary">@Asset.Location</span></div>
                        <div class="col-md-6"><strong>Assigned Employee:</strong> <span class="text-secondary">@(Asset.AssignedTo ?? "Unassigned")</span></div>
                        <div class="col-md-6"><strong>Purchased Date:</strong> <span class="text-secondary">@Asset.PurchaseDate.ToString("yyyy-MM-dd")</span></div>
                        <div class="col-md-6"><strong>Database Registered:</strong> <span class="text-secondary">@Asset.CreatedDate.ToString("g")</span></div>
                    </div>
                </div>

                <!-- Secondary Tab Sections: Assignment history / Documents -->
                <div class="tabs-container">
                    <div class="tab-item @(DetailSubView == "history" ? "active" : "")" @onclick='() => SetDetailSubView("history")'>History Trail</div>
                    <div class="tab-item @(DetailSubView == "documents" ? "active" : "")" @onclick='() => SetDetailSubView("documents")'>Attachments (2)</div>
                </div>

                @if (DetailSubView == "history")
                {
                    <Timeline Title="Audit & Operations History" Subtitle="State logs captured for this record" 
                              Events="GetItemAuditEvents()" />
                }
                else
                {
                    <div class="card-custom">
                        <h4 class="h2-title mb-3">Documents & Image Attachments</h4>
                        <div class="d-flex flex-column gap-2">
                            <div class="p-3 border rounded-3 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="lucide-file-text text-primary fs-4"></i>
                                    <div>
                                        <div class="fw-semibold text-caption">Original_Purchase_Invoice.pdf</div>
                                        <span class="text-secondary" style="font-size: 10px;">PDF Document • 4.2 MB</span>
                                    </div>
                                </div>
                                <button class="btn-custom btn-custom-secondary py-1 px-3 text-caption" @onclick='() => NotificationState.AddToast("File Downloaded", "Acquisition invoice successfully saved to downloads.", ToastType.Success)'>Download</button>
                            </div>
                            <div class="p-3 border rounded-3 d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="lucide-image text-success fs-4"></i>
                                    <div>
                                        <div class="fw-semibold text-caption">Asset_Condition_Verification.jpg</div>
                                        <span class="text-secondary" style="font-size: 10px;">JPEG Image • 1.8 MB</span>
                                    </div>
                                </div>
                                <button class="btn-custom btn-custom-secondary py-1 px-3 text-caption" @onclick='() => NotificationState.AddToast("File Downloaded", "Asset inspection image downloaded.", ToastType.Success)'>Download</button>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Right Side Context Sidebar -->
            <div class="col-lg-4">
                <div class="card-custom bg-light-custom" style="background-color: var(--bg-surface-hover);">
                    <h3 class="h2-title border-bottom pb-3 mb-3">Lifecycle State</h3>
                    <p class="text-caption text-secondary mb-4">Quickly toggle state parameters or manage assignments directly.</p>
                    
                    @if (Asset.Status == "Available")
                    {
                        <button class="btn-custom btn-custom-primary w-100 mb-2 py-2" @onclick="OpenAssignDialog">
                            <i class="lucide-user-plus"></i> Assign Asset
                        </button>
                        <button class="btn-custom btn-custom-secondary w-100 mb-2 py-2" @onclick="OpenTransferDialog">
                            <i class="lucide-send"></i> Transfer Branch
                        </button>
                        <button class="btn-custom btn-custom-secondary w-100 mb-2 py-2" style="border-color: var(--warning); color: var(--warning);" @onclick="() => ToggleMaintenance(true)">
                            <i class="lucide-wrench"></i> Flag for Maintenance
                        </button>
                    }
                    else if (Asset.Status == "Assigned")
                    {
                        <button class="btn-custom btn-custom-secondary w-100 mb-2 py-2" style="border-color: var(--info); color: var(--info);" @onclick="ReturnAsset">
                            <i class="lucide-undo-2"></i> Register Return
                        </button>
                    }
                    else if (Asset.Status == "Maintenance")
                    {
                        <button class="btn-custom btn-custom-primary w-100 mb-2 py-2" style="background-color: var(--success);" @onclick="() => ToggleMaintenance(false)">
                            <i class="lucide-check"></i> Complete Maintenance
                        </button>
                    }
                </div>
            </div>
        </div>
    }
</div>

<!-- Assign Custody Dialog -->
<Dialog IsOpen="IsAssignDialogOpen" Title="Assign Asset Custody" Size="md" OnClose="() => IsAssignDialogOpen = false">
    <ChildContent>
        <div class="form-group-custom mb-3">
            <label class="form-label-custom">Select Employee for Assignment</label>
            <select class="form-control-custom" @bind="SelectedEmployeeForAssignment">
                <option value="">-- Choose Employee --</option>
                @if (Employees != null)
                {
                    @foreach (var emp in Employees)
                    {
                        <option value="@emp.Name">@emp.Name (@emp.Department)</option>
                    }
                }
            </select>
        </div>
        <p class="text-caption text-secondary">The asset condition is logged as 'Verifiable Good'. This worker will receive an automated email request to confirm custody.</p>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="() => IsAssignDialogOpen = false">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="ConfirmAssign">Assign Custody</button>
    </FooterContent>
</Dialog>

<!-- Transfer Branch Dialog -->
<Dialog IsOpen="IsTransferDialogOpen" Title="Transfer Operations Branch" Size="md" OnClose="() => IsTransferDialogOpen = false">
    <ChildContent>
        <div class="form-group-custom mb-3">
            <label class="form-label-custom">Target Branch Destination</label>
            <select class="form-control-custom" @bind="SelectedBranchForTransfer">
                <option value="">-- Select Branch --</option>
                @foreach (var br in Db.Branches)
                {
                    <option value="@br">@br</option>
                }
            </select>
        </div>
        <p class="text-caption text-secondary">A logistics transit request will be flagged. Estimated branch asset migration time: 24 hours.</p>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="() => IsTransferDialogOpen = false">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="ConfirmTransfer">Transfer</button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public string Id { get; set; } = "";
    private AssetMock? Asset;
    private List<EmployeeMock>? Employees;
    private string DetailSubView = "history";

    private bool IsAssignDialogOpen = false;
    private bool IsTransferDialogOpen = false;
    private string SelectedEmployeeForAssignment = "";
    private string SelectedBranchForTransfer = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsset();
        Employees = await EmployeeApiClient.GetEmployeesAsync();
    }

    private async Task LoadAsset()
    {
        Asset = await AssetApiClient.GetAssetAsync(Id);
        if (Asset == null)
        {
            NavigationManager.NavigateTo("/assets");
        }
    }

    private void SetDetailSubView(string view)
    {
        DetailSubView = view;
    }

    private List<Timeline.TimelineEvent> GetItemAuditEvents()
    {
        var list = new List<Timeline.TimelineEvent>();
        foreach (var log in Db.AuditLogs.Where(l => l.EntityId == Id))
        {
            list.Add(new Timeline.TimelineEvent
            {
                Timestamp = log.Timestamp,
                Title = log.Action.ToUpper() + " Event",
                Details = log.Details,
                User = log.User
            });
        }
        if (!list.Any())
        {
            list.Add(new Timeline.TimelineEvent
            {
                Timestamp = DateTime.Now.AddMonths(-1),
                Title = "RECORD CREATION",
                Details = "Resource registered and integrated into NexAsset ledger.",
                User = "System Seed"
            });
        }
        return list;
    }

    private void OpenAssignDialog()
    {
        SelectedEmployeeForAssignment = "";
        IsAssignDialogOpen = true;
    }

    private async Task ConfirmAssign()
    {
        if (Asset != null && !string.IsNullOrEmpty(SelectedEmployeeForAssignment))
        {
            await AssetApiClient.AssignAssetAsync(Asset.Id, SelectedEmployeeForAssignment);
            await LoadAsset();
        }
        IsAssignDialogOpen = false;
    }

    private void OpenTransferDialog()
    {
        SelectedBranchForTransfer = "";
        IsTransferDialogOpen = true;
    }

    private async Task ConfirmTransfer()
    {
        if (Asset != null && !string.IsNullOrEmpty(SelectedBranchForTransfer))
        {
            await AssetApiClient.TransferAssetAsync(Asset.Id, SelectedBranchForTransfer);
            await LoadAsset();
        }
        IsTransferDialogOpen = false;
    }

    private async Task ReturnAsset()
    {
        if (Asset != null)
        {
            await AssetApiClient.ReturnAssetAsync(Asset.Id);
            await LoadAsset();
        }
    }

    private async Task ToggleMaintenance(bool inMaintenance)
    {
        if (Asset != null)
        {
            await AssetApiClient.SetMaintenanceStatusAsync(Asset.Id, inMaintenance);
            await LoadAsset();
        }
    }
}
