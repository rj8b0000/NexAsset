@page "/assets"
@using NexAsset.Web.Infrastructure.Services
@using NexAsset.Web.Features.Assets.Components
@inject IAssetApiClient AssetApiClient
@inject IEmployeeApiClient EmployeeApiClient
@inject MockDatabaseService Db
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Assets Ledger</h1>
            <span class="text-caption text-secondary">Manage and organize physical hardware and equipment records.</span>
        </div>
        <div>
            <button type="button" class="btn-custom btn-custom-primary" @onclick='() => NavigationManager.NavigateTo("/assets/create")'>
                <i class="lucide-plus"></i> Create Asset
            </button>
        </div>
    </div>

    @if (Assets == null)
    {
        <LoadingState />
    }
    else
    {
        <DataTable TItem="AssetMock" Items="Assets" Type="Asset" Columns="AssetColumns"
                   IdSelector="a => a.Id" CategorySelector="a => a.Category" StatusSelector="a => a.Status"
                   OnViewDetails="HandleViewDetails" OnEdit="HandleEdit" OnDelete="HandleOpenDeleteDialog"
                   OnBulkDelete="HandleBulkDelete">
            <CustomRowActions Context="asset">
                @if (asset.Status == "Available")
                {
                    <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--primary);" @onclick="() => OpenAssignDialog(asset)">
                        <i class="lucide-user-plus me-2"></i> Assign
                    </button>
                    <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--warning);" @onclick="() => ToggleMaintenance(asset, true)">
                        <i class="lucide-wrench me-2"></i> Maintenance
                    </button>
                }
                else if (asset.Status == "Assigned")
                {
                    <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--info);" @onclick="() => ReturnAsset(asset)">
                        <i class="lucide-undo-2 me-2"></i> Return
                    </button>
                }
                else if (asset.Status == "Maintenance")
                {
                    <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--success);" @onclick="() => ToggleMaintenance(asset, false)">
                        <i class="lucide-check me-2"></i> Resolve Maint.
                    </button>
                }
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenTransferDialog(asset)">
                    <i class="lucide-send me-2"></i> Transfer
                </button>
            </CustomRowActions>
        </DataTable>
    }
</div>

<!-- Delete Confirm Dialog -->
<ConfirmDeleteDialog IsOpen="IsDeleteDialogOpen" EntityLabel="asset ledger record"
                      OnClose="() => IsDeleteDialogOpen = false" OnConfirm="ConfirmDelete" />

<!-- Assign Custody Dialog -->
<AssignAssetDialog IsOpen="IsAssignDialogOpen" Employees="Employees"
                    OnClose="() => IsAssignDialogOpen = false" OnConfirm="ConfirmAssign" />

<!-- Transfer Branch Dialog -->
<TransferAssetDialog IsOpen="IsTransferDialogOpen" Branches="Db.Branches"
                      OnClose="() => IsTransferDialogOpen = false" OnConfirm="ConfirmTransfer" />

@code {
    private new List<AssetMock>? Assets;
    private List<EmployeeMock>? Employees;
    private List<ColumnDefinition<AssetMock>> AssetColumns = new();

    private AssetMock? SelectedAsset;
    private bool IsDeleteDialogOpen = false;
    private bool IsAssignDialogOpen = false;
    private bool IsTransferDialogOpen = false;

    protected override async Task OnInitializedAsync()
    {
        Assets = await AssetApiClient.GetAssetsAsync();
        Employees = await EmployeeApiClient.GetEmployeesAsync();

        AssetColumns = new()
        {
            new() { Header = "Asset ID", PropertySelector = a => a.Id, SortColumn = "Id" },
            new() { Header = "Name", PropertySelector = a => a.Name, SortColumn = "Name" },
            new() { Header = "Category", PropertySelector = a => a.Category, SortColumn = "Category" },
            new() { Header = "Location", PropertySelector = a => a.Location, SortColumn = "Location" },
            new() { Header = "Status", PropertySelector = a => a.Status, SortColumn = "Status",
                    Template = asset => @<span class="badge-custom @(asset.Status == "Available" ? "badge-custom-success" : asset.Status == "Assigned" ? "badge-custom-primary" : "badge-custom-warning")">@asset.Status</span> },
            new() { Header = "Value", PropertySelector = a => a.Value.ToString(), SortColumn = "Value" },
            new() { Header = "AssignedTo", PropertySelector = a => a.AssignedTo ?? "Unassigned", SortColumn = "AssignedTo" }
        };
    }

    private void HandleViewDetails(AssetMock asset)
    {
        NavigationManager.NavigateTo($"/assets/details/{asset.Id}");
    }

    private void HandleEdit(AssetMock asset)
    {
        NavigationManager.NavigateTo($"/assets/edit/{asset.Id}");
    }

    private void HandleOpenDeleteDialog(AssetMock asset)
    {
        SelectedAsset = asset;
        IsDeleteDialogOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (SelectedAsset != null)
        {
            await AssetApiClient.DeleteAssetAsync(SelectedAsset.Id);
            Assets = await AssetApiClient.GetAssetsAsync();
        }
        IsDeleteDialogOpen = false;
    }

    private async Task HandleBulkDelete(List<AssetMock> items)
    {
        foreach (var item in items)
        {
            await AssetApiClient.DeleteAssetAsync(item.Id);
        }
        Assets = await AssetApiClient.GetAssetsAsync();
    }

    private void OpenAssignDialog(AssetMock asset)
    {
        SelectedAsset = asset;
        IsAssignDialogOpen = true;
    }

    private async Task ConfirmAssign(string employeeName)
    {
        if (SelectedAsset != null)
        {
            await AssetApiClient.AssignAssetAsync(SelectedAsset.Id, employeeName);
            Assets = await AssetApiClient.GetAssetsAsync();
        }
        IsAssignDialogOpen = false;
    }

    private void OpenTransferDialog(AssetMock asset)
    {
        SelectedAsset = asset;
        IsTransferDialogOpen = true;
    }

    private async Task ConfirmTransfer(string branchName)
    {
        if (SelectedAsset != null)
        {
            await AssetApiClient.TransferAssetAsync(SelectedAsset.Id, branchName);
            Assets = await AssetApiClient.GetAssetsAsync();
        }
        IsTransferDialogOpen = false;
    }

    private async Task ReturnAsset(AssetMock asset)
    {
        await AssetApiClient.ReturnAssetAsync(asset.Id);
        Assets = await AssetApiClient.GetAssetsAsync();
    }

    private async Task ToggleMaintenance(AssetMock asset, bool inMaintenance)
    {
        await AssetApiClient.SetMaintenanceStatusAsync(asset.Id, inMaintenance);
        Assets = await AssetApiClient.GetAssetsAsync();
    }
}
