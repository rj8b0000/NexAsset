@page "/assets"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Assets
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Assets.Components
@inject IAssetApiClient AssetApiClient
@inject IAssetCategoryApiClient AssetCategoryApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IBranchApiClient BranchApiClient
@inject IDepartmentApiClient DepartmentApiClient
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Assets</h1>
            <span class="text-caption text-secondary">Track physical assets, their placement, and lifecycle status.</span>
        </div>
        @if (Perms.HasPermission("Assets.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Asset
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading assets..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load assets" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="AssetListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Asset"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="a => a.Id.ToString()"
                   OnViewDetails="OpenDetails"
                   OnEdit="OpenEdit"
                   EditPermission="Assets.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Assets.Delete"
                   CustomRowActions="LifecycleActions" />
    }
</div>

<AssetFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<AssetDetailsDialog IsOpen="_detailsOpen" AssetId="_detailsId" OnClose="() => _detailsOpen = false"
                    Organizations="_orgNames" Categories="_categoryNames" Branches="_branchNames"
                    Departments="_deptNames" Employees="_empNames" />

<AssignAssetDialog IsOpen="_assignOpen" AssetId="_actionAssetId" OrganizationId="_actionAssetOrgId" AssetName="@_actionAssetName"
                   OnClose="() => _assignOpen = false" OnCompleted='() => OnLifecycleCompleted("assigned")' />

<UnassignAssetDialog IsOpen="_unassignOpen" AssetId="_actionAssetId" AssetName="@_actionAssetName"
                     OnClose="() => _unassignOpen = false" OnCompleted='() => OnLifecycleCompleted("unassigned")' />

<TransferAssetDialog IsOpen="_transferOpen" AssetId="_actionAssetId" AssetName="@_actionAssetName"
                     OnClose="() => _transferOpen = false" OnCompleted='() => OnLifecycleCompleted("transferred")' />

<ReturnAssetDialog IsOpen="_returnOpen" AssetId="_actionAssetId" AssetName="@_actionAssetName"
                   OnClose="() => _returnOpen = false" OnCompleted='() => OnLifecycleCompleted("returned")' />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="asset"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<AssetListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private bool _detailsOpen;
    private Guid? _detailsId;
    private AssetListItem? _deleteTarget;

    // Lifecycle action dialogs (assign / unassign / transfer / return)
    private bool _assignOpen;
    private bool _unassignOpen;
    private bool _transferOpen;
    private bool _returnOpen;
    private Guid? _actionAssetId;
    private Guid? _actionAssetOrgId;
    private string _actionAssetName = "";

    private Dictionary<Guid, string> _orgNames = new();
    private Dictionary<Guid, string> _categoryNames = new();
    private Dictionary<Guid, string> _branchNames = new();
    private Dictionary<Guid, string> _deptNames = new();
    private Dictionary<Guid, string> _empNames = new();

    private List<ColumnDefinition<AssetListItem>> _columns = new();

    // Lifecycle actions in the row menu, gated by current status: an unassigned asset can be
    // assigned; an assigned one can be transferred, returned, or unassigned. The backend enforces
    // the real business rules — these gates just keep the menu sensible.
    private RenderFragment<AssetListItem> LifecycleActions => item =>
        @<text>
            @if (item.AssetStatus == NexAsset.Web.Models.Assets.AssetStatus.Assigned)
            {
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenTransfer(item)">
                    <i class="lucide-arrow-right-left me-2"></i> Transfer
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenReturn(item)">
                    <i class="lucide-undo-2 me-2"></i> Return
                </button>
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenUnassign(item)">
                    <i class="lucide-user-x me-2"></i> Unassign
                </button>
            }
            else
            {
                <button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenAssign(item)">
                    <i class="lucide-user-check me-2"></i> Assign
                </button>
            }
        </text>;

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Asset Code", PropertySelector = a => a.AssetCode, SortColumn = "AssetCode" },
            new() { Header = "Name", Sortable = true, SortColumn = "AssetName", Template = a =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@a.AssetName</span> },
            new() { Header = "Category", Sortable = false, Template = a => @<span>@Lookup(_categoryNames, a.CategoryId)</span> },
            new() { Header = "Serial", Sortable = false, Template = a => @<span>@(string.IsNullOrEmpty(a.SerialNumber) ? "—" : a.SerialNumber)</span> },
            new() { Header = "Branch", Sortable = false, Template = a => @<span>@Lookup(_branchNames, a.BranchId)</span> },
            new() { Header = "Holder", Sortable = false, Template = a => @<span>@Lookup(_empNames, a.CurrentEmployeeId)</span> },
            new() { Header = "Status", Sortable = false, Template = a =>
                @<span class="badge-custom @(AssetStatus.BadgeClass(a.AssetStatus))">@AssetStatus.Label(a.AssetStatus)</span> }
        };

        await LoadLookupsAsync();
        await LoadAsync(_query);
    }

    private static string Lookup(Dictionary<Guid, string> map, Guid? id) =>
        id is { } g && map.TryGetValue(g, out var n) ? n : "—";

    private async Task LoadLookupsAsync()
    {
        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null) _orgNames = orgs.Data.Items.ToDictionary(o => o.Id, o => o.Name);
        var cats = await AssetCategoryApiClient.GetPagedAsync(big);
        if (cats.IsSuccess && cats.Data is not null) _categoryNames = cats.Data.Items.ToDictionary(c => c.Id, c => c.Name);
        var branches = await BranchApiClient.GetPagedAsync(big);
        if (branches.IsSuccess && branches.Data is not null) _branchNames = branches.Data.Items.ToDictionary(b => b.Id, b => b.Name);
        var depts = await DepartmentApiClient.GetPagedAsync(big);
        if (depts.IsSuccess && depts.Data is not null) _deptNames = depts.Data.Items.ToDictionary(d => d.Id, d => d.Name);
        var emps = await EmployeeApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "FirstName" });
        if (emps.IsSuccess && emps.Data is not null) _empNames = emps.Data.Items.ToDictionary(e => e.Id, e => $"{e.FirstName} {e.LastName}");
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await AssetApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading assets.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(AssetListItem item) { _editId = item.Id; _formOpen = true; }
    private void OpenDetails(AssetListItem item) { _detailsId = item.Id; _detailsOpen = true; }

    private void SetActionTarget(AssetListItem item)
    {
        _actionAssetId = item.Id;
        _actionAssetOrgId = item.OrganizationId;
        _actionAssetName = $"{item.AssetCode} · {item.AssetName}";
    }

    private void OpenAssign(AssetListItem item) { SetActionTarget(item); _assignOpen = true; }
    private void OpenUnassign(AssetListItem item) { SetActionTarget(item); _unassignOpen = true; }
    private void OpenTransfer(AssetListItem item) { SetActionTarget(item); _transferOpen = true; }
    private void OpenReturn(AssetListItem item) { SetActionTarget(item); _returnOpen = true; }

    private async Task OnLifecycleCompleted(string verb)
    {
        _assignOpen = _unassignOpen = _transferOpen = _returnOpen = false;
        Notifications.ShowSuccess("Done", $"Asset {verb} successfully.");
        await LoadAsync(_query);
    }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Asset saved successfully.");
        await LoadLookupsAsync();
        await LoadAsync(_query);
    }

    private void AskDelete(AssetListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await AssetApiClient.DeleteAsync(target.Id);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Asset \"{target.AssetName}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this asset.");
        }
    }
}
