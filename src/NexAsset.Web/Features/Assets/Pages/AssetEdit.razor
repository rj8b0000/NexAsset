@page "/assets/edit/{id}"
@using NexAsset.Web.Infrastructure.Models
@using NexAsset.Web.Infrastructure.Services
@inject IAssetApiClient AssetApiClient
@inject MockDatabaseService Db
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    @if (Asset == null)
    {
        <LoadingState />
    }
    else
    {
        <FormSection Title="@($"Edit Asset: {Asset.Id}")" 
                     Breadcrumbs='(new List<string> { "Assets", "Edit" })' 
                     OnCancel="HandleCancel" OnSave="HandleSave" OnReset="HandleReset">
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Asset Name</label>
                    <input type="text" class="form-control-custom" placeholder="e.g. MacBook Pro M3" @bind="Asset.Name" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Serial Code</label>
                    <input type="text" class="form-control-custom" placeholder="e.g. C02GXXXX" @bind="Asset.Serial" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Equipment Category</label>
                    <select class="form-control-custom" @bind="Asset.Category">
                        <option value="IT Equipment">IT Equipment</option>
                        <option value="Mobile Devices">Mobile Devices</option>
                        <option value="Networking">Networking</option>
                        <option value="Office Equipment">Office Equipment</option>
                        <option value="Vehicles">Vehicles</option>
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Acquisition Value (USD)</label>
                    <input type="number" class="form-control-custom" placeholder="0.00" @bind="Asset.Value" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Operations Location</label>
                    <select class="form-control-custom" @bind="Asset.Location">
                        @foreach (var br in Db.Branches)
                        {
                            <option value="@br">@br</option>
                        }
                    </select>
                </div>
            </div>
        </FormSection>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private AssetMock? Asset;
    private AssetMock? OriginalAsset;

    protected override async Task OnInitializedAsync()
    {
        var original = await AssetApiClient.GetAssetAsync(Id);
        if (original != null)
        {
            // Clone the original to avoid mutating state directly on bind in case user cancels
            Asset = new AssetMock
            {
                Id = original.Id,
                Name = original.Name,
                Serial = original.Serial,
                Category = original.Category,
                Value = original.Value,
                Location = original.Location,
                Status = original.Status,
                AssignedTo = original.AssignedTo,
                PurchaseDate = original.PurchaseDate,
                CreatedDate = original.CreatedDate
            };
            OriginalAsset = original;
        }
        else
        {
            NavigationManager.NavigateTo("/assets");
        }
    }

    private async Task HandleSave()
    {
        if (Asset != null)
        {
            await AssetApiClient.UpdateAssetAsync(Asset);
        }
        NavigationManager.NavigateTo("/assets");
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/assets");
    }

    private void HandleReset()
    {
        if (OriginalAsset != null && Asset != null)
        {
            Asset.Name = OriginalAsset.Name;
            Asset.Serial = OriginalAsset.Serial;
            Asset.Category = OriginalAsset.Category;
            Asset.Value = OriginalAsset.Value;
            Asset.Location = OriginalAsset.Location;
            Asset.Status = OriginalAsset.Status;
        }
    }
}
