@page "/procurement/create"
@using NexAsset.Web.Infrastructure.Services
@inject IProcurementApiClient ProcurementApiClient
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <FormSection Title="New Purchase Request" 
                 Breadcrumbs='(new List<string> { "Procurement", "Create" })' 
                 OnCancel="HandleCancel" OnSave="HandleSave" OnReset="HandleReset">
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Required Item Name</label>
                <input type="text" class="form-control-custom" placeholder="e.g. Dell Monitor 32&quot;" @bind="NewRequest.ItemName" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Quantity</label>
                <input type="number" class="form-control-custom" placeholder="1" @bind="NewRequest.Quantity" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Unit Price (USD)</label>
                <input type="number" class="form-control-custom" placeholder="0.00" @bind="NewRequest.UnitPrice" />
            </div>
        </div>
    </FormSection>
</div>

@code {
    private ProcurementMock NewRequest = new() 
    { 
        Quantity = 1, 
        Requester = "Admin User", 
        Status = "Pending" 
    };

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(NewRequest.ItemName)) return;
        await ProcurementApiClient.CreateProcurementRequestAsync(NewRequest);
        NavigationManager.NavigateTo("/procurement");
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/procurement");
    }

    private void HandleReset()
    {
        NewRequest = new ProcurementMock
        {
            Quantity = 1,
            Requester = "Admin User",
            Status = "Pending"
        };
    }
}
