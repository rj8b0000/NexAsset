@page "/designations"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Foundation
@using NexAsset.Web.Features.Designations.Components
@inject IDesignationApiClient DesignationApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IDepartmentApiClient DepartmentApiClient
@inject NexAsset.Web.Infrastructure.HR.IPermissionApiClient PermissionApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Designations</h1>
            <span class="text-caption text-secondary">Define job titles and roles across organizations and departments.</span>
        </div>
        @if (Perms.HasPermission("Designations.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Designation
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading designations..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load designations" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="DesignationListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Designation"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="d => d.Id.ToString()"
                   OnEdit="OpenEdit"
                   EditPermission="Designations.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Designations.Delete"
                   CustomRowActions="PermissionsAction" />
    }
</div>

<DesignationFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<PermissionTreeDialog IsOpen="_permsOpen" SubjectName="@_permsDesignationTitle"
                      LoadAssigned="() => PermissionApiClient.GetForDesignationAsync(_permsDesignationId!.Value)"
                      Assign="pid => PermissionApiClient.AssignToDesignationAsync(_permsDesignationId!.Value, pid)"
                      Remove="pid => PermissionApiClient.RemoveFromDesignationAsync(_permsDesignationId!.Value, pid)"
                      OnClose="() => _permsOpen = false" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="designation"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<DesignationListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private DesignationListItem? _deleteTarget;

    private bool _permsOpen;
    private Guid? _permsDesignationId;
    private string _permsDesignationTitle = "";

    private Dictionary<Guid, string> _orgNames = new();
    private Dictionary<Guid, string> _departmentNames = new();
    private List<ColumnDefinition<DesignationListItem>> _columns = new();

    private RenderFragment<DesignationListItem> PermissionsAction => item =>
        @<button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenPermissions(item)">
            <i class="lucide-key-round me-2"></i> Permissions
        </button>;

    private void OpenPermissions(DesignationListItem item)
    {
        _permsDesignationId = item.Id;
        _permsDesignationTitle = item.Title;
        _permsOpen = true;
    }

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Title", PropertySelector = d => d.Title, SortColumn = "Title" },
            new() { Header = "Organization", Sortable = false, Template = d =>
                @<span>@(_orgNames.TryGetValue(d.OrganizationId, out var n) ? n : "—")</span> },
            @* No department means the designation spans the whole company (CEO, COO, MD). *@
            new() { Header = "Department", Sortable = false, Template = d =>
                @<span>@(d.DepartmentId is { } dept ? (_departmentNames.TryGetValue(dept, out var dn) ? dn : "—") : "All")</span> },
            new() { Header = "Status", SortColumn = "IsActive", Template = d =>
                @<span class="badge-custom @(d.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(d.IsActive ? "Active" : "Inactive")</span> }
        };

        await LoadOrganizationNamesAsync();
        await LoadDepartmentNamesAsync();
        await LoadAsync(_query);
    }

    private async Task LoadOrganizationNamesAsync()
    {
        var result = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _orgNames = result.Data.Items.ToDictionary(o => o.Id, o => o.Name);
    }

    private async Task LoadDepartmentNamesAsync()
    {
        var result = await DepartmentApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _departmentNames = result.Data.Items.ToDictionary(d => d.Id, d => d.Name);
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await DesignationApiClient.GetPagedAsync(query);
        _busy = false;

        if (result.IsSuccess && result.Data is not null)
            _page = result.Data;
        else
            _loadError = result.Error?.Message ?? "Something went wrong while loading designations.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(DesignationListItem item) { _editId = item.Id; _formOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Designation saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(DesignationListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await DesignationApiClient.DeleteAsync(target.Id);
        _busy = false;

        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Designation \"{target.Title}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this designation.");
        }
    }
}
