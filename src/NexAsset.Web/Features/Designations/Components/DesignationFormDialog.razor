@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Models.Foundation
@using NexAsset.Web.Shared.Models
@inject IDesignationApiClient DesignationApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IDepartmentApiClient DepartmentApiClient

<Dialog IsOpen="IsOpen" Title="@(IsEdit ? "Edit Designation" : "New Designation")" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (_loading)
        {
            <LoadingState Message="Loading designation..." />
        }
        else
        {
            @if (!string.IsNullOrEmpty(_generalError))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                    <i class="lucide-alert-circle"></i> @_generalError
                </div>
            }
            <div class="row g-3">
                <SelectField Label="Organization" Required="true" Options="_orgOptions" Placeholder="Select an organization"
                             Value="@OrgIdString" ValueChanged="OnOrgChanged" Error='@Err("OrganizationId")' />
                <SelectField Label="Department" Options="DeptOptions" Placeholder="(None)"
                             Value="@DeptIdString" ValueChanged="OnDeptChanged" Error='@Err("DepartmentId")' />
                <TextField Label="Title" Required="true" ColumnClass="col-12" Value="@_model.Title" ValueChanged="@(v => _model.Title = v)" Error='@Err("Title")' />
                <TextField Label="Description" ColumnClass="col-12" Multiline="true" Value="@_model.Description" ValueChanged="@(v => _model.Description = v)" Error='@Err("Description")' />
                @if (IsEdit)
                {
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="desig-active" checked="@_model.IsActive" @onchange="e => _model.IsActive = (bool)e.Value!" />
                            <label class="form-check-label text-caption" for="desig-active">Active</label>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@(_saving || _loading)">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Save</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EditId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private DesignationFormModel _model = new();
    private List<SelectField.Option> _orgOptions = new();
    private List<(Guid Id, Guid OrgId, string Label)> _allDepartments = new();
    private bool _loading;
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private bool IsEdit => EditId.HasValue;
    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    private string OrgIdString => _model.OrganizationId == Guid.Empty ? "" : _model.OrganizationId.ToString();
    private string DeptIdString => _model.DepartmentId?.ToString() ?? "";

    // Departments belonging to the selected organization only.
    private IReadOnlyList<SelectField.Option> DeptOptions => _allDepartments
        .Where(d => d.OrgId == _model.OrganizationId)
        .Select(d => new SelectField.Option(d.Id.ToString(), d.Label))
        .ToList();

    private void OnOrgChanged(string v)
    {
        _model.OrganizationId = Guid.TryParse(v, out var g) ? g : Guid.Empty;
        // A department from a different org is no longer valid.
        if (_model.DepartmentId is { } dep && !_allDepartments.Any(d => d.Id == dep && d.OrgId == _model.OrganizationId))
            _model.DepartmentId = null;
    }

    private void OnDeptChanged(string v) => _model.DepartmentId = Guid.TryParse(v, out var g) ? g : null;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open) { _open = true; await InitializeAsync(); }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task InitializeAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        _model = new DesignationFormModel();
        _loading = true;

        await LoadLookupsAsync();

        if (EditId.HasValue)
        {
            var result = await DesignationApiClient.GetByIdAsync(EditId.Value);
            if (result.IsSuccess && result.Data is not null)
                _model = DesignationFormModel.FromDetail(result.Data);
            else
                _generalError = result.Error?.Message ?? "Could not load this designation.";
        }
        _loading = false;
    }

    private async Task LoadLookupsAsync()
    {
        var orgs = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (orgs.IsSuccess && orgs.Data is not null)
            _orgOptions = orgs.Data.Items.Select(o => new SelectField.Option(o.Id.ToString(), $"{o.Code} — {o.Name}")).ToList();

        var depts = await DepartmentApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" });
        if (depts.IsSuccess && depts.Data is not null)
            _allDepartments = depts.Data.Items.Select(d => (d.Id, d.OrganizationId, $"{d.Code} — {d.Name}")).ToList();
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();

        if (_model.OrganizationId == Guid.Empty) _fieldErrors["OrganizationId"] = "Organization is required.";
        if (string.IsNullOrWhiteSpace(_model.Title)) _fieldErrors["Title"] = "Title is required.";
        if (_fieldErrors.Count > 0) return;

        _saving = true;
        bool success;
        ApiError? error;
        if (IsEdit)
        {
            var res = await DesignationApiClient.UpdateAsync(EditId!.Value, _model);
            success = res.IsSuccess; error = res.Error;
        }
        else
        {
            var res = await DesignationApiClient.CreateAsync(_model);
            success = res.IsSuccess; error = res.Error;
        }
        _saving = false;

        if (!success) { ApplyError(error); return; }
        await OnSaved.InvokeAsync();
    }

    private void ApplyError(ApiError? error)
    {
        _generalError = error?.Message ?? "Save failed. Please try again.";
        if (error?.FieldErrors is not null)
            foreach (var kv in error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
