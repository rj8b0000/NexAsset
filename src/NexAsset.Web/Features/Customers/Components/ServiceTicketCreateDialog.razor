@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Customers
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Models.Customers
@using NexAsset.Web.Shared.Models
@inject IServiceTicketApiClient ServiceTicketApiClient
@inject ICustomerApiClient CustomerApiClient
@inject IOrganizationApiClient OrganizationApiClient

<Dialog IsOpen="IsOpen" Title="New Service Ticket" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_generalError))
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                <i class="lucide-alert-circle"></i> @_generalError
            </div>
        }
        <div class="row g-3">
            <SelectField Label="Organization" Required="true" Options="_orgOptions" Placeholder="Select an organization"
                         Value="@(_model.OrganizationId == Guid.Empty ? "" : _model.OrganizationId.ToString())"
                         ValueChanged="@(v => _model.OrganizationId = Guid.TryParse(v, out var g) ? g : Guid.Empty)"
                         Error='@Err("OrganizationId")' />
            <SelectField Label="Customer" Required="true" Options="_customerOptions" Placeholder="Select a customer"
                         Value="@(_model.CustomerId == Guid.Empty ? "" : _model.CustomerId.ToString())"
                         ValueChanged="@(v => _model.CustomerId = Guid.TryParse(v, out var g) ? g : Guid.Empty)"
                         Error='@Err("CustomerId")' />
            <TextField Label="Ticket Number" Required="true" Value="@_model.TicketNumber" ValueChanged="@(v => _model.TicketNumber = v)" Error='@Err("TicketNumber")' />
            <SelectField Label="Priority" Required="true" Options="_priorityOptions" Placeholder="Select priority"
                         Value="@_model.Priority.ToString()"
                         ValueChanged="@(v => _model.Priority = int.TryParse(v, out var p) ? p : TicketPriority.Medium)"
                         Error='@Err("Priority")' />
            <TextField Label="Title" Required="true" ColumnClass="col-12" Value="@_model.Title" ValueChanged="@(v => _model.Title = v)" Error='@Err("Title")' />
            <TextField Label="Description" ColumnClass="col-12" Multiline="true" Value="@_model.Description" ValueChanged="@(v => _model.Description = v)" Error='@Err("Description")' />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Save</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ServiceTicketCreateModel _model = new();
    private List<SelectField.Option> _orgOptions = new();
    private List<SelectField.Option> _customerOptions = new();
    private readonly List<SelectField.Option> _priorityOptions =
        TicketPriority.Options.Select(o => new SelectField.Option(o.Value.ToString(), o.Label)).ToList();

    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open)
        {
            _open = true;
            _generalError = null;
            _fieldErrors = new();
            _model = new ServiceTicketCreateModel();
            await LoadLookupsAsync();
        }
        else if (!IsOpen && _open)
        {
            _open = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null)
            _orgOptions = orgs.Data.Items.Select(o => new SelectField.Option(o.Id.ToString(), $"{o.Code} — {o.Name}")).ToList();
        var customers = await CustomerApiClient.GetPagedAsync(big);
        if (customers.IsSuccess && customers.Data is not null)
            _customerOptions = customers.Data.Items.Select(c => new SelectField.Option(c.Id.ToString(), $"{c.Code} — {c.Name}")).ToList();
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();

        if (_model.OrganizationId == Guid.Empty) _fieldErrors["OrganizationId"] = "Organization is required.";
        if (_model.CustomerId == Guid.Empty) _fieldErrors["CustomerId"] = "Customer is required.";
        if (string.IsNullOrWhiteSpace(_model.TicketNumber)) _fieldErrors["TicketNumber"] = "Ticket number is required.";
        if (string.IsNullOrWhiteSpace(_model.Title)) _fieldErrors["Title"] = "Title is required.";
        if (_fieldErrors.Count > 0) return;

        _saving = true;
        var result = await ServiceTicketApiClient.CreateAsync(_model);
        _saving = false;

        if (!result.IsSuccess)
        {
            _generalError = result.Error?.Message ?? "Save failed. Please try again.";
            if (result.Error?.FieldErrors is not null)
                foreach (var kv in result.Error.FieldErrors)
                    _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
            return;
        }
        await OnSaved.InvokeAsync();
    }
}
