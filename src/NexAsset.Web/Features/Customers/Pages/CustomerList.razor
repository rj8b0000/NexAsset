@page "/customers"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Customers
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Customers
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Customers.Components
@inject ICustomerApiClient CustomerApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Customers</h1>
            <span class="text-caption text-secondary">Manage customer accounts and their service history.</span>
        </div>
        @if (Perms.HasPermission("Customers.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Customer
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading customers..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load customers" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="CustomerItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Customer"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="c => c.Id.ToString()"
                   OnEdit="OpenEdit"
                   EditPermission="Customers.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Customers.Delete" />
    }
</div>

<CustomerFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="customer"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<CustomerItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private CustomerItem? _deleteTarget;

    private readonly List<ColumnDefinition<CustomerItem>> _columns = new()
    {
        new() { Header = "Customer Code", PropertySelector = c => c.Code, SortColumn = "Code" },
        new() { Header = "Customer Name", PropertySelector = c => c.Name, SortColumn = "Name" },
        new() { Header = "Email", PropertySelector = c => c.Email, SortColumn = "Email" },
        new() { Header = "Phone", Sortable = false, Template = c => @<span>@(string.IsNullOrEmpty(c.Phone) ? "—" : c.Phone)</span> },
        new() { Header = "Status", SortColumn = "IsActive", Template = c =>
            @<span class="badge-custom @(c.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(c.IsActive ? "Active" : "Inactive")</span> }
    };

    protected override Task OnInitializedAsync() => LoadAsync(_query);

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await CustomerApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading customers.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(CustomerItem item) { _editId = item.Id; _formOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Customer saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(CustomerItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await CustomerApiClient.DeleteAsync(target.Id);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Customer \"{target.Name}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this customer.");
        }
    }
}
