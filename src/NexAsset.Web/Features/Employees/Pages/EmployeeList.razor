@page "/employees"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.HR
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Employees.Components
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IBranchApiClient BranchApiClient
@inject IDepartmentApiClient DepartmentApiClient
@inject IDesignationApiClient DesignationApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Employees</h1>
            <span class="text-caption text-secondary">Manage employee records, employment details, and org placement.</span>
        </div>
        @if (Perms.HasPermission("Employees.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Employee
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading employees..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load employees" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="EmployeeListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Employee"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="e => e.Id.ToString()"
                   OnViewDetails="OpenDetails"
                   OnEdit="OpenEdit"
                   EditPermission="Employees.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Employees.Delete"
                   CustomRowActions="ActivateDeactivateAction" />
    }
</div>

<EmployeeFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<EmployeeDetailsDialog IsOpen="_detailsOpen" EmployeeId="_detailsId" OnClose="() => _detailsOpen = false"
                       Organizations="_orgNames" Branches="_branchNames" Departments="_deptNames"
                       Designations="_designationNames" Managers="_empNames" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="employee"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<EmployeeListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private bool _detailsOpen;
    private Guid? _detailsId;
    private EmployeeListItem? _deleteTarget;

    private Dictionary<Guid, string> _orgNames = new();
    private Dictionary<Guid, string> _branchNames = new();
    private Dictionary<Guid, string> _deptNames = new();
    private Dictionary<Guid, string> _designationNames = new();
    private Dictionary<Guid, string> _empNames = new();

    private List<ColumnDefinition<EmployeeListItem>> _columns = new();

    private RenderFragment<EmployeeListItem> ActivateDeactivateAction => item =>
        @<button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => ToggleActiveAsync(item)">
            <i class="@(item.IsActive ? "lucide-user-x" : "lucide-user-check") me-2"></i> @(item.IsActive ? "Deactivate" : "Activate")
        </button>;

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Code", PropertySelector = e => e.EmployeeCode, SortColumn = "EmployeeCode" },
            new() { Header = "Name", Sortable = true, SortColumn = "FirstName", Template = e =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@e.FirstName @e.LastName</span> },
            new() { Header = "Email", PropertySelector = e => e.Email, SortColumn = "Email" },
            new() { Header = "Organization", Sortable = false, Template = e => @<span>@Lookup(_orgNames, e.OrganizationId)</span> },
            new() { Header = "Branch", Sortable = false, Template = e => @<span>@Lookup(_branchNames, e.BranchId)</span> },
            new() { Header = "Department", Sortable = false, Template = e => @<span>@Lookup(_deptNames, e.DepartmentId)</span> },
            new() { Header = "Designation", Sortable = false, Template = e => @<span>@Lookup(_designationNames, e.DesignationId)</span> },
            new() { Header = "Employment", Sortable = false, Template = e => @<span>@EmploymentStatus.Label(e.EmploymentStatus)</span> },
            new() { Header = "Joining Date", Sortable = true, SortColumn = "JoiningDate", Template = e => @<span>@e.JoiningDate.ToString("yyyy-MM-dd")</span> },
            new() { Header = "Status", SortColumn = "IsActive", Template = e =>
                @<span class="badge-custom @(e.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(e.IsActive ? "Active" : "Inactive")</span> }
        };

        await LoadLookupsAsync();
        await LoadAsync(_query);
    }

    private static string Lookup(Dictionary<Guid, string> map, Guid? id) =>
        id is { } g && map.TryGetValue(g, out var n) ? n : "—";

    private async Task LoadLookupsAsync()
    {
        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null) _orgNames = orgs.Data.Items.ToDictionary(o => o.Id, o => o.Name);
        var branches = await BranchApiClient.GetPagedAsync(big);
        if (branches.IsSuccess && branches.Data is not null) _branchNames = branches.Data.Items.ToDictionary(b => b.Id, b => b.Name);
        var depts = await DepartmentApiClient.GetPagedAsync(big);
        if (depts.IsSuccess && depts.Data is not null) _deptNames = depts.Data.Items.ToDictionary(d => d.Id, d => d.Name);
        var desigs = await DesignationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Title" });
        if (desigs.IsSuccess && desigs.Data is not null) _designationNames = desigs.Data.Items.ToDictionary(d => d.Id, d => d.Title);
        var emps = await EmployeeApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "FirstName" });
        if (emps.IsSuccess && emps.Data is not null) _empNames = emps.Data.Items.ToDictionary(e => e.Id, e => $"{e.FirstName} {e.LastName}");
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await EmployeeApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading employees.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(EmployeeListItem item) { _editId = item.Id; _formOpen = true; }
    private void OpenDetails(EmployeeListItem item) { _detailsId = item.Id; _detailsOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Employee saved successfully.");
        await LoadLookupsAsync();
        await LoadAsync(_query);
    }

    private void AskDelete(EmployeeListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await EmployeeApiClient.DeleteAsync(target.Id);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Employee \"{target.FirstName} {target.LastName}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this employee.");
        }
    }

    // No dedicated activate endpoint — toggle IsActive through a full update (GetById → PUT).
    private async Task ToggleActiveAsync(EmployeeListItem item)
    {
        _busy = true;
        var detail = await EmployeeApiClient.GetByIdAsync(item.Id);
        if (!detail.IsSuccess || detail.Data is null)
        {
            _busy = false;
            Notifications.ShowError("Failed", detail.Error?.Message ?? "Could not load the employee.");
            return;
        }
        var model = EmployeeFormModel.FromDetail(detail.Data);
        model.IsActive = !item.IsActive;
        var result = await EmployeeApiClient.UpdateAsync(item.Id, model);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess(model.IsActive ? "Activated" : "Deactivated", $"{item.FirstName} {item.LastName} is now {(model.IsActive ? "active" : "inactive")}.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Update failed", result.Error?.Message ?? "Could not update the employee.");
        }
    }
}
