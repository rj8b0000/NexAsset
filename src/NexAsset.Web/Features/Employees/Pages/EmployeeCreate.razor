@page "/employees/create"
@using NexAsset.Web.Infrastructure.Services
@inject IEmployeeApiClient EmployeeApiClient
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <FormSection Title="Register New Employee" 
                 Breadcrumbs='(new List<string> { "Employees", "Create" })' 
                 OnCancel="HandleCancel" OnSave="HandleSave" OnReset="HandleReset">
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Full Name</label>
                <input type="text" class="form-control-custom" placeholder="Alice Smith" @bind="NewEmployee.Name" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Email Address</label>
                <input type="email" class="form-control-custom" placeholder="alice@nexasset.com" @bind="NewEmployee.Email" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Department</label>
                <input type="text" class="form-control-custom" placeholder="Engineering" @bind="NewEmployee.Department" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Job Role</label>
                <input type="text" class="form-control-custom" placeholder="Principal Engineer" @bind="NewEmployee.Role" />
            </div>
        </div>
        <div class="col-md-6">
            <div class="form-group-custom">
                <label class="form-label-custom">Status</label>
                <select class="form-control-custom" @bind="NewEmployee.Status">
                    <option value="Active">Active</option>
                    <option value="On Leave">On Leave</option>
                    <option value="Terminated">Terminated</option>
                </select>
            </div>
        </div>
    </FormSection>
</div>

@code {
    private EmployeeMock NewEmployee = new() { Status = "Active" };

    private async Task HandleSave()
    {
        if (string.IsNullOrEmpty(NewEmployee.Name)) return;
        await EmployeeApiClient.CreateEmployeeAsync(NewEmployee);
        NavigationManager.NavigateTo("/employees");
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/employees");
    }

    private void HandleReset()
    {
        NewEmployee = new EmployeeMock { Status = "Active" };
    }
}
