@page "/employees/edit/{id}"
@using NexAsset.Web.Infrastructure.Models
@using NexAsset.Web.Infrastructure.Services
@inject IEmployeeApiClient EmployeeApiClient
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    @if (Employee == null)
    {
        <LoadingState />
    }
    else
    {
        <FormSection Title="@($"Edit Employee: {Employee.Id}")" 
                     Breadcrumbs='(new List<string> { "Employees", "Edit" })' 
                     OnCancel="HandleCancel" OnSave="HandleSave" OnReset="HandleReset">
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Full Name</label>
                    <input type="text" class="form-control-custom" placeholder="Alice Smith" @bind="Employee.Name" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Email Address</label>
                    <input type="email" class="form-control-custom" placeholder="alice@nexasset.com" @bind="Employee.Email" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Department</label>
                    <input type="text" class="form-control-custom" placeholder="Engineering" @bind="Employee.Department" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Job Role</label>
                    <input type="text" class="form-control-custom" placeholder="Principal Engineer" @bind="Employee.Role" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group-custom">
                    <label class="form-label-custom">Status</label>
                    <select class="form-control-custom" @bind="Employee.Status">
                        <option value="Active">Active</option>
                        <option value="On Leave">On Leave</option>
                        <option value="Terminated">Terminated</option>
                    </select>
                </div>
            </div>
        </FormSection>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = "";
    private EmployeeMock? Employee;
    private EmployeeMock? OriginalEmployee;

    protected override async Task OnInitializedAsync()
    {
        var original = await EmployeeApiClient.GetEmployeeAsync(Id);
        if (original != null)
        {
            Employee = new EmployeeMock
            {
                Id = original.Id,
                Name = original.Name,
                Email = original.Email,
                Department = original.Department,
                Role = original.Role,
                Status = original.Status,
                AssetsAssigned = original.AssetsAssigned
            };
            OriginalEmployee = original;
        }
        else
        {
            NavigationManager.NavigateTo("/employees");
        }
    }

    private async Task HandleSave()
    {
        if (Employee != null)
        {
            await EmployeeApiClient.UpdateEmployeeAsync(Employee);
        }
        NavigationManager.NavigateTo("/employees");
    }

    private void HandleCancel()
    {
        NavigationManager.NavigateTo("/employees");
    }

    private void HandleReset()
    {
        if (OriginalEmployee != null && Employee != null)
        {
            Employee.Name = OriginalEmployee.Name;
            Employee.Email = OriginalEmployee.Email;
            Employee.Department = OriginalEmployee.Department;
            Employee.Role = OriginalEmployee.Role;
            Employee.Status = OriginalEmployee.Status;
        }
    }
}
