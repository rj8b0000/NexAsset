@using NexAsset.Web.Models.HR
@inject NexAsset.Web.Infrastructure.HR.IEmployeeApiClient EmployeeApiClient

<Dialog IsOpen="IsOpen" Title="Employee Details" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (_loading)
        {
            <LoadingState Message="Loading employee..." />
        }
        else if (_error is not null)
        {
            <div class="alert alert-danger py-2 px-3 border-0 text-caption rounded-3" style="background-color: var(--danger-light); color: var(--danger);">@_error</div>
        }
        else if (_detail is not null)
        {
            <div class="d-flex align-items-center gap-3 mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 52px; height: 52px; background-color: var(--primary-light); color: var(--primary); font-size: 18px;">
                    @Initials(_detail.FirstName, _detail.LastName)
                </div>
                <div>
                    <div class="h2-title mb-0">@_detail.FirstName @_detail.LastName</div>
                    <span class="text-caption text-secondary">@_detail.EmployeeCode</span>
                    <span class="badge-custom @(_detail.IsActive ? "badge-custom-success" : "badge-custom-secondary") ms-2">@(_detail.IsActive ? "Active" : "Inactive")</span>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="text-label mb-2">Contact Information</div>
                    @Row("Email", _detail.Email)
                    @Row("Phone", string.IsNullOrEmpty(_detail.Phone) ? "—" : _detail.Phone!)
                </div>
                <div class="col-md-6">
                    <div class="text-label mb-2">Employment</div>
                    @Row("Status", EmploymentStatus.Label(_detail.EmploymentStatus))
                    @Row("Joining Date", _detail.JoiningDate.ToString("yyyy-MM-dd"))
                    @Row("Reporting Manager", Name(Managers, _detail.ReportingManagerId))
                </div>
                <div class="col-md-6">
                    <div class="text-label mb-2">Organization</div>
                    @Row("Organization", Name(Organizations, _detail.OrganizationId))
                    @Row("Branch", Name(Branches, _detail.BranchId))
                    @Row("Department", Name(Departments, _detail.DepartmentId))
                    @Row("Designation", Name(Designations, _detail.DesignationId))
                </div>
                <div class="col-md-6">
                    <div class="text-label mb-2">Account</div>
                    @Row("Linked login", _detail.IdentityUserId is null ? "—" : "Yes")
                </div>
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose">Close</button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EmployeeId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public Dictionary<Guid, string> Organizations { get; set; } = new();
    [Parameter] public Dictionary<Guid, string> Branches { get; set; } = new();
    [Parameter] public Dictionary<Guid, string> Departments { get; set; } = new();
    [Parameter] public Dictionary<Guid, string> Designations { get; set; } = new();
    [Parameter] public Dictionary<Guid, string> Managers { get; set; } = new();

    private EmployeeDetail? _detail;
    private bool _loading;
    private string? _error;
    private bool _open;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open) { _open = true; await LoadAsync(); }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task LoadAsync()
    {
        _detail = null; _error = null;
        if (EmployeeId is null) return;
        _loading = true;
        var result = await EmployeeApiClient.GetByIdAsync(EmployeeId.Value);
        _loading = false;
        if (result.IsSuccess && result.Data is not null) _detail = result.Data;
        else _error = result.Error?.Message ?? "Could not load this employee.";
    }

    private static string Initials(string first, string last) =>
        $"{(first.Length > 0 ? first[0] : ' ')}{(last.Length > 0 ? last[0] : ' ')}".Trim().ToUpperInvariant();

    private static string Name(Dictionary<Guid, string> map, Guid? id) =>
        id is { } g && map.TryGetValue(g, out var n) ? n : "—";

    private RenderFragment Row(string label, string value) => @<div class="d-flex justify-content-between py-1 border-bottom" style="border-color: var(--border-color) !important;">
        <span class="text-caption text-secondary">@label</span>
        <span class="text-caption fw-semibold" style="color: var(--text-primary);">@value</span>
    </div>;
}
