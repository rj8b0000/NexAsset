@page "/administration"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.Administration
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Models.Administration
@using NexAsset.Web.Shared.Models
@inject IAuditTrailApiClient AuditTrailApiClient
@inject NavigationManager NavigationManager

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">System Administration</h1>
            <span class="text-caption text-secondary">Review system operations logs, user audit trails, and configuration events.</span>
        </div>
    </div>

    <!-- Admin tabs list -->
    <div class="tabs-container mb-3">
        <div class="tab-item active">Audit Trails</div>
        <div class="tab-item" @onclick='() => NavigationManager.NavigateTo("/administration/timeline")'>System Timeline</div>
        <div class="tab-item" @onclick='() => NavigationManager.NavigateTo("/settings")'>System Settings</div>
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading audit trail..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load the audit trail" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="AuditLogRecord"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Audit Log"
                   ShowFilterPanel="false"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="l => l.Id.ToString()" />
    }
</div>

@code {
    private PagedResult<AuditLogRecord>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private List<ColumnDefinition<AuditLogRecord>> _columns = new();

    protected override Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Timestamp", Sortable = true, SortColumn = "TimestampUtc", Template = l =>
                @<span>@l.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</span> },
            new() { Header = "Entity", PropertySelector = l => l.EntityName, SortColumn = "EntityName" },
            new() { Header = "Action", Sortable = true, SortColumn = "Action", Template = l =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@l.Action</span> },
            new() { Header = "Entity ID", Sortable = false, Template = l =>
                @<span class="text-caption">@(l.EntityId?.ToString() ?? "—")</span> },
            new() { Header = "User", Sortable = false, Template = l =>
                @<span class="text-caption">@(l.UserId?.ToString() ?? "System")</span> },
            new() { Header = "Changes", Sortable = false, Template = l =>
                @<span class="text-caption text-secondary">@Truncate(l.NewValues ?? l.OldValues)</span> }
        };
        return LoadAsync(_query);
    }

    private static string Truncate(string? v) =>
        string.IsNullOrWhiteSpace(v) ? "—" : v!.Length > 80 ? v[..80] + "…" : v!;

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await AuditTrailApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading the audit trail.";
    }
}
