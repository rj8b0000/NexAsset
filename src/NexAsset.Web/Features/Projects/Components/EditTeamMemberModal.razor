<Dialog IsOpen="IsOpen" Title="Edit Team Member" OnClose="OnClose"><ChildContent><TextField Label="Project Role" Required="true" Value="Role" ValueChanged="@(x => Role = x)" /><TextField Label="Allocation %" Type="number" Value="Allocation" ValueChanged="@(x => Allocation = x)" /></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Save</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? Role { get; set; } [Parameter] public string? Allocation { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } }
