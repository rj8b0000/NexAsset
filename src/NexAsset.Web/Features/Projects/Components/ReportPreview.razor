<div class="border rounded-2 p-3" style="border-color: var(--border-color) !important;"><div class="d-flex justify-content-between align-items-center mb-3"><span class="text-label text-muted-custom">Reports</span><ReportSelector OnSelected="Select" /></div><div class="text-caption text-secondary">@_message</div></div>
@code { [Parameter] public Guid ProjectId { get; set; } private string _message = "Select a report to review its project data."; private Task Select(string report) { _message = $"{report} report preview is ready for export."; return Task.CompletedTask; } }
