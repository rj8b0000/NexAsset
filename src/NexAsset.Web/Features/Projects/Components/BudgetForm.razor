@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Models.Projects
@inject IProjectApiClient ProjectApiClient
@if (_loading) { <LoadingState Message="Loading budget..." /> } else if (_budget is null) { <EmptyState Title="No budget recorded" Description="Record the first budget snapshot for this project." IconClass="lucide-wallet-cards" /> } else { <div class="border rounded-2 p-3" style="border-color: var(--border-color) !important;"><div class="row g-3"><div class="col-md-4"><div class="text-label text-muted-custom">Estimated</div><div class="fs-4">@_budget.EstimatedBudget.ToString("N2")</div></div><div class="col-md-4"><div class="text-label text-muted-custom">Approved</div><div class="fs-4">@_budget.ApprovedBudget.ToString("N2")</div></div><div class="col-md-4"><div class="text-label text-muted-custom">Actual</div><div class="fs-4">@_budget.ActualCost.ToString("N2")</div></div></div><BudgetHistoryTable ProjectId="ProjectId" /></div> }
@code { [Parameter] public Guid ProjectId { get; set; } private BudgetSnapshot? _budget; private bool _loading = true; protected override async Task OnParametersSetAsync() { _loading = true; var result = await ProjectApiClient.GetBudgetAsync(ProjectId); if (result.IsSuccess) _budget = result.Data; _loading = false; } }
