<Dialog IsOpen="IsOpen" Title="Add Parameter Section" OnClose="OnClose"><ChildContent><TextField Label="Section Name" Required="true" Value="Name" ValueChanged="@(x => Name = x)" /><TextField Label="Display Order" Type="number" Value="DisplayOrder" ValueChanged="@(x => DisplayOrder = x)" /></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Save</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? Name { get; set; } [Parameter] public string? DisplayOrder { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } }
