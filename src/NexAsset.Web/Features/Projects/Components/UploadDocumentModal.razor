<Dialog IsOpen="IsOpen" Title="Upload Document" Size="lg" OnClose="OnClose"><ChildContent><div class="row g-3"><TextField Label="Document Name" Required="true" Value="DocumentName" ValueChanged="@(x => DocumentName = x)" /><TextField Label="Category" Required="true" Value="Category" ValueChanged="@(x => Category = x)" /><TextField Label="Description" ColumnClass="col-12" Multiline="true" Value="Description" ValueChanged="@(x => Description = x)" /><input class="form-control-custom col-12" type="file" @onchange="OnFileSelected" /></div></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Upload</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? DocumentName { get; set; } [Parameter] public string? Category { get; set; } [Parameter] public string? Description { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } private Task OnFileSelected(ChangeEventArgs args) => Task.CompletedTask; }
