@using NexAsset.Web.Models.Projects
<Dialog IsOpen="IsOpen" Title="Version History" OnClose="OnClose"><ChildContent>@if (Documents.Count == 0) { <div class="text-caption text-secondary">No versions available.</div> } else { @foreach (var document in Documents.OrderByDescending(x => x.Version)) { <div class="d-flex justify-content-between py-2 border-bottom"><span>Version @document.Version</span><span class="text-caption text-secondary">@document.UploadedAtUtc.ToLocalTime().ToString("dd MMM yyyy")</span></div> } }</ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Close</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public IReadOnlyCollection<ProjectDocument> Documents { get; set; } = []; [Parameter] public EventCallback OnClose { get; set; } }
