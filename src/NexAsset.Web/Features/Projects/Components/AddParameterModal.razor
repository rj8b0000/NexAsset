<Dialog IsOpen="IsOpen" Title="Add Parameter" OnClose="OnClose"><ChildContent><TextField Label="Parameter Name" Required="true" Value="Name" ValueChanged="@(x => Name = x)" /><SelectField Label="Input Type" Options="_types" Value="InputType" ValueChanged="@(x => InputType = x)" /></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Save</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? Name { get; set; } [Parameter] public string? InputType { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } private readonly List<SelectField.Option> _types = new() { new("1", "Text"), new("2", "Textarea"), new("3", "Number"), new("4", "Decimal"), new("5", "Date"), new("6", "Dropdown"), new("7", "Checkbox") }; }
