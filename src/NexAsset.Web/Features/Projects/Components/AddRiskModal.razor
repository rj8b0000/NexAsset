<Dialog IsOpen="IsOpen" Title="Add Risk" Size="lg" OnClose="OnClose"><ChildContent><div class="row g-3"><TextField Label="Title" Required="true" Value="Title" ValueChanged="@(x => Title = x)" /><TextField Label="Category" Required="true" Value="Category" ValueChanged="@(x => Category = x)" /><TextField Label="Description" Multiline="true" ColumnClass="col-12" Value="Description" ValueChanged="@(x => Description = x)" /></div></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Add Risk</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? Title { get; set; } [Parameter] public string? Category { get; set; } [Parameter] public string? Description { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } }
