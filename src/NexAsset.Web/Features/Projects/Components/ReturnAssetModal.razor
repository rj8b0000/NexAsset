<Dialog IsOpen="IsOpen" Title="Return Asset" OnClose="OnClose"><ChildContent><TextField Label="Returned Quantity" Type="number" Required="true" Value="ReturnedQuantity" ValueChanged="@(x => ReturnedQuantity = x)" /><div class="form-check mt-3"><input class="form-check-input" type="checkbox" id="usable" @bind="IsUsable" /><label class="form-check-label" for="usable">Asset is usable</label></div></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Return</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? ReturnedQuantity { get; set; } [Parameter] public bool IsUsable { get; set; } = true; [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } }
