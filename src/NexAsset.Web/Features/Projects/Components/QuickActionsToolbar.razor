@inject NavigationManager Navigation
<div class="d-flex gap-2 flex-wrap mb-3"><button class="btn-custom btn-custom-secondary" title="Edit project" @onclick="Edit"><i class="lucide-pencil"></i></button><button class="btn-custom btn-custom-secondary" title="Manage team" @onclick="ManageTeam"><i class="lucide-users"></i></button><button class="btn-custom btn-custom-secondary" title="Allocate asset" @onclick="ManageAssets"><i class="lucide-box"></i></button><button class="btn-custom btn-custom-secondary" title="Upload document" @onclick="ManageDocuments"><i class="lucide-upload"></i></button><button class="btn-custom btn-custom-secondary" title="Add risk" @onclick="ManageRisks"><i class="lucide-shield-alert"></i></button></div>
@code { [Parameter] public Guid ProjectId { get; set; } private void Edit() => Navigation.NavigateTo($"/projects/{ProjectId}"); private void ManageTeam() => Go("team"); private void ManageAssets() => Go("assets"); private void ManageDocuments() => Go("documents"); private void ManageRisks() => Go("risks"); private void Go(string tab) => Navigation.NavigateTo($"/projects/{ProjectId}?tab={tab}"); }
