@using NexAsset.Web.Models.Projects
<div class="row align-items-center py-2 border-bottom"><div class="col-md-4"><label class="text-caption fw-semibold">@Parameter.ParameterName @if (Parameter.IsRequired) { <span style="color: var(--danger);">*</span> }</label>@if (!string.IsNullOrWhiteSpace(Parameter.Unit)) { <span class="text-muted-custom small ms-1">@Parameter.Unit</span> }</div><div class="col-md-8">@if (Parameter.InputType == 2) { <textarea class="form-control-custom" @bind="Value"></textarea> } else if (Parameter.InputType == 7) { <input type="checkbox" @bind="_checked" /> } else if (Parameter.InputType == 6) { <select class="form-control-custom" @bind="Value"><option value="">Select</option>@foreach (var option in Options) { <option value="@option">@option</option> }</select> } else { <input class="form-control-custom" type="@InputType" @bind="Value" /> }</div></div>
@code { [Parameter, EditorRequired] public ProjectParameter Parameter { get; set; } = default!; [Parameter] public string? Value { get; set; } [Parameter] public EventCallback<string?> ValueChanged { get; set; } private bool _checked; private string InputType => Parameter.InputType switch { 3 or 4 => "number", 5 => "date", 8 => "email", 9 => "tel", 10 => "url", _ => "text" }; private IReadOnlyCollection<string> Options => string.IsNullOrWhiteSpace(Parameter.DropdownOptionsJson) ? [] : System.Text.Json.JsonSerializer.Deserialize<string[]>(Parameter.DropdownOptionsJson) ?? []; }
