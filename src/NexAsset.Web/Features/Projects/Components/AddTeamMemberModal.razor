<Dialog IsOpen="IsOpen" Title="Add Team Member" OnClose="OnClose"><ChildContent><div class="row g-3"><TextField Label="Employee ID" Required="true" Value="_employeeId" ValueChanged="@(x => _employeeId = x)" /><TextField Label="Project Role" Required="true" Value="_role" ValueChanged="@(x => _role = x)" /><TextField Label="Allocation %" Type="number" Required="true" Value="_allocation" ValueChanged="@(x => _allocation = x)" /></div></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="Submit">Add</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSubmit { get; set; } private string _employeeId = string.Empty; private string _role = string.Empty; private string _allocation = "100"; private Task Submit() => OnSubmit.InvokeAsync(); }
