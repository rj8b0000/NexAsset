@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Projects
@using NexAsset.Web.Shared.Components
@using NexAsset.Web.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@inject IProjectDocumentApiClient DocumentApiClient
@inject INotificationService Notifications

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
            <h3 class="h3-title">Project Documents</h3>
            <span class="text-caption text-secondary">Upload drawings, agreements, permits, and inspection reports.</span>
        </div>
        <button class="btn-custom btn-custom-secondary" @onclick="() => _uploadDialogOpen = true">
            <i class="lucide-upload me-1"></i> Upload Document
        </button>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading project documents..." />
    }
    else if (_docs.Count == 0)
    {
        <EmptyState Title="No documents uploaded" Description="Upload agreements, technical drawings, surveys, or invoices for this project."
                    IconClass="lucide-file-text" ActionLabel="Upload First Document" ActionIconClass="lucide-upload"
                    OnActionClick="() => _uploadDialogOpen = true" />
    }
    else
    {
        <DataTable TItem="ProjectDocumentItem"
                   Items="_docs"
                   Columns="_columns"
                   Type="Project Document"
                   IdSelector="d => d.Id.ToString()"
                   OnDelete="AskDelete" />
    }
</div>

<!-- Upload Dialog -->
<Dialog IsOpen="_uploadDialogOpen" Title="Upload Project Document" OnClose="ResetAndCloseUploadDialog">
    <ChildContent>
        <div class="row g-3">
            <!-- File Upload Dropzone -->
            <div class="col-12">
                <label class="form-label-custom mb-2">Select File to Upload <span class="text-danger">*</span></label>
                <InputFile OnChange="HandleFileSelected" class="d-none" id="docFileInput" />
                <label for="docFileInput" class="w-100 p-4 text-center cursor-pointer rounded-3"
                       style="border: 2px dashed var(--border-color); background-color: var(--bg-surface-hover); cursor: pointer; display: block; transition: all 0.2s;">
                    <div class="mb-2">
                        <i class="lucide-upload-cloud" style="font-size: 32px; color: var(--primary);"></i>
                    </div>
                    @if (string.IsNullOrEmpty(_selectedFileName))
                    {
                        <div class="fw-bold text-body-custom mb-1">Click to browse or drop file here</div>
                        <div class="text-caption text-secondary">Supports PDF, DWG, DOCX, XLSX, PNG, JPG (Max 50MB)</div>
                    }
                    else
                    {
                        <div class="text-success fw-bold mb-1"><i class="lucide-check-circle me-1"></i> File Selected</div>
                        <div class="badge bg-success-custom text-success py-1 px-3" style="font-size: 13px;">
                            <i class="lucide-file-text me-1"></i> @_selectedFileName (@_selectedFileSize)
                        </div>
                        <div class="text-caption text-secondary mt-1">Click to change selected file</div>
                    }
                </label>
            </div>

            <TextField Label="Document Name" Value="@_docName" ValueChanged="v => _docName = v" Required="true" Placeholder="e.g. Site Survey Report.pdf" ColumnClass="col-12" />
            
            <SelectField Label="Category" Required="true" Options="_categoryOptions" Placeholder="Select Category"
                         Value="@_category.ToString()" ValueChanged="OnCategoryChanged" ColumnClass="col-12" />

            <TextField Label="Description" Value="@_description" ValueChanged="v => _description = v" Multiline="true" Rows="3" Placeholder="Optional notes or revision details..." ColumnClass="col-12" />
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="ResetAndCloseUploadDialog">Cancel</button>
        <button class="btn-custom btn-custom-primary ms-2" @onclick="ConfirmUploadAsync">Confirm Upload</button>
    </FooterContent>
</Dialog>

<ConfirmDeleteDialog IsOpen="_deleteOpen" EntityLabel="project document" OnClose="() => _deleteOpen = false" OnConfirm="ConfirmDeleteAsync" />

@code {
    [Parameter] public Guid ProjectId { get; set; }

    private List<ProjectDocumentItem> _docs = new();
    private bool _loading = true;

    private bool _uploadDialogOpen;
    private string _docName = string.Empty;
    private DocumentCategory _category = DocumentCategory.TechnicalDrawing;
    private string? _description;
    private string? _selectedFileName;
    private string? _selectedFileSize;

    private bool _deleteOpen;
    private Guid? _deleteId;

    private readonly List<SelectField.Option> _categoryOptions = Enum.GetValues(typeof(DocumentCategory))
        .Cast<DocumentCategory>()
        .Select(c => new SelectField.Option(c.ToString(), c.ToString()))
        .ToList();

    private readonly List<ColumnDefinition<ProjectDocumentItem>> _columns = new()
    {
        new() { Header = "Document Name", PropertySelector = x => x.DocumentName, Sortable = true },
        new() { Header = "Category", PropertySelector = x => x.Category.ToString() },
        new() { Header = "Version", PropertySelector = x => $"v{x.Version}" },
        new() { Header = "Uploaded At", PropertySelector = x => x.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm") }
    };

    protected override async Task OnParametersSetAsync()
    {
        if (ProjectId != Guid.Empty)
        {
            await LoadAsync();
        }
        else
        {
            if (_docs.Count == 0)
            {
                _docs = new List<ProjectDocumentItem>
                {
                    new ProjectDocumentItem
                    {
                        Id = Guid.NewGuid(),
                        DocumentName = "Initial Site Survey & Topo Map.pdf",
                        Category = DocumentCategory.TechnicalDrawing,
                        Version = 1,
                        UploadedAtUtc = DateTime.UtcNow.AddDays(-2)
                    },
                    new ProjectDocumentItem
                    {
                        Id = Guid.NewGuid(),
                        DocumentName = "State Nodal Agency Grid Connectivity Permit.pdf",
                        Category = DocumentCategory.GovernmentApproval,
                        Version = 1,
                        UploadedAtUtc = DateTime.UtcNow.AddDays(-1)
                    }
                };
            }
            _loading = false;
        }
    }

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            _selectedFileName = file.Name;
            _selectedFileSize = $"{file.Size / 1024.0 / 1024.0:F2} MB";
            if (string.IsNullOrWhiteSpace(_docName))
            {
                _docName = file.Name;
            }
        }
    }

    private void OnCategoryChanged(string val)
    {
        if (Enum.TryParse<DocumentCategory>(val, out var cat))
        {
            _category = cat;
        }
    }

    private void ResetAndCloseUploadDialog()
    {
        _uploadDialogOpen = false;
        _docName = string.Empty;
        _description = string.Empty;
        _selectedFileName = null;
        _selectedFileSize = null;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var res = await DocumentApiClient.GetPagedAsync(ProjectId, null, new PagedQuery { PageSize = 50 });
        _loading = false;

        if (res.IsSuccess && res.Data != null)
        {
            _docs = res.Data.Items.ToList();
        }
    }

    private async Task ConfirmUploadAsync()
    {
        if (string.IsNullOrWhiteSpace(_docName))
        {
            Notifications.ShowError("Validation Error", "Please select a file or enter a document name.");
            return;
        }

        if (ProjectId == Guid.Empty)
        {
            _docs.Add(new ProjectDocumentItem
            {
                Id = Guid.NewGuid(),
                DocumentName = _docName,
                Category = _category,
                Version = 1,
                UploadedAtUtc = DateTime.UtcNow
            });
            Notifications.ShowSuccess("Success", $"Document '{_docName}' uploaded to project draft.");
            ResetAndCloseUploadDialog();
            return;
        }

        Notifications.ShowSuccess("Success", $"Document '{_docName}' uploaded successfully.");
        ResetAndCloseUploadDialog();
        await LoadAsync();
    }

    private void AskDelete(ProjectDocumentItem doc)
    {
        _deleteId = doc.Id;
        _deleteOpen = true;
    }

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteId.HasValue)
        {
            if (ProjectId == Guid.Empty)
            {
                _docs.RemoveAll(x => x.Id == _deleteId.Value);
                Notifications.ShowSuccess("Success", "Document removed.");
                _deleteOpen = false;
                return;
            }

            var res = await DocumentApiClient.DeleteAsync(ProjectId, _deleteId.Value);
            if (res.IsSuccess)
            {
                Notifications.ShowSuccess("Success", "Document deleted.");
                await LoadAsync();
            }
        }
        _deleteOpen = false;
    }
}
