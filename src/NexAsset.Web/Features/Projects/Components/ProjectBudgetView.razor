@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Models.Projects
@using NexAsset.Web.Infrastructure.Notifications
@inject IProjectWorkspaceApiClient ProjectApi
@inject INotificationService Notifications

<div class="dashboard-card-custom p-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="h5 mb-1">Financial Overview</h2>
            <div class="text-caption text-secondary">Manage and track project budget and actual expenditures.</div>
        </div>
        <button class="btn-custom btn-custom-primary" @onclick="SaveBudgetAsync" disabled="@_busy">
            <i class="lucide-save"></i> Save Budget
        </button>
    </div>

    @if (_loading)
    {
        <LoadingState Message="Loading financial data..." />
    }
    else
    {
        <div class="row g-4">
            <div class="col-md-6">
                <div class="p-3 bg-light rounded-3 border">
                    <h3 class="h6 mb-3 text-uppercase text-secondary fw-semibold">Estimates & Allocation</h3>
                    <div class="mb-3">
                        <label class="form-label-custom">Estimated Budget</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" class="form-control-custom form-control-lg fw-bold" @bind="_form.EstimatedBudget" />
                        </div>
                    </div>
                    
                    <div class="mt-4 p-3 rounded-3 @(_budgetVariance < 0 ? "bg-danger-subtle text-danger" : "bg-success-subtle text-success")">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-semibold">Budget Variance</span>
                            <i class="lucide-@(_budgetVariance < 0 ? "trending-down" : "trending-up")"></i>
                        </div>
                        <h4 class="h3 mb-0 fw-bold">@Math.Abs(_budgetVariance).ToString("C")</h4>
                        <div class="text-caption mt-1">@(_budgetVariance < 0 ? "Over budget" : "Under budget")</div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6">
                <div class="p-3 border rounded-3 h-100">
                    <h3 class="h6 mb-3 text-uppercase text-secondary fw-semibold">Actual Costs</h3>
                    
                    <div class="mb-2 row align-items-center">
                        <label class="col-sm-5 col-form-label form-label-custom mb-0">Procurement</label>
                        <div class="col-sm-7">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control-custom" @bind="_form.ProcurementCost" @bind:event="oninput" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-2 row align-items-center">
                        <label class="col-sm-5 col-form-label form-label-custom mb-0">Maintenance</label>
                        <div class="col-sm-7">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control-custom" @bind="_form.MaintenanceCost" @bind:event="oninput" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-2 row align-items-center">
                        <label class="col-sm-5 col-form-label form-label-custom mb-0">Labour</label>
                        <div class="col-sm-7">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control-custom" @bind="_form.LabourCost" @bind:event="oninput" />
                            </div>
                        </div>
                    </div>
                    
                    <div class="mb-3 row align-items-center">
                        <label class="col-sm-5 col-form-label form-label-custom mb-0">Miscellaneous</label>
                        <div class="col-sm-7">
                            <div class="input-group input-group-sm">
                                <span class="input-group-text">$</span>
                                <input type="number" class="form-control-custom" @bind="_form.MiscellaneousCost" @bind:event="oninput" />
                            </div>
                        </div>
                    </div>
                    
                    <hr />
                    
                    <div class="row align-items-center">
                        <div class="col-sm-5 fw-bold text-end">Total Actual Cost:</div>
                        <div class="col-sm-7">
                            <h4 class="h5 mb-0 fw-bold">@_totalActualCost.ToString("C")</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid ProjectId { get; set; }
    
    private ProjectBudgetFormModel _form = new();
    private bool _loading = true;
    private bool _busy;
    
    private decimal _totalActualCost => _form.ProcurementCost + _form.MaintenanceCost + _form.LabourCost + _form.MiscellaneousCost;
    private decimal _budgetVariance => _form.EstimatedBudget - _totalActualCost;
    
    protected override async Task OnInitializedAsync()
    {
        await LoadBudgetAsync();
    }
    
    private async Task LoadBudgetAsync()
    {
        _loading = true;
        var result = await ProjectApi.GetBudgetAsync(ProjectId);
        if (result.IsSuccess && result.Data is not null)
        {
            _form = new ProjectBudgetFormModel
            {
                ProjectId = result.Data.ProjectId,
                EstimatedBudget = result.Data.EstimatedBudget,
                ActualCost = result.Data.ActualCost, // will be overwritten below if auto-calc was desired, but let's map it
                ProcurementCost = result.Data.ProcurementCost,
                MaintenanceCost = result.Data.MaintenanceCost,
                LabourCost = result.Data.LabourCost,
                MiscellaneousCost = result.Data.MiscellaneousCost
            };
        }
        else
        {
            _form = new ProjectBudgetFormModel { ProjectId = ProjectId };
        }
        _loading = false;
    }
    
    private async Task SaveBudgetAsync()
    {
        _busy = true;
        _form.ActualCost = _totalActualCost; // Auto calc the total
        var result = await ProjectApi.UpsertBudgetAsync(ProjectId, _form);
        _busy = false;
        
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Saved", "Project budget was updated.");
        }
        else
        {
            Notifications.ShowError("Error", result.Error?.Message ?? "Could not save budget.");
        }
    }
}
