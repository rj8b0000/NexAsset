<Dialog IsOpen="IsOpen" Title="Allocate Asset" OnClose="OnClose"><ChildContent><div class="row g-3"><TextField Label="Asset ID" Required="true" Value="AssetId" ValueChanged="@(x => AssetId = x)" /><TextField Label="Quantity" Required="true" Type="number" Value="Quantity" ValueChanged="@(x => Quantity = x)" /></div></ChildContent><FooterContent><button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button><button class="btn-custom btn-custom-primary" @onclick="OnSave">Allocate</button></FooterContent></Dialog>
@code { [Parameter] public bool IsOpen { get; set; } [Parameter] public string? AssetId { get; set; } [Parameter] public string? Quantity { get; set; } [Parameter] public EventCallback OnClose { get; set; } [Parameter] public EventCallback OnSave { get; set; } }
