<div>@if (Groups.Count == 0) { <div class="text-caption text-secondary">No search results.</div> } else { @foreach (var group in Groups) { <div class="mb-3"><div class="text-label text-muted-custom mb-2">@group.EntityType (@group.Items.Count)</div>@foreach (var item in group.Items) { <a class="d-block border rounded-2 p-2 mb-1 text-decoration-none" style="border-color: var(--border-color) !important;" href="@item.NavigationUrl"><div class="text-caption fw-semibold">@item.DisplayText</div><div class="small text-muted-custom">@item.Highlight</div></a> }</div> } }</div>
@code { [Parameter] public IReadOnlyCollection<SearchGroup> Groups { get; set; } = []; public sealed record SearchGroup(string EntityType, IReadOnlyCollection<SearchItem> Items); public sealed record SearchItem(Guid Id, string DisplayText, string Highlight, string NavigationUrl); }
