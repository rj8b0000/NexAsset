@using NexAsset.Web.Models.Projects
<div class="border rounded-2 p-3 h-100" style="border-color: var(--border-color) !important;"><div class="text-label text-muted-custom mb-2">Overview</div><div class="d-flex justify-content-between"><span class="badge-custom badge-custom-info">@Status(Project.Status)</span><span class="text-caption">@Priority(Project.Priority)</span></div><div class="mt-3 text-caption"><div>Start: @Project.StartDate?.ToString("dd MMM yyyy")</div><div>Expected: @Project.ExpectedCompletionDate?.ToString("dd MMM yyyy")</div></div></div>
@code { [Parameter, EditorRequired] public ProjectDetail Project { get; set; } = default!; private static string Status(int value) => Enum.GetName(typeof(StatusView), value) ?? "Unknown"; private static string Priority(int value) => Enum.GetName(typeof(PriorityView), value) ?? "Normal"; private enum StatusView { Draft = 1, Planning, AwaitingApproval, Approved, InProgress, OnHold, Completed, Archived, Cancelled } private enum PriorityView { Low = 1, Medium, High, Critical } }
