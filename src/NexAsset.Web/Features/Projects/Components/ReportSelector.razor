<div class="d-flex align-items-center gap-2 flex-wrap"><select class="form-control-custom" style="max-width: 260px;" @bind="Selected"><option>Summary</option><option>Team</option><option>Assets</option><option>Budget</option><option>Risks</option><option>Documents</option><option>Activities</option><option>Timeline</option><option>Parameters</option></select><button class="btn-custom btn-custom-secondary" @onclick="Preview"><i class="lucide-eye"></i></button></div>
@code { [Parameter] public string Selected { get; set; } = "Summary"; [Parameter] public EventCallback<string> OnSelected { get; set; } private Task Preview() => OnSelected.InvokeAsync(Selected); }
