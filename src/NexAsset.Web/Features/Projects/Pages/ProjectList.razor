@page "/projects"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Projects
@using NexAsset.Web.Shared.Components
@using NexAsset.Web.Shared.Models
@inject IProjectApiClient ProjectApiClient
@inject INotificationService Notifications
@inject NavigationManager Navigation
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Project Workspace</h1>
            <span class="text-caption text-secondary">Manage projects, parameters, and documentation.</span>
        </div>
        @if (Perms.HasPermission("Projects.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick='() => Navigation.NavigateTo("/projects/wizard")'>
                <i class="lucide-plus"></i> Create Project
            </button>
        }
    </div>

    @if (_draftSession != null)
    {
        <div class="card-custom p-3 mb-4 d-flex align-items-center justify-content-between flex-wrap gap-3" style="background-color: var(--primary-light); border: 1px solid var(--primary-border);">
            <div class="d-flex align-items-center gap-3">
                <div class="p-2 bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="lucide-edit-3 fs-5"></i>
                </div>
                <div>
                    <h4 class="h4-title text-primary mb-1">Unsaved Draft Project Session Found</h4>
                    <span class="text-caption text-secondary">
                        Saved section step @_draftSession.CurrentStep (@_draftSession.LastSavedAtUtc.ToLocalTime().ToString("MMM dd, yyyy HH:mm:ss"))
                    </span>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn-custom btn-custom-secondary" @onclick="DiscardDraftAsync">
                    <i class="lucide-trash-2 text-danger me-1"></i> Discard Draft
                </button>
                <button class="btn-custom btn-custom-primary" @onclick='() => Navigation.NavigateTo("/projects/wizard?resume=true")'>
                    <i class="lucide-play me-1"></i> Resume Draft Project
                </button>
            </div>
        </div>
    }

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading projects..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load projects" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="ProjectListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Project"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="p => p.Id.ToString()"
                   OnViewDetails="ViewProject"
                   OnDelete="AskDelete"
                   DeletePermission="Projects.Delete" />
    }
</div>

<ConfirmDeleteDialog IsOpen="_deleteOpen" EntityLabel="project" OnClose="() => _deleteOpen = false" OnConfirm="ConfirmDelete" />

@code {
    private PagedResult<ProjectListItem>? _page;
    private string? _loadError;
    private bool _busy;
    private PagedQuery _query = new() { PageNumber = 1, PageSize = 10 };
    private DraftSessionModel? _draftSession;

    private bool _deleteOpen;
    private Guid? _deleteId;

    private readonly List<ColumnDefinition<ProjectListItem>> _columns = new()
    {
        new() { Header = "Code", PropertySelector = x => x.ProjectCode, Sortable = true },
        new() { Header = "Project Name", PropertySelector = x => x.ProjectName, Sortable = true },
        new() { Header = "Category", PropertySelector = x => x.CategoryName },
        new() { Header = "Priority", PropertySelector = x => x.Priority.ToString() },
        new() { Header = "Status", PropertySelector = x => x.Status.ToString() },
        new() { Header = "Manager", PropertySelector = x => x.ProjectManagerName ?? "-" }
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync(_query);
        await CheckDraftSessionAsync();
    }

    private async Task CheckDraftSessionAsync()
    {
        try
        {
            var res = await ProjectApiClient.GetDraftSessionAsync(Guid.Empty, Guid.Empty);
            if (res.IsSuccess && res.Data != null)
            {
                _draftSession = res.Data;
            }
        }
        catch
        {
            // Ignored
        }
    }

    private async Task DiscardDraftAsync()
    {
        try
        {
            var res = await ProjectApiClient.DeleteDraftSessionAsync(Guid.Empty, Guid.Empty);
            if (res.IsSuccess)
            {
                _draftSession = null;
                Notifications.ShowSuccess("Success", "Draft session discarded.");
            }
        }
        catch
        {
            Notifications.ShowError("Error", "Failed to discard draft session.");
        }
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _busy = true;
        _query = query;
        var res = await ProjectApiClient.GetPagedAsync(query);
        _busy = false;

        if (res.IsSuccess)
        {
            _page = res.Data;
            _loadError = null;
        }
        else
        {
            _loadError = res.Error?.Message;
        }
    }

    private void ViewProject(ProjectListItem item)
    {
        Navigation.NavigateTo($"/projects/{item.Id}");
    }

    private void AskDelete(ProjectListItem item)
    {
        _deleteId = item.Id;
        _deleteOpen = true;
    }

    private async Task ConfirmDelete()
    {
        if (_deleteId.HasValue)
        {
            var res = await ProjectApiClient.DeleteAsync(_deleteId.Value);
            if (res.IsSuccess)
            {
                Notifications.ShowSuccess("Success", "Project deleted.");
                await LoadAsync(_query);
            }
            else
            {
                Notifications.ShowError("Error", res.Error?.Message ?? "Failed to delete project.");
            }
        }
        _deleteOpen = false;
    }
}
