@page "/projects/new"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Projects
@using NexAsset.Web.State
@inject IProjectApiClient ProjectApiClient
@inject IProjectCategoryApiClient CategoryApiClient
@inject NavigationState NavigationState
@inject NavigationManager Navigation
@inject INotificationService Notifications

<div class="animate-fade-in" style="max-width: 980px;">
    <div class="d-flex align-items-center justify-content-between mb-4"><div><h1 class="h1-title mb-1">New Project</h1><span class="text-caption text-secondary">Step @_step of 7</span></div><span class="text-caption text-muted-custom">@_saveState</span></div>
    <div class="d-flex gap-1 mb-4 overflow-auto">@for (var index = 1; index <= 7; index++) { var current = index; <button class="btn-custom @(current == _step ? "btn-custom-primary" : "btn-custom-secondary")" @onclick="() => _step = current">@current</button> }</div>
    <div class="border rounded-2 p-4" style="border-color: var(--border-color) !important;">
        @if (_step == 1)
        {
            <div class="row g-3">
                <div class="col-md-6"><label class="form-label-custom">Project code</label><input class="form-control-custom" @bind="_model.ProjectCode" @bind:event="oninput" /></div>
                <div class="col-md-6"><label class="form-label-custom">Project name</label><input class="form-control-custom" @bind="_model.ProjectName" @bind:event="oninput" /></div>
                <div class="col-md-6"><label class="form-label-custom">Category</label><select class="form-control-custom" @bind="_model.CategoryId"><option value="@Guid.Empty">Select category</option>@foreach (var category in _categories) { <option value="@category.Id">@category.Name</option> }</select></div>
                <div class="col-md-6"><label class="form-label-custom">Priority</label><select class="form-control-custom" @bind="_model.Priority"><option value="1">Low</option><option value="2">Medium</option><option value="3">High</option><option value="4">Critical</option></select></div>
                <div class="col-md-6"><label class="form-label-custom">Start date</label><input type="date" class="form-control-custom" @bind="_model.StartDate" /></div>
                <div class="col-md-6"><label class="form-label-custom">Expected completion</label><input type="date" class="form-control-custom" @bind="_model.ExpectedCompletionDate" /></div>
                <div class="col-12"><label class="form-label-custom">Description</label><textarea class="form-control-custom" rows="4" @bind="_model.Description"></textarea></div>
            </div>
        }
        else if (_step == 6)
        {
            <dl class="row mb-0"><dt class="col-sm-3">Code</dt><dd class="col-sm-9">@_model.ProjectCode</dd><dt class="col-sm-3">Name</dt><dd class="col-sm-9">@_model.ProjectName</dd><dt class="col-sm-3">Organization</dt><dd class="col-sm-9">@_model.OrganizationId</dd></dl>
        }
        else if (_step == 7)
        {
            <div class="text-center py-4"><i class="lucide-circle-check-big fs-1" style="color: var(--success);"></i><h2 class="h2-title mt-3">Ready to create</h2><p class="text-caption text-secondary mb-0">The workspace will be created with a draft status.</p></div>
        }
        else
        {
            <div class="py-4 text-center text-secondary"><i class="lucide-layers-2 fs-2"></i><p class="mb-0 mt-2">This step is available after the project workspace is created. You can add these records immediately from the project detail page.</p></div>
        }
    </div>
    @if (_error is not null) { <div class="alert alert-danger mt-3">@_error</div> }
    <div class="d-flex justify-content-between mt-4"><button class="btn-custom btn-custom-secondary" disabled="@(_step == 1)" @onclick="Back">Back</button>@if (_step < 7) { <button class="btn-custom btn-custom-primary" @onclick="Next">Next</button> } else { <button class="btn-custom btn-custom-primary" disabled="@_saving" @onclick="CreateAsync"><i class="lucide-save"></i> Create Project</button> }</div>
</div>

@code {
    private readonly ProjectInput _model = new();
    private List<ProjectCategoryItem> _categories = new();
    private int _step = 1;
    private bool _saving;
    private string? _error;
    private string _saveState = "Unsaved changes";

    protected override async Task OnInitializedAsync()
    {
        _model.OrganizationId = NavigationState.ActiveOrganizationId ?? Guid.Empty;
        var result = await CategoryApiClient.GetPagedAsync(new NexAsset.Web.Shared.Models.PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null) _categories = result.Data.Items.Where(x => _model.OrganizationId == Guid.Empty || x.OrganizationId == _model.OrganizationId).ToList();
    }

    private void Back() => _step = Math.Max(1, _step - 1);
    private void Next() { if (_step == 1 && !ValidateGeneral()) return; _step = Math.Min(7, _step + 1); _ = SaveDraftAsync(); }
    private bool ValidateGeneral()
    {
        _error = _model.OrganizationId == Guid.Empty ? "Choose an organization before creating a project." : _model.CategoryId == Guid.Empty ? "Choose a project category." : string.IsNullOrWhiteSpace(_model.ProjectCode) ? "Project code is required." : string.IsNullOrWhiteSpace(_model.ProjectName) ? "Project name is required." : null;
        return _error is null;
    }
    private async Task SaveDraftAsync()
    {
        if (_model.OrganizationId == Guid.Empty) return;
        _saveState = "Saving...";
        await Task.Delay(TimeSpan.FromSeconds(5));
        var state = System.Text.Json.JsonSerializer.Serialize(_model);
        var result = await ProjectApiClient.SaveDraftAsync(new DraftInput { OrganizationId = _model.OrganizationId, WizardStateJson = state, CurrentStep = _step });
        _saveState = result.IsSuccess ? $"Saved at {DateTime.Now:HH:mm:ss}" : "Unsaved changes";
        await InvokeAsync(StateHasChanged);
    }
    private async Task CreateAsync()
    {
        if (!ValidateGeneral()) { _step = 1; return; }
        _saving = true;
        var result = await ProjectApiClient.CreateAsync(_model);
        _saving = false;
        if (result.IsSuccess && result.Data is not null) { Notifications.ShowSuccess("Project created", "The workspace is ready."); Navigation.NavigateTo($"/projects/{result.Data.Id}"); }
        else _error = result.Error?.Message ?? "Project could not be created.";
    }
}
