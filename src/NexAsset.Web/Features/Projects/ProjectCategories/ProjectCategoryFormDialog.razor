@using NexAsset.Web.Infrastructure.Projects
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Projects
@using NexAsset.Web.Shared.Components
@inject IProjectCategoryApiClient CategoryApiClient
@inject INotificationService Notifications

<Dialog IsOpen="IsOpen" Title="@(EditId.HasValue ? "Edit Project Category" : "New Project Category")" OnClose="OnClose">
    <ChildContent>
        <div class="mb-3">
            <TextField Label="Category Name" @bind-Value="_model.Name" Required="true" Placeholder="e.g. Solar EPC, Electrical Testing" />

            <!-- Suggested Categories Quick Selection -->
            <div class="mt-3">
                <label class="form-label-custom text-caption text-secondary">Suggested Industry Categories</label>
                <div class="d-flex flex-wrap gap-1 mt-1 p-2 bg-light-custom rounded-3" style="max-height: 120px; overflow-y: auto; border: 1px solid var(--border-color);">
                    @foreach (var sug in SuggestedCategories)
                    {
                        <button type="button" class="btn btn-sm btn-outline-secondary py-0 px-2 rounded-pill text-caption @(_model.Name == sug ? "active btn-primary text-white" : "")"
                                style="font-size: 11px;" @onclick="() => SelectSuggestedCategory(sug)">
                            + @sug
                        </button>
                    }
                </div>
            </div>

            <div class="mt-3">
                <TextField Label="Description" @bind-Value="_model.Description" Multiline="true" Rows="2" Placeholder="Optional category description" />
            </div>

            <div class="d-flex align-items-center justify-content-between mt-3">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="categoryActive" @bind="_model.IsActive" />
                    <label class="form-check-label text-body-custom" for="categoryActive">Active Status</label>
                </div>
                <div>
                    <span class="badge @(IsCurrentCategorySuggested ? "bg-info-custom text-info" : "bg-secondary-custom text-secondary")">
                        @(IsCurrentCategorySuggested ? "Suggested Category" : "Custom Category")
                    </span>
                </div>
            </div>
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose">Cancel</button>
        <button class="btn-custom btn-custom-primary ms-2" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving) { <span>Saving...</span> } else { <span>Save Category</span> }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EditId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private ProjectCategoryFormModel _model = new();
    private bool _saving;

    private static readonly string[] SuggestedCategories = new[]
    {
        "Solar EPC", "Utility Scale Solar", "Rooftop Solar", "Electrical Substation", "O&M",
        "Electrical Testing", "Underground Cable", "HT/LT Panel", "Transmission Line",
        "Distribution Line", "Industrial Electrical", "Commercial Electrical", "Mechanical",
        "Civil Construction", "Infrastructure", "Water Treatment", "Manufacturing", "Facility Management"
    };

    private bool IsCurrentCategorySuggested => SuggestedCategories.Contains(_model.Name, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && EditId.HasValue)
        {
            var res = await CategoryApiClient.GetByIdAsync(EditId.Value);
            if (res.IsSuccess && res.Data != null)
            {
                _model = new ProjectCategoryFormModel
                {
                    OrganizationId = res.Data.OrganizationId,
                    Name = res.Data.Name,
                    Description = res.Data.Description,
                    IsActive = res.Data.IsActive,
                    IsSuggested = res.Data.IsSuggested
                };
            }
        }
        else if (IsOpen)
        {
            _model = new ProjectCategoryFormModel { IsActive = true };
        }
    }

    private void SelectSuggestedCategory(string name)
    {
        _model.Name = name;
        _model.IsSuggested = true;
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            Notifications.ShowError("Validation Error", "Category Name is required.");
            return;
        }

        _model.IsSuggested = IsCurrentCategorySuggested;
        _saving = true;
        try
        {
            if (EditId.HasValue)
            {
                var res = await CategoryApiClient.UpdateAsync(EditId.Value, _model);
                if (res.IsSuccess)
                {
                    Notifications.ShowSuccess("Success", "Project Category updated successfully.");
                    await OnSaved.InvokeAsync();
                    await OnClose.InvokeAsync();
                }
                else
                {
                    Notifications.ShowError("Error", res.Error?.Message ?? "Failed to update category.");
                }
            }
            else
            {
                var res = await CategoryApiClient.CreateAsync(_model);
                if (res.IsSuccess)
                {
                    Notifications.ShowSuccess("Success", "Project Category created successfully.");
                    await OnSaved.InvokeAsync();
                    await OnClose.InvokeAsync();
                }
                else
                {
                    Notifications.ShowError("Error", res.Error?.Message ?? "Failed to create category.");
                }
            }
        }
        finally
        {
            _saving = false;
        }
    }
}
