@page "/inventory"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Inventory
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Inventory
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Inventory.Components
@inject IInventoryApiClient InventoryApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IBranchApiClient BranchApiClient
@inject INotificationService Notifications

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Inventory</h1>
            <span class="text-caption text-secondary">Monitor stock levels, record movements, and track reorder points.</span>
        </div>
        <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
            <i class="lucide-plus"></i> New Item
        </button>
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading inventory..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load inventory" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="InventoryItemModel"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Inventory Item"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="i => i.Id.ToString()"
                   OnViewDetails="OpenDetails"
                   OnEdit="OpenEdit"
                   CustomRowActions="MovementAction" />
    }
</div>

<InventoryItemFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<StockMovementDialog IsOpen="_movementOpen" InventoryItemId="_movementItemId" ItemName="@_movementItemName"
                     OnClose="() => _movementOpen = false" OnCompleted="OnMovementCompleted" />

<InventoryDetailsDialog IsOpen="_detailsOpen" ItemId="_detailsId" OnClose="() => _detailsOpen = false"
                        Organizations="_orgNames" Branches="_branchNames" />

@code {
    private PagedResult<InventoryItemModel>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private bool _detailsOpen;
    private Guid? _detailsId;

    private bool _movementOpen;
    private Guid? _movementItemId;
    private string _movementItemName = "";

    private Dictionary<Guid, string> _orgNames = new();
    private Dictionary<Guid, string> _branchNames = new();
    private List<ColumnDefinition<InventoryItemModel>> _columns = new();

    private RenderFragment<InventoryItemModel> MovementAction => item =>
        @<button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenMovement(item)">
            <i class="lucide-package me-2"></i> Record Movement
        </button>;

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Item Code", PropertySelector = i => i.ItemCode, SortColumn = "ItemCode" },
            new() { Header = "Item Name", Sortable = true, SortColumn = "ItemName", Template = i =>
                @<span class="fw-semibold" style="color: var(--text-primary);">@i.ItemName</span> },
            new() { Header = "Warehouse", Sortable = false, Template = i =>
                @<span>@(i.BranchId is { } b && _branchNames.TryGetValue(b, out var n) ? n : "—")</span> },
            new() { Header = "Stock", Sortable = true, SortColumn = "CurrentStock", Template = i =>
                @<span>@i.CurrentStock @i.UnitOfMeasure</span> },
            new() { Header = "Available", Sortable = false, Template = i => @<span>@i.AvailableStock @i.UnitOfMeasure</span> },
            new() { Header = "Reorder Level", Sortable = false, Template = i => @<span>@i.ReorderLevel</span> },
            new() { Header = "Status", Sortable = false, Template = i =>
                @<span>
                    @if (i.IsLowStock)
                    {
                        <span class="badge-custom badge-custom-danger">Low Stock</span>
                    }
                    else
                    {
                        <span class="badge-custom @(i.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(i.IsActive ? "In Stock" : "Inactive")</span>
                    }
                </span> }
        };

        await LoadLookupsAsync();
        await LoadAsync(_query);
    }

    private async Task LoadLookupsAsync()
    {
        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null) _orgNames = orgs.Data.Items.ToDictionary(o => o.Id, o => o.Name);
        var branches = await BranchApiClient.GetPagedAsync(big);
        if (branches.IsSuccess && branches.Data is not null) _branchNames = branches.Data.Items.ToDictionary(b => b.Id, b => b.Name);
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await InventoryApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading inventory.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(InventoryItemModel item) { _editId = item.Id; _formOpen = true; }
    private void OpenDetails(InventoryItemModel item) { _detailsId = item.Id; _detailsOpen = true; }

    private void OpenMovement(InventoryItemModel item)
    {
        _movementItemId = item.Id;
        _movementItemName = $"{item.ItemCode} · {item.ItemName}";
        _movementOpen = true;
    }

    private async Task OnMovementCompleted()
    {
        _movementOpen = false;
        Notifications.ShowSuccess("Recorded", "Stock movement recorded.");
        await LoadAsync(_query);
    }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Inventory item saved successfully.");
        await LoadAsync(_query);
    }
}
