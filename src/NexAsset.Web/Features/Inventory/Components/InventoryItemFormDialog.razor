@using System.Globalization
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Inventory
@using NexAsset.Web.Models.Inventory
@using NexAsset.Web.Shared.Models
@inject IInventoryApiClient InventoryApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject IBranchApiClient BranchApiClient

<Dialog IsOpen="IsOpen" Title="@(IsEdit ? "Edit Inventory Item" : "New Inventory Item")" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (_loading)
        {
            <LoadingState Message="Loading item..." />
        }
        else
        {
            @if (!string.IsNullOrEmpty(_generalError))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                    <i class="lucide-alert-circle"></i> @_generalError
                </div>
            }
            <div class="row g-3">
                <SelectField Label="Organization" Required="true" Options="_orgOptions" Placeholder="Select an organization"
                             Value="@(_model.OrganizationId == Guid.Empty ? "" : _model.OrganizationId.ToString())"
                             ValueChanged="OnOrgChanged" Error='@Err("OrganizationId")' />
                <SelectField Label="Branch / Warehouse" Options="BranchOptions" Placeholder="(None)"
                             Value="@(_model.BranchId?.ToString() ?? "")"
                             ValueChanged="@(v => _model.BranchId = Guid.TryParse(v, out var g) ? g : null)"
                             Error='@Err("BranchId")' />
                <TextField Label="Item Code" Required="true" Value="@_model.ItemCode" ValueChanged="@(v => _model.ItemCode = v)" Error='@Err("ItemCode")' />
                <TextField Label="Item Name" Required="true" Value="@_model.ItemName" ValueChanged="@(v => _model.ItemName = v)" Error='@Err("ItemName")' />
                <TextField Label="Unit of Measure" Required="true" Value="@_model.UnitOfMeasure" ValueChanged="@(v => _model.UnitOfMeasure = v)" Error='@Err("UnitOfMeasure")' />
                <TextField Label="Reorder Level" Type="number" Value="@_reorderStr" ValueChanged="@(v => _reorderStr = v)" Error='@Err("ReorderLevel")' />
                @if (!IsEdit)
                {
                    <TextField Label="Opening Stock" Type="number" Value="@_stockStr" ValueChanged="@(v => _stockStr = v)" Error='@Err("CurrentStock")' />
                }
                <TextField Label="Description" ColumnClass="col-12" Multiline="true" Value="@_model.Description" ValueChanged="@(v => _model.Description = v)" Error='@Err("Description")' />
                @if (IsEdit)
                {
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="inv-active" checked="@_model.IsActive" @onchange="e => _model.IsActive = (bool)e.Value!" />
                            <label class="form-check-label text-caption" for="inv-active">Active</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <p class="text-caption text-secondary mb-0">
                            <i class="lucide-info me-1"></i> Stock levels are changed through stock movements, not by editing the item.
                        </p>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@(_saving || _loading)">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Save</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EditId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private InventoryItemFormModel _model = new();
    private string _stockStr = "0";
    private string _reorderStr = "0";
    private List<SelectField.Option> _orgOptions = new();
    private List<(Guid Id, Guid OrgId, string Label)> _branches = new();
    private bool _loading;
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private bool IsEdit => EditId.HasValue;
    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    private IReadOnlyList<SelectField.Option> BranchOptions => _branches
        .Where(b => b.OrgId == _model.OrganizationId)
        .Select(b => new SelectField.Option(b.Id.ToString(), b.Label)).ToList();

    private void OnOrgChanged(string v)
    {
        _model.OrganizationId = Guid.TryParse(v, out var g) ? g : Guid.Empty;
        if (_model.BranchId is { } b && !_branches.Any(x => x.Id == b && x.OrgId == _model.OrganizationId))
            _model.BranchId = null;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open) { _open = true; await InitializeAsync(); }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task InitializeAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        _model = new InventoryItemFormModel();
        _stockStr = "0";
        _reorderStr = "0";
        _loading = true;

        var big = new PagedQuery { PageNumber = 1, PageSize = 500, SortBy = "Name" };
        var orgs = await OrganizationApiClient.GetPagedAsync(big);
        if (orgs.IsSuccess && orgs.Data is not null)
            _orgOptions = orgs.Data.Items.Select(o => new SelectField.Option(o.Id.ToString(), $"{o.Code} — {o.Name}")).ToList();
        var branches = await BranchApiClient.GetPagedAsync(big);
        if (branches.IsSuccess && branches.Data is not null)
            _branches = branches.Data.Items.Select(b => (b.Id, b.OrganizationId, $"{b.Code} — {b.Name}")).ToList();

        if (EditId.HasValue)
        {
            var result = await InventoryApiClient.GetByIdAsync(EditId.Value);
            if (result.IsSuccess && result.Data is not null)
            {
                _model = InventoryItemFormModel.FromItem(result.Data);
                _reorderStr = _model.ReorderLevel.ToString(CultureInfo.InvariantCulture);
            }
            else
            {
                _generalError = result.Error?.Message ?? "Could not load this item.";
            }
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();

        if (_model.OrganizationId == Guid.Empty) _fieldErrors["OrganizationId"] = "Organization is required.";
        if (string.IsNullOrWhiteSpace(_model.ItemCode)) _fieldErrors["ItemCode"] = "Item code is required.";
        if (string.IsNullOrWhiteSpace(_model.ItemName)) _fieldErrors["ItemName"] = "Item name is required.";
        if (string.IsNullOrWhiteSpace(_model.UnitOfMeasure)) _fieldErrors["UnitOfMeasure"] = "Unit of measure is required.";
        if (!int.TryParse(_reorderStr, out var reorder) || reorder < 0) _fieldErrors["ReorderLevel"] = "Enter a valid number.";
        else _model.ReorderLevel = reorder;
        if (!IsEdit)
        {
            if (!int.TryParse(_stockStr, out var stock) || stock < 0) _fieldErrors["CurrentStock"] = "Enter a valid number.";
            else _model.CurrentStock = stock;
        }
        if (_fieldErrors.Count > 0) return;

        _saving = true;
        bool success;
        ApiError? error;
        if (IsEdit)
        {
            var res = await InventoryApiClient.UpdateAsync(EditId!.Value, _model);
            success = res.IsSuccess; error = res.Error;
        }
        else
        {
            var res = await InventoryApiClient.CreateAsync(_model);
            success = res.IsSuccess; error = res.Error;
        }
        _saving = false;

        if (!success)
        {
            _generalError = error?.Message ?? "Save failed. Please try again.";
            if (error?.FieldErrors is not null)
                foreach (var kv in error.FieldErrors)
                    _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
            return;
        }
        await OnSaved.InvokeAsync();
    }
}
