@using NexAsset.Web.Infrastructure.Users
@inject IUserApiClient UserApiClient
@inject NexAsset.Web.Infrastructure.Notifications.INotificationService Notify

<Dialog IsOpen="IsOpen" Title="@($"Reset password — {UserEmail}")" Size="sm" OnClose="OnClose">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">@_error</div>
        }
        <div class="row g-3">
            <TextField Label="New password" Required="true" ColumnClass="col-12" Type="password"
                       Value="@_password" ValueChanged="@(v => _password = v)" />
        </div>
        <div class="text-caption text-secondary mt-2">The user signs in with this password immediately; they are not notified.</div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Resetting...</span>
            }
            else
            {
                <i class="lucide-key-round"></i>
                <span>Reset Password</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? UserId { get; set; }
    [Parameter] public string UserEmail { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    private string _password = "";
    private string? _error;
    private bool _saving;
    private bool _open;

    protected override void OnParametersSet()
    {
        if (IsOpen && !_open) { _open = true; _password = ""; _error = null; }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task SaveAsync()
    {
        if (UserId is null) return;
        _error = null;

        if (string.IsNullOrWhiteSpace(_password) || _password.Length < 8)
        {
            _error = "Password must be at least 8 characters.";
            return;
        }

        _saving = true;
        var result = await UserApiClient.ResetPasswordAsync(UserId.Value, _password);
        _saving = false;

        if (!result.IsSuccess)
        {
            _error = result.Error?.Message ?? "Could not reset the password.";
            return;
        }

        Notify.ShowSuccess("Password reset", $"{UserEmail} can now sign in with the new password.");
        await OnClose.InvokeAsync();
    }
}
