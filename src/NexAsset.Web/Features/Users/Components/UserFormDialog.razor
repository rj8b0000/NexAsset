@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.HR
@using NexAsset.Web.Infrastructure.Users
@using NexAsset.Web.Models.HR
@using NexAsset.Web.Models.Users
@using NexAsset.Web.Shared.Models
@inject IUserApiClient UserApiClient
@inject IRoleApiClient RoleApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

@*
    Creates a standalone login account — one with no employee record, which therefore draws its
    permissions from the roles picked here. Logins for staff are created with the employee.
*@
<Dialog IsOpen="IsOpen" Title="New User" Size="md" OnClose="OnClose">
    <ChildContent>
        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">@_error</div>
        }

        <div class="p-3 rounded mb-3 text-caption" style="background-color: var(--bg-surface-hover); color: var(--text-secondary);">
            <i class="lucide-info me-1"></i>
            This creates a login with no employee record, so its access comes from the roles below.
            To give a staff member a login, create them under Employees instead — their access comes
            from their designation.
        </div>

        <div class="row g-3">
            <TextField Label="Email" Required="true" ColumnClass="col-12" Type="email"
                       Value="@_model.Email" ValueChanged="@(v => _model.Email = v)" Error='@Err("Email")' />
            <TextField Label="Password" Required="true" ColumnClass="col-12" Type="password"
                       Value="@_model.Password" ValueChanged="@(v => _model.Password = v)" Error='@Err("Password")' />

            @* The organization decides which data the account can see. Only a SuperAdmin may
               choose it (or leave it blank for a system-wide login); anyone else creating a
               user can only create it inside their own organization. *@
            @if (Perms.IsSuperAdmin)
            {
                <SelectField Label="Organization" ColumnClass="col-12" Options="_orgOptions"
                             Placeholder="All organizations (system-wide login)"
                             Value="@(_model.OrganizationId?.ToString() ?? "")"
                             ValueChanged="@(v => _model.OrganizationId = Guid.TryParse(v, out var g) ? g : null)"
                             Error='@Err("OrganizationId")' />
            }
            else
            {
                <div class="col-12">
                    <label class="form-label-custom">Organization</label>
                    <input class="form-control-custom" value="@(Perms.OrganizationName ?? "—")" disabled />
                </div>
            }
        </div>

        <div class="mt-3">
            <label class="form-label-custom">Roles</label>
            @if (_roles.Count == 0)
            {
                <div class="text-caption text-secondary">No roles exist yet.</div>
            }
            else
            {
                <div class="row g-2">
                    @foreach (var role in _roles)
                    {
                        <div class="col-6">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="role-@role"
                                       checked="@_model.Roles.Contains(role)"
                                       @onchange="() => ToggleRole(role)" />
                                <label class="form-check-label text-caption" for="role-@role" style="color: var(--text-primary);">@role</label>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Creating...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Create User</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private UserFormModel _model = new();
    private List<string> _roles = new();
    private List<SelectField.Option> _orgOptions = new();
    private Dictionary<string, string> _fieldErrors = new();
    private string? _error;
    private bool _saving;
    private bool _open;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open)
        {
            _open = true;
            // A non-SuperAdmin can only ever create users inside their own organization.
            _model = new UserFormModel { OrganizationId = Perms.IsSuperAdmin ? null : Perms.OrganizationId };
            _error = null;
            _fieldErrors = new();
            await LoadRolesAsync();
            if (Perms.IsSuperAdmin) await LoadOrganizationsAsync();
        }
        else if (!IsOpen && _open)
        {
            _open = false;
        }
    }

    private async Task LoadRolesAsync()
    {
        var result = await RoleApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 100, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _roles = result.Data.Items.Select(r => r.Name).ToList();
    }

    private async Task LoadOrganizationsAsync()
    {
        var result = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _orgOptions = result.Data.Items
                .Select(o => new SelectField.Option(o.Id.ToString(), $"{o.Code} — {o.Name}"))
                .ToList();
    }

    private void ToggleRole(string role)
    {
        if (!_model.Roles.Remove(role))
            _model.Roles.Add(role);
    }

    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    private async Task SaveAsync()
    {
        _error = null;
        _fieldErrors = new();
        _saving = true;
        var result = await UserApiClient.CreateAsync(_model);
        _saving = false;

        if (result.IsSuccess)
        {
            await OnSaved.InvokeAsync();
            return;
        }

        _error = result.Error?.Message ?? "Could not create this user.";
        if (result.Error?.FieldErrors is not null)
            foreach (var kv in result.Error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
