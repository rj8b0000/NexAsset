@page "/departments"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Foundation
@using NexAsset.Web.Features.Departments.Components
@inject IDepartmentApiClient DepartmentApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Departments</h1>
            <span class="text-caption text-secondary">Organize functional departments within each organization.</span>
        </div>
        @if (Perms.HasPermission("Departments.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Department
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading departments..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load departments" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="DepartmentListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Department"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="d => d.Id.ToString()"
                   OnEdit="OpenEdit"
                   EditPermission="Departments.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Departments.Delete" />
    }
</div>

<DepartmentFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="department"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<DepartmentListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private DepartmentListItem? _deleteTarget;

    private Dictionary<Guid, string> _orgNames = new();
    private List<ColumnDefinition<DepartmentListItem>> _columns = new();

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Code", PropertySelector = d => d.Code, SortColumn = "Code" },
            new() { Header = "Name", PropertySelector = d => d.Name, SortColumn = "Name" },
            new() { Header = "Organization", Sortable = false, Template = d =>
                @<span>@(_orgNames.TryGetValue(d.OrganizationId, out var n) ? n : "—")</span> },
            new() { Header = "Status", SortColumn = "IsActive", Template = d =>
                @<span class="badge-custom @(d.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(d.IsActive ? "Active" : "Inactive")</span> }
        };

        await LoadOrganizationNamesAsync();
        await LoadAsync(_query);
    }

    private async Task LoadOrganizationNamesAsync()
    {
        var result = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _orgNames = result.Data.Items.ToDictionary(o => o.Id, o => o.Name);
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await DepartmentApiClient.GetPagedAsync(query);
        _busy = false;

        if (result.IsSuccess && result.Data is not null)
            _page = result.Data;
        else
            _loadError = result.Error?.Message ?? "Something went wrong while loading departments.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(DepartmentListItem item) { _editId = item.Id; _formOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Department saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(DepartmentListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await DepartmentApiClient.DeleteAsync(target.Id);
        _busy = false;

        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Department \"{target.Name}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this department.");
        }
    }
}
