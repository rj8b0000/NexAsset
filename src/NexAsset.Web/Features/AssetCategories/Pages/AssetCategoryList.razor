@page "/asset-categories"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Assets
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Assets
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.AssetCategories.Components
@inject IAssetCategoryApiClient AssetCategoryApiClient
@inject IOrganizationApiClient OrganizationApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Asset Categories</h1>
            <span class="text-caption text-secondary">Classify assets into categories for reporting and organization.</span>
        </div>
        @if (Perms.HasPermission("AssetCategories.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Category
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading categories..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load categories" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="AssetCategoryListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Asset Category"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="c => c.Id.ToString()"
                   OnEdit="OpenEdit"
                   EditPermission="AssetCategories.Update"
                   OnDelete="AskDelete"
                   DeletePermission="AssetCategories.Delete" />
    }
</div>

<AssetCategoryFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="asset category"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<AssetCategoryListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private AssetCategoryListItem? _deleteTarget;

    private Dictionary<Guid, string> _orgNames = new();
    private List<ColumnDefinition<AssetCategoryListItem>> _columns = new();

    protected override async Task OnInitializedAsync()
    {
        _columns = new()
        {
            new() { Header = "Code", PropertySelector = c => c.Code, SortColumn = "Code" },
            new() { Header = "Name", PropertySelector = c => c.Name, SortColumn = "Name" },
            new() { Header = "Organization", Sortable = false, Template = c =>
                @<span>@(_orgNames.TryGetValue(c.OrganizationId, out var n) ? n : "—")</span> },
            new() { Header = "Status", SortColumn = "IsActive", Template = c =>
                @<span class="badge-custom @(c.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(c.IsActive ? "Active" : "Inactive")</span> }
        };

        await LoadOrganizationNamesAsync();
        await LoadAsync(_query);
    }

    private async Task LoadOrganizationNamesAsync()
    {
        var result = await OrganizationApiClient.GetPagedAsync(new PagedQuery { PageNumber = 1, PageSize = 200, SortBy = "Name" });
        if (result.IsSuccess && result.Data is not null)
            _orgNames = result.Data.Items.ToDictionary(o => o.Id, o => o.Name);
    }

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await AssetCategoryApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading categories.";
    }

    private void OpenCreate() { _editId = null; _formOpen = true; }
    private void OpenEdit(AssetCategoryListItem item) { _editId = item.Id; _formOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Asset category saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(AssetCategoryListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await AssetCategoryApiClient.DeleteAsync(target.Id);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Category \"{target.Name}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this category.");
        }
    }
}
