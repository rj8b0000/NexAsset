@page "/organizations"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.Foundation
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.Foundation
@using NexAsset.Web.Features.Organizations.Components
@inject IOrganizationApiClient OrganizationApiClient
@inject INotificationService Notifications
@inject NexAsset.Web.Infrastructure.Authentication.IPermissionChecker Perms

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Organizations</h1>
            <span class="text-caption text-secondary">Manage operational organizations, legal entities, and workspaces.</span>
        </div>
        @if (Perms.HasPermission("Organizations.Create"))
        {
            <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
                <i class="lucide-plus"></i> New Organization
            </button>
        }
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading organizations..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load organizations"
                    Description="@_loadError"
                    IconClass="lucide-alert-triangle"
                    ActionLabel="Retry"
                    ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="OrganizationListItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Organization"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="o => o.Id.ToString()"
                   OnEdit="OpenEdit"
                   EditPermission="Organizations.Update"
                   OnDelete="AskDelete"
                   DeletePermission="Organizations.Delete" />
    }
</div>

<OrganizationFormDialog IsOpen="_formOpen" EditId="_editId" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="organization"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<OrganizationListItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private OrganizationListItem? _deleteTarget;

    private readonly List<ColumnDefinition<OrganizationListItem>> _columns = new()
    {
        new() { Header = "Code", PropertySelector = o => o.Code, SortColumn = "Code" },
        new() { Header = "Name", PropertySelector = o => o.Name, SortColumn = "Name" },
        new() { Header = "Email", PropertySelector = o => o.Email, SortColumn = "Email" },
        new() { Header = "Status", SortColumn = "IsActive", Template = item =>
            @<span class="badge-custom @(item.IsActive ? "badge-custom-success" : "badge-custom-secondary")">@(item.IsActive ? "Active" : "Inactive")</span> }
    };

    protected override Task OnInitializedAsync() => LoadAsync(_query);

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await OrganizationApiClient.GetPagedAsync(query);
        _busy = false;

        if (result.IsSuccess && result.Data is not null)
            _page = result.Data;
        else
            _loadError = result.Error?.Message ?? "Something went wrong while loading organizations.";
    }

    private void OpenCreate()
    {
        _editId = null;
        _formOpen = true;
    }

    private void OpenEdit(OrganizationListItem item)
    {
        _editId = item.Id;
        _formOpen = true;
    }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Organization saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(OrganizationListItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await OrganizationApiClient.DeleteAsync(target.Id);
        _busy = false;

        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Organization \"{target.Name}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this organization.");
        }
    }
}
