@page "/roles"
@attribute [Authorize]
@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.HR
@using NexAsset.Web.Infrastructure.Notifications
@using NexAsset.Web.Models.HR
@using NexAsset.Web.Shared.Models
@using NexAsset.Web.Features.Roles.Components
@inject IRoleApiClient RoleApiClient
@inject INotificationService Notifications

<div class="animate-fade-in">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h1-title">Roles</h1>
            <span class="text-caption text-secondary">Manage access roles and their assigned permissions.</span>
        </div>
        <button class="btn-custom btn-custom-primary" @onclick="OpenCreate">
            <i class="lucide-plus"></i> New Role
        </button>
    </div>

    @if (_page is null && _loadError is null)
    {
        <LoadingState Message="Loading roles..." />
    }
    else if (_loadError is not null)
    {
        <EmptyState Title="Couldn't load roles" Description="@_loadError"
                    IconClass="lucide-alert-triangle" ActionLabel="Retry" ActionIconClass="lucide-rotate-cw"
                    OnActionClick="() => LoadAsync(_query)" />
    }
    else
    {
        <DataTable TItem="RoleItem"
                   Items="_page!.Items"
                   Columns="_columns"
                   Type="Role"
                   ServerMode="true"
                   ServerTotalCount="_page.TotalCount"
                   ServerPageNumber="_page.PageNumber"
                   ServerPageSize="_page.PageSize"
                   IsLoading="_busy"
                   OnQueryChanged="LoadAsync"
                   IdSelector="r => r.Id.ToString()"
                   OnEdit="OpenEdit"
                   OnDelete="AskDelete"
                   CustomRowActions="ManagePermissionsAction" />
    }
</div>

<RoleFormDialog IsOpen="_formOpen" EditId="_editId" EditName="_editName" OnClose="() => _formOpen = false" OnSaved="OnSaved" />

<RolePermissionsDialog IsOpen="_permsOpen" RoleId="_permsRoleId" RoleName="_permsRoleName" OnClose="() => _permsOpen = false" />

<ConfirmDeleteDialog IsOpen="_deleteTarget is not null" EntityLabel="role"
                     OnClose="() => _deleteTarget = null" OnConfirm="ConfirmDeleteAsync" />

@code {
    private PagedResult<RoleItem>? _page;
    private PagedQuery _query = new();
    private string? _loadError;
    private bool _busy;

    private bool _formOpen;
    private Guid? _editId;
    private string? _editName;

    private bool _permsOpen;
    private Guid? _permsRoleId;
    private string _permsRoleName = "";

    private RoleItem? _deleteTarget;

    private readonly List<ColumnDefinition<RoleItem>> _columns = new()
    {
        new() { Header = "Role Name", PropertySelector = r => r.Name, SortColumn = "Name" }
    };

    private RenderFragment<RoleItem> ManagePermissionsAction => role =>
        @<button class="dropdown-item py-2 px-3 w-100 text-start rounded text-caption border-0 bg-transparent" style="color: var(--text-primary);" @onclick="() => OpenPermissions(role)">
            <i class="lucide-key-round me-2"></i> Permissions
        </button>;

    protected override Task OnInitializedAsync() => LoadAsync(_query);

    private async Task LoadAsync(PagedQuery query)
    {
        _query = query;
        _loadError = null;
        _busy = true;
        var result = await RoleApiClient.GetPagedAsync(query);
        _busy = false;
        if (result.IsSuccess && result.Data is not null) _page = result.Data;
        else _loadError = result.Error?.Message ?? "Something went wrong while loading roles.";
    }

    private void OpenCreate() { _editId = null; _editName = null; _formOpen = true; }
    private void OpenEdit(RoleItem item) { _editId = item.Id; _editName = item.Name; _formOpen = true; }
    private void OpenPermissions(RoleItem item) { _permsRoleId = item.Id; _permsRoleName = item.Name; _permsOpen = true; }

    private async Task OnSaved()
    {
        _formOpen = false;
        Notifications.ShowSuccess("Saved", "Role saved successfully.");
        await LoadAsync(_query);
    }

    private void AskDelete(RoleItem item) => _deleteTarget = item;

    private async Task ConfirmDeleteAsync()
    {
        if (_deleteTarget is null) return;
        var target = _deleteTarget;
        _deleteTarget = null;
        _busy = true;
        var result = await RoleApiClient.DeleteAsync(target.Id);
        _busy = false;
        if (result.IsSuccess)
        {
            Notifications.ShowSuccess("Deleted", $"Role \"{target.Name}\" was deleted.");
            await LoadAsync(_query);
        }
        else
        {
            Notifications.ShowError("Delete failed", result.Error?.Message ?? "Could not delete this role.");
        }
    }
}
