@using NexAsset.Web.Infrastructure.API
@using NexAsset.Web.Infrastructure.HR
@using NexAsset.Web.Models.HR
@inject IPermissionApiClient PermissionApiClient

<Dialog IsOpen="IsOpen" Title="@(IsEdit ? "Edit Permission" : "New Permission")" Size="lg" OnClose="OnClose">
    <ChildContent>
        @if (_loading)
        {
            <LoadingState Message="Loading permission..." />
        }
        else
        {
            @if (!string.IsNullOrEmpty(_generalError))
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2 px-3 border-0 text-caption rounded-3 mb-3" style="background-color: var(--danger-light); color: var(--danger);">
                    <i class="lucide-alert-circle"></i> @_generalError
                </div>
            }
            <div class="row g-3">
                <TextField Label="Code" Required="true" Value="@_model.Code" ValueChanged="@(v => _model.Code = v)" Error='@Err("Code")' />
                <TextField Label="Name" Required="true" Value="@_model.Name" ValueChanged="@(v => _model.Name = v)" Error='@Err("Name")' />
                <TextField Label="Description" ColumnClass="col-12" Multiline="true" Value="@_model.Description" ValueChanged="@(v => _model.Description = v)" Error='@Err("Description")' />
                @if (IsEdit)
                {
                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="perm-active" checked="@_model.IsActive" @onchange="e => _model.IsActive = (bool)e.Value!" />
                            <label class="form-check-label text-caption" for="perm-active">Active</label>
                        </div>
                    </div>
                }
            </div>
        }
    </ChildContent>
    <FooterContent>
        <button class="btn-custom btn-custom-secondary" @onclick="OnClose" disabled="@_saving">Cancel</button>
        <button class="btn-custom btn-custom-primary" @onclick="SaveAsync" disabled="@(_saving || _loading)">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                <span>Saving...</span>
            }
            else
            {
                <i class="lucide-save"></i>
                <span>Save</span>
            }
        </button>
    </FooterContent>
</Dialog>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public Guid? EditId { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }

    private PermissionFormModel _model = new();
    private bool _loading;
    private bool _saving;
    private string? _generalError;
    private Dictionary<string, string> _fieldErrors = new();
    private bool _open;

    private bool IsEdit => EditId.HasValue;
    private string? Err(string field) => _fieldErrors.TryGetValue(field, out var e) ? e : null;

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !_open) { _open = true; await InitializeAsync(); }
        else if (!IsOpen && _open) { _open = false; }
    }

    private async Task InitializeAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        _model = new PermissionFormModel();

        if (EditId.HasValue)
        {
            _loading = true;
            var result = await PermissionApiClient.GetByIdAsync(EditId.Value);
            _loading = false;
            if (result.IsSuccess && result.Data is not null)
                _model = PermissionFormModel.FromDetail(result.Data);
            else
                _generalError = result.Error?.Message ?? "Could not load this permission.";
        }
    }

    private async Task SaveAsync()
    {
        _generalError = null;
        _fieldErrors = new();
        if (string.IsNullOrWhiteSpace(_model.Code)) _fieldErrors["Code"] = "Code is required.";
        if (string.IsNullOrWhiteSpace(_model.Name)) _fieldErrors["Name"] = "Name is required.";
        if (_fieldErrors.Count > 0) return;

        _saving = true;
        bool success;
        ApiError? error;
        if (IsEdit)
        {
            var res = await PermissionApiClient.UpdateAsync(EditId!.Value, _model);
            success = res.IsSuccess; error = res.Error;
        }
        else
        {
            var res = await PermissionApiClient.CreateAsync(_model);
            success = res.IsSuccess; error = res.Error;
        }
        _saving = false;

        if (!success) { ApplyError(error); return; }
        await OnSaved.InvokeAsync();
    }

    private void ApplyError(ApiError? error)
    {
        _generalError = error?.Message ?? "Save failed. Please try again.";
        if (error?.FieldErrors is not null)
            foreach (var kv in error.FieldErrors)
                _fieldErrors[kv.Key] = string.Join(" ", kv.Value);
    }
}
