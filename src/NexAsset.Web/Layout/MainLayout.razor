@inherits LayoutComponentBase
@using NexAsset.Web.State
@using NexAsset.Web.Features.Dashboard.Components
@inject AuthenticationState AuthenticationState
@inject NavigationState NavigationState
@implements IDisposable

@if (!AuthenticationState.IsAuthenticated)
{
    <LoginPage />
}
else
{
    <div class="app-layout @(NavigationState.SidebarCollapsed ? "sidebar-collapsed" : "")">
        <!-- Left Sidebar -->
        <Sidebar />
        
        <!-- Topbar Header -->
        <Topbar />
        
        <!-- Core Main Content Window -->
        <main class="content-slot">
            @Body
        </main>
    </div>
}

<!-- Global Toast Notification Queue -->
<Toast />

@code {
    protected override void OnInitialized()
    {
        AuthenticationState.OnChange += StateHasChanged;
        NavigationState.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthenticationState.OnChange -= StateHasChanged;
        NavigationState.OnChange -= StateHasChanged;
    }
}