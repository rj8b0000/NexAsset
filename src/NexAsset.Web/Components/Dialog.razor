@if (IsOpen)
{
    <div class="modal-backdrop-custom d-flex align-items-center justify-content-center" style="position: fixed; inset: 0; background-color: rgba(15, 23, 42, 0.4); backdrop-filter: blur(4px); z-index: 2000; animation: fadeIn 0.15s ease-out forwards;">
        <div class="card-custom p-0 animate-fade-in" style="width: 100%; max-width: @GetMaxWidth(); overflow: hidden; border: 1px solid var(--border-color); box-shadow: var(--shadow-lg); animation: scaleUp 0.2s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;">
            <!-- Header -->
            <div class="p-3 border-bottom d-flex align-items-center justify-content-between" style="background-color: var(--bg-surface-hover);">
                <h3 class="h2-title mb-0">@Title</h3>
                <button type="button" class="btn-custom btn-custom-secondary p-1" style="border-radius: 50%; border-color: transparent; width: 30px; height: 30px;" @onclick="Close">
                    <i class="lucide-x"></i>
                </button>
            </div>

            <!-- Content Body -->
            <div class="p-4" style="max-height: 70vh; overflow-y: auto; background-color: var(--bg-surface);">
                @ChildContent
            </div>

            <!-- Footer Actions -->
            @if (FooterContent != null)
            {
                <div class="p-3 border-top d-flex align-items-center justify-content-end gap-2" style="background-color: var(--bg-surface-hover);">
                    @FooterContent
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; } = false;
    [Parameter] public string Title { get; set; } = "Dialog";
    [Parameter] public string Size { get; set; } = "md"; // sm, md, lg
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? FooterContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private void Close()
    {
        OnClose.InvokeAsync();
    }

    private string GetMaxWidth()
    {
        return Size.ToLower() switch
        {
            "sm" => "400px",
            "lg" => "800px",
            _ => "550px"
        };
    }
}
